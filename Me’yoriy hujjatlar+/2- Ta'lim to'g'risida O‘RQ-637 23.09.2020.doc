<style type="text/css">BODY{scrollbar-base-color:scrollbar;scrollbar-highlight-color:white;scrollbar-darkshadow-color:scrollbar;scrollbar-shadow-color:white;}#divCont DIV{border:none;white-space:normal;}#divCont IMG{float:none;vertical-align:middle;}#divCont A{text-decoration:none;}#divCont A:link{color:#008080;}#divCont A:visited{color:#008080;}#divCont A:hover{color:#ff0000;}#divCont P{margin:0px;padding:0px;line-height:1.0;}#divCont LABEL{display:none;}.aExp{text-align:left;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:normal;color:red;font-weight:600;font-size:12pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.aOAD{width:100%;text-align:right;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:italic;color:#808080;font-weight:400;font-size:10pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.signCont{text-align:center;margin:0pt 0pt 12pt 0px;text-indent:0pt;}.mrkup{background-color:#00008B!important;color:#FFFFFF!important;}.mrkupNav{color:#00008B!important;}.mrkupNav SPAN{font:12px Webdings!important;padding:0px 2px!important;}.iorRN{font-weight:600;}.iorVal{text-indent:0px;margin-left:1px;}.clausePrfx{display:inline;float:left;}.clauseSuff{display:block;width:100%;text-indent:0px;}@media print{.clausePrfx{float:none;}.clauseSuff{display:inline;width:auto;}}.ACCEPTING_BODY{text-align:center; text-indent:0; margin:0 0 0 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman";font-variant:normal; line-height:normal;text-transform:uppercase;}.ACT_ESSENTIAL_ELEMENTS{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.ACT_ESSENTIAL_ELEMENTS_NUM{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;padding-bottom: 20px;}.ACT_FORM{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_FORM_LAW{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TEXT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.ACT_TITLE{text-align:center; text-indent:0; margin:12pt 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TITLE_APPL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 10pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TITLE{text-align:center; text-indent:0pt; margin:10pt 0pt 12pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 0pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TITLE{text-align:center; text-indent:0pt; margin:0pt 0pt 12pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.BY_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:0; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CHANGES_ORIGINS{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CLAUSE_AFTER_SRC{text-align:justify;text-justify:inter-word; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:boldl; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.CLAUSE_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT_FOR_WARNING{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.DEPARTMENTAL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.EXPLANATION{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:normal; color:#993366; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; line-height:normal;}.EXTRACT{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.FOOTNOTE{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#339966; font-weight:normal; font-size:10pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.GRIF_PARLAMENT{text-align: left; text-indent:0 mm; margin:0 0 3pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.INDEXES_ON_REF{text-align:left;text-indent:0cm;margin:3pt 0.9cm 3pt 0.95cm;font-style:normal;color:#008000;font-weight:normal;font-size:11pt;font-family:"Times New Roman"; font-variant:normal;line-height:1.0;}.IS_TABLE_FOR_LIST_TEMP{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.NEW_EDITION{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:lowercase; font-variant:normal; line-height:normal;}.OFFICIAL_SOUR_TEXT{text-align:right; font-size:8pt; font-family:Arial, Helvetica, sans-serif; border: 1px solid #A9DBFC; background-color: #E6EDFF;}.PUBLICATION_ORIGIN{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE_STAMPS_PLACEHOLDER{text-align:justify; text-justify:inter-word; text-indent:0; margin:4 10; vertical-align:text-top; flow:left;}.SIGNATURE_STAMP_TEXT{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; vertical-align:baseline!important;}.SIGNATURE_WITH_BOLD{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TABLE_STD{background:#ffffff;color:#000000;margin:4pt;font-size:12pt;width:100%;height:100%;overflow:visible;}.TEXT_15_LEFT{text-align: left; text-indent:30 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_30_LEFT{text-align: left; text-indent:45 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD{text-align:justify;  text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;text-indent:15mm;}.TEXT_BOLD_CENTER{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD_RIGHT{text-align:right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_CENTER{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_AFTER_SRC{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_DEFAULT{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_ITALIC{text-align:justify; text-indent:0; margin:0; font-style:italic; color:#000080; font-weight:italic; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal; text-indent:15mm}.TEXT_RIGHT{text-align: right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}DIV#theSysCssID TABLE{background-color:ivory;color:#000000;border-collapse:separate;font:x-small Tahoma;table-layout:auto;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theSysCssID TABLE TD,TH{border:1px solid #000000;cursor:auto;min-height:8pt;padding:1px 1px 1px 2px;vertical-align:top;white-space:normal;word-wrap:break-word;display:block!important;visibility:visible!important;}DIV#theNormCssID TABLE{background-color:#f5f5f5;color:red;border:1px solid red;font:small Verdana;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNormCssID TABLE TD,TH{border:1px solid red;cursor:auto;min-height:8pt;padding:2px 2px 2px 3px;vertical-align:top;white-space:normal;word-wrap:normal;display:block!important;visibility:visible!important;}DIV#theDefCssID TABLE{background-color:#ffffff;color:#000000;border:1px solid #000000;border-collapse:collapse;font:normal normal normal small/normal Times New Roman;table-layout:fixed;text-align:left;text-decoration:none;text-indent:0;text-transform:none;width:100%;word-spacing:normal;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theDefCssID TABLE TD,TH{background-color:#ffffff;color:#000000;border:1px solid #000000;cursor:auto!important;font:normal normal normal small/normal Times New Roman;min-height:8pt;padding:1px 1px 1px 2px;text-align:left;text-decoration:none;text-indent:0;text-transform:none;vertical-align:top;white-space:normal;word-wrap:break-word;word-spacing:normal;display:block!important;visibility:visible!important;}DIV#theNotCssID TABLE{position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNotCssID TABLE TD,TH,CAPTION{display:block!important;visibility:visible!important;}A#tabBoxDisable TABLE TD,TH{color:#808080;border-color:#808080;}.tabBox{display:inline-block;} .OFFICIAL_SOUR_TEXT{display:none;}</style>
</head>
<body lang='uz-Latn-UZ'><div class=WordSection1>
﻿<div id="divCont" style="background:#ffffff;border:none;margin:auto;"><div class="ACT_FORM"><div name="-5013027" id="-5013027">Oʻzbekiston Respublikasining Qonuni</div></div><div class="ACT_TITLE"><div name="-5013028" id="-5013028">Taʼlim toʻgʻrisida</div></div><div class="GRIF_PARLAMENT"><div name="-5013033" id="-5013033">Qonunchilik palatasi tomonidan 2020-yil 19-mayda qabul qilingan <br />Senat tomonidan 2020-yil 7-avgustda maʼqullangan </div></div><div class="BY_DEFAULT"><div name="-5013035" id="-5013035"></div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5013038" id="-5013038">1-bob. Umumiy qoidalar</div></div><div class="CLAUSE_DEFAULT"><div name="-5013040" id="-5013040">1-modda. Ushbu Qonunning maqsadi</div></div><div class="ACT_TEXT"><div name="-5013044" id="-5013044">Ushbu Qonunning maqsadi taʼlim sohasidagi munosabatlarni tartibga solishdan iborat.</div></div><div class="BY_DEFAULT"><div name="-5591326" id="-5591326"></div></div><div class="CLAUSE_DEFAULT"><div name="-5591329" id="-5591329">2-modda. Taʼlim toʻgʻrisidagi qonunchilik</div></div><div class="ACT_TEXT"><div name="-5591334" id="-5591334">Taʼlim toʻgʻrisidagi qonunchilik ushbu Qonun va boshqa qonunchilik hujjatlaridan iboratdir.</div></div><div class="ACT_TEXT"><div name="-5591336" id="-5591336">Agar Oʻzbekiston Respublikasining xalqaro shartnomasida Oʻzbekiston Respublikasining taʼlim toʻgʻrisidagi qonunchiligida nazarda tutilganidan boshqacha qoidalar belgilangan boʻlsa, xalqaro shartnoma qoidalari qoʻllaniladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591346" id="-5591346"><em>(</em>2-modda <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405530">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son)</em><em> </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5013049" id="-5013049">3-modda. Asosiy tushunchalar </div></div><div class="ACT_TEXT"><div name="-5013053" id="-5013053">Ushbu Qonunda quyidagi asosiy tushunchalar qoʻllaniladi:</div></div><div class="ACT_TEXT"><div name="-5013057" id="-5013057">davlat akkreditatsiyasi — davlat taʼlim muassasalari va tashkilotlari, shuningdek nodavlat taʼlim tashkilotlari (bundan buyon matnda taʼlim tashkilotlari deb yuritiladi) faoliyatining davlat taʼlim standartlari va davlat taʼlim talablariga hamda oʻquv dasturlariga muvofiqligining davlat tomonidan eʼtirof etilishi hamda ularning bitiruvchilariga maʼlumot toʻgʻrisidagi hujjatlarni topshirish huquqining taqdim etilishidan iborat jarayon; </div></div><div class="ACT_TEXT"><div name="-5013059" id="-5013059">davlat taʼlim muassasasi — davlat hokimiyati va boshqaruvi organlari tomonidan davlat mulki boʻlgan mol-mulk negizida tashkil etilgan, davlat taʼlim standartlariga va davlat taʼlim talablariga muvofiq taʼlim beradigan muassasa;</div></div><div class="ACT_TEXT"><div name="-5013061" id="-5013061">davlat taʼlim standartlari — davlat tomonidan taʼlimning mazmuni va sifatiga nisbatan belgilanadigan talablar majmui;</div></div><div class="ACT_TEXT"><div name="-5013062" id="-5013062">davlat taʼlim talablari — taʼlimning tuzilmasiga, mazmuniga va uni amalga oshirish shart-sharoitlariga, shuningdek taʼlim oluvchilarning jismoniy, shaxsiy, intellektual, ilmiy hamda kasbiy sifatlariga qoʻyiladigan majburiy talablar; </div></div><div class="BY_DEFAULT"><div name="-7098430" id="-7098430"></div></div><div class="ACT_TEXT"><div name="-7098432" id="-7098432">kompleks davlat akkreditatsiyasi — oʻrta maxsus, professional, oliy taʼlimni va oliy taʼlimdan keyingi taʼlimni, shuningdek kadrlarni tayyorlash va qayta tayyorlashni amalga oshiruvchi davlat va nodavlat taʼlim tashkilotlarini tashqi baholash natijalariga asoslangan jarayon;</div></div><div class="ACT_TEXT"><div name="-7098433" id="-7098433">maxsus davlat akkreditatsiyasi — oʻrta maxsus, professional, oliy taʼlimni va oliy taʼlimdan keyingi taʼlimni, shuningdek kadrlarni qayta tayyorlash va ularning malakasini oshirishni amalga oshiruvchi davlat va nodavlat taʼlim tashkilotlarida taʼlim dasturlari boʻyicha oʻquv jarayoni boshlanishidan oldin amalga oshiriladigan jarayon;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098435" id="-7098435">(3-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094135">Qonuniga </a>asosan oltinchi va yettinchi xatboshilar bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013065" id="-5013065">malaka — shaxsning kasbiy faoliyatning muayyan turini bajarishga tayyorgarligini ifodalaydigan, maʼlumot toʻgʻrisidagi tegishli hujjat bilan tasdiqlanadigan bilim, qobiliyat, mahorat va koʻnikmalar darajasi;</div></div><div class="ACT_TEXT"><div name="-5013068" id="-5013068">mutaxassislik — malaka berish bilan yakunlanadigan muayyan kasbiy tayyorgarlik turining nomi;</div></div><div class="BY_DEFAULT"><div name="-5685027" id="-5685027"></div></div><div class="ACT_TEXT"><div name="-5685028" id="-5685028">nodavlat taʼlim tashkiloti — davlat taʼlim standartlari, davlat taʼlim talablari va oʻquv dasturlariga muvofiq taʼlim xizmatlari koʻrsatish faoliyatini amalga oshirish huquqini beradigan litsenziya asosida yoki xabardor qilish tartibida taʼlim xizmatlari koʻrsatuvchi yuridik shaxs; </div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5685029" id="-5685029">(3-moddaning sakkizinchi xatboshisi Oʻzbekiston Respublikasining 2021-yil 12-oktabrdagi OʻRQ-721-sonli <a href="https://lex.uz/uz/docs/-5674701?ONDATE=12.10.2021 00#-5675918">Qonuni</a> tahririda — Qonunchilik maʼlumotlari milliy bazasi, 12.10.2021-y., 03/21/721/0952-son)</div></div><div class="ACT_TEXT"><div name="-5013073" id="-5013073">tarbiya — aniq maqsadli hamda ijtimoiy-tarixiy tajriba asosida yosh avlodni har tomonlama kamol toptirishga, ularning ongini, maʼnaviy-axloqiy qadriyatlar va dunyoqarashini shakllantirishga qaratilgan tizimli jarayon;</div></div><div class="ACT_TEXT"><div name="-5013075" id="-5013075">taʼlim — taʼlim oluvchilarga chuqur nazariy bilim, malakalar va amaliy koʻnikmalar berishga, shuningdek ularning umumtaʼlim va kasbiy bilim, malaka hamda koʻnikmalarini shakllantirishga, qobiliyatini rivojlantirishga qaratilgan tizimli jarayon; </div></div><div class="BY_DEFAULT"><div name="-7098438" id="-7098438"></div></div><div class="ACT_TEXT"><div name="-7098440" id="-7098440">taʼlim dasturi — davlat taʼlim standartlariga, kasb standartlariga va milliy (tarmoq) malaka doirasiga muvofiq ishlab chiqilgan taʼlim standartlaridan, oʻquv rejalaridan, oʻquv dasturlaridan va tegishli uslubiy koʻrsatmalardan iborat normativ-uslubiy hujjatlar majmui;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098446" id="-7098446">(3-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094139">Qonuniga </a>asosan oʻn uchinchi xatboshi bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013077" id="-5013077">taʼlim kampusi — yagona hududda birlashtirilgan oʻquv binolarini, ilmiy-tadqiqot institutlarini (markazlarini), ishlab chiqarish majmualari va texnoparklarni, taʼlim-tarbiya jarayoni ishtirokchilarining vaqtincha yashash joylarini, laboratoriyalarni, axborot-resurs markazlarini (kutubxonalarni), sport inshootlarini, umumiy ovqatlanish obyektlarini oʻz ichiga olgan binolar hamda inshootlar majmuidan iborat boʻlgan, oʻquv jarayoni, maʼnaviy-axloqiy tarbiyaning yuqori samaradorligini taʼminlaydigan taʼlim-tarbiya muhiti;</div></div><div class="ACT_TEXT"><div name="-5013079" id="-5013079">taʼlim-tarbiya jarayoni ishtirokchilari — taʼlim oluvchilar, voyaga yetmagan taʼlim oluvchilarning ota-onalari yoki boshqa qonuniy vakillari, pedagog xodimlar va ularning vakillari;</div></div><div class="ACT_TEXT"><div name="-5013081" id="-5013081">taʼlim tashkilotlari attestatsiyasi — taʼlim tashkilotlarining faoliyatini baholash, davlat taʼlim standartlari, davlat taʼlim talablari hamda oʻquv dasturlariga muvofiq kadrlar tayyorlash mazmuni, darajasi va sifatini aniqlash boʻyicha davlat nazoratining asosiy shakli;</div></div><div class="BY_DEFAULT"><div name="-7098448" id="-7098448"></div></div><div class="ACT_TEXT"><div name="-7098449" id="-7098449">xalqaro akkreditatsiya — taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari tomonidan Oʻzbekiston Respublikasi hududida faoliyatni amalga oshirishga vakolat berilgan va xalqaro akkreditatsiya tashkilotlarining reyestriga kiritilgan xalqaro taʼlim sifatini taʼminlash tarmoqlarining toʻla huquqli aʼzosi boʻlgan xalqaro akkreditatsiya tashkilotlari tomonidan amalga oshiriladigan jarayon.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098451" id="-7098451">(3-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094142">Qonuniga </a>asosan oʻn yettinchi xatboshi bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013083" id="-5013083">4-modda. Taʼlim sohasidagi asosiy prinsiplar</div></div><div class="ACT_TEXT"><div name="-5013087" id="-5013087">Taʼlim sohasidagi asosiy prinsiplar quyidagilardan iborat:</div></div><div class="ACT_TEXT"><div name="-5013090" id="-5013090">taʼlim ustuvorligining tan olinishi;</div></div><div class="ACT_TEXT"><div name="-5013094" id="-5013094">taʼlim olish shaklini tanlash erkinligi;</div></div><div class="ACT_TEXT"><div name="-5013097" id="-5013097">taʼlim sohasida kamsitishlarga yoʻl qoʻyilmasligi;</div></div><div class="ACT_TEXT"><div name="-5013100" id="-5013100">taʼlim olishga doir teng imkoniyatlarning taʼminlanishi; </div></div><div class="ACT_TEXT"><div name="-5013101" id="-5013101">taʼlim va tarbiyaga milliy hamda umuminsoniy qadriyatlarning singdirilganligi;</div></div><div class="ACT_TEXT"><div name="-5013105" id="-5013105">taʼlim va tarbiyaning insonparvarlik, demokratik xususiyati;</div></div><div class="ACT_TEXT"><div name="-5013106" id="-5013106">taʼlimning uzluksizligi va izchilligi;</div></div><div class="ACT_TEXT"><div name="-5013109" id="-5013109">oʻn bir yillik taʼlimning hamda olti yoshdan yetti yoshgacha boʻlgan bolalarni bir yil davomida umumiy oʻrta taʼlimga tayyorlashning majburiyligi;</div></div><div class="ACT_TEXT"><div name="-5013113" id="-5013113">davlat taʼlim standartlari va davlat taʼlim talablari doirasida taʼlim olishning hamma uchun ochiqligi;</div></div><div class="ACT_TEXT"><div name="-5013114" id="-5013114">oʻquv dasturlarini tanlashga doir yondashuvning yagonaligi va tabaqalashtirilganligi; </div></div><div class="ACT_TEXT"><div name="-5013117" id="-5013117">insonning butun hayoti davomida taʼlim olishi;</div></div><div class="ACT_TEXT"><div name="-5013119" id="-5013119">jamiyatda pedagoglarni ijtimoiy himoya qilishning kafolatlanganligi;</div></div><div class="ACT_TEXT"><div name="-5013122" id="-5013122">taʼlim tizimining dunyoviy xususiyatga egaligi;</div></div><div class="ACT_TEXT"><div name="-5013125" id="-5013125">bilimlilik, qobiliyatlilik va isteʼdodning ragʻbatlantirilishi;</div></div><div class="ACT_TEXT"><div name="-5013126" id="-5013126">taʼlim tizimida davlat va jamoat boshqaruvining uygʻunligi;</div></div><div class="ACT_TEXT"><div name="-5013129" id="-5013129">taʼlim faoliyati sohasidagi ochiqlik va shaffoflik.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013133" id="-5013133">5-modda. Taʼlim olish huquqi</div></div><div class="BY_DEFAULT"><div name="-7112164" id="-7112164"></div></div><div class="ACT_TEXT"><div name="-7112169" id="-7112169">Jinsi, irqi, millati, tili, dini, eʼtiqodi, ijtimoiy kelib chiqishi, ijtimoiy mavqeyidan qatʼi nazar, har kimga taʼlim olish uchun teng huquqlar kafolatlanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7112170" id="-7112170">(5-moddaning birinchi qismi Oʻzbekiston Respublikasining 2024-yil 20-sentabrdagi OʻRQ-963-sonli <a href="https://lex.uz/uz/docs/-7108715?ONDATE=21.09.2024 00#-7108818">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.09.2024-y., 03/24/963/0735-son)</div></div><div class="ACT_TEXT"><div name="-5013190" id="-5013190">Taʼlim olish huquqi: </div></div><div class="ACT_TEXT"><div name="-5013191" id="-5013191">taʼlim tashkilotlarini rivojlantirish;</div></div><div class="ACT_TEXT"><div name="-5013192" id="-5013192">taʼlim tashkilotlarida innovatsion faoliyatni qoʻllab-quvvatlash va oʻquv dasturlarini innovatsion texnologiyalarni qoʻllagan holda amalga oshirish; </div></div><div class="ACT_TEXT"><div name="-5013193" id="-5013193">ishlab chiqarishdan ajralgan (kunduzgi) va ajralmagan holda (sirtqi, kechki, masofaviy) taʼlim olishni tashkil etish;</div></div><div class="ACT_TEXT"><div name="-5013194" id="-5013194">kadrlarni tayyorlash, qayta tayyorlash va ularning malakasini oshirish;</div></div><div class="ACT_TEXT"><div name="-5013195" id="-5013195">umumiy oʻrta, oʻrta maxsus taʼlimni va boshlangʻich professional taʼlimni bepul olish;</div></div><div class="ACT_TEXT"><div name="-5013196" id="-5013196">oilada yoki mustaqil oʻqish orqali taʼlim olgan fuqarolarga, shuningdek umumiy oʻrta taʼlim olmagan shaxslarga akkreditatsiyadan oʻtgan davlat taʼlim muassasalarida eksternat tartibida attestatsiyadan oʻtish huquqini berish orqali taʼminlanadi.</div></div><div class="BY_DEFAULT"><div name="-5591339" id="-5591339"></div></div><div class="ACT_TEXT"><div name="-5591340" id="-5591340">Chet ellik fuqarolar Oʻzbekiston Respublikasining xalqaro shartnomalariga va qonunchiligiga muvofiq Oʻzbekiston Respublikasida taʼlim olishga haqlidir.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591342" id="-5591342"><em>(</em>5-moddaning uchinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405544">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5013198" id="-5013198">Oʻzbekiston Respublikasida doimiy yashayotgan fuqaroligi boʻlmagan shaxslar taʼlim olish uchun Oʻzbekiston Respublikasi fuqarolari bilan teng huquqlarga ega.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5013199" id="-5013199">2-bob. Taʼlim tizimi, turlari va shakllari</div></div><div class="CLAUSE_DEFAULT"><div name="-5013200" id="-5013200">6-modda. Taʼlim tizimi</div></div><div class="ACT_TEXT"><div name="-5013201" id="-5013201">Taʼlim tizimi:</div></div><div class="ACT_TEXT"><div name="-5013202" id="-5013202">davlat taʼlim standartlarini, davlat taʼlim talablarini, oʻquv rejalari va oʻquv dasturlarini;</div></div><div class="ACT_TEXT"><div name="-5013203" id="-5013203">davlat taʼlim standartlarini, davlat taʼlim talablari va oʻquv dasturlarini amalga oshiruvchi taʼlim tashkilotlarini;</div></div><div class="ACT_TEXT"><div name="-5013205" id="-5013205">taʼlim sifatini baholashni amalga oshiruvchi tashkilotlarni;</div></div><div class="ACT_TEXT"><div name="-5013206" id="-5013206">taʼlim tizimining faoliyat koʻrsatishi va rivojlanishini taʼminlash uchun zarur boʻlgan tadqiqot ishlarini bajaruvchi ilmiy-pedagogik muassasalarni;</div></div><div class="ACT_TEXT"><div name="-5013207" id="-5013207">taʼlim sohasidagi davlat boshqaruvi organlarini, shuningdek ularning tasarrufidagi tashkilotlarni oʻz ichiga oladi.</div></div><div class="ACT_TEXT"><div name="-5013208" id="-5013208">Taʼlim tizimi yagona va uzluksizdir.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013209" id="-5013209">7-modda. Taʼlim turlari</div></div><div class="ACT_TEXT"><div name="-5013211" id="-5013211">Taʼlim turlari quyidagilardan iborat:</div></div><div class="ACT_TEXT"><div name="-5013212" id="-5013212">maktabgacha taʼlim va tarbiya;</div></div><div class="ACT_TEXT"><div name="-5013214" id="-5013214">umumiy oʻrta va oʻrta maxsus taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013218" id="-5013218">professional taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013220" id="-5013220">oliy taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013221" id="-5013221">oliy taʼlimdan keyingi taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013223" id="-5013223">kadrlarni qayta tayyorlash va ularning malakasini oshirish;</div></div><div class="BY_DEFAULT"><div name="-7803131" id="-7803131"></div></div><div class="ACT_TEXT"><div name="-7803133" id="-7803133">qoʻshimcha taʼlim.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803137" id="-7803137">(7-moddaning sakkizinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789615">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013227" id="-5013227">8-modda. Maktabgacha taʼlim va tarbiya</div></div><div class="ACT_TEXT"><div name="-5013229" id="-5013229">Maktabgacha taʼlim va tarbiya bolalarni oʻqitish va tarbiyalashga, ularni intellektual, maʼnaviy-axloqiy, etik, estetik va jismoniy jihatdan rivojlantirishga, shuningdek bolalarni umumiy oʻrta taʼlimga tayyorlashga qaratilgan taʼlim turidir.</div></div><div class="ACT_TEXT"><div name="-5013230" id="-5013230">Maktabgacha taʼlim va tarbiya olti yoshdan yetti yoshgacha boʻlgan bolalarni boshlangʻich taʼlimga bir yillik majburiy tayyorlashni ham nazarda tutadi.</div></div><div class="ACT_TEXT"><div name="-5013232" id="-5013232">Maktabgacha taʼlim va tarbiyani tashkil etish tartibi ushbu Qonun, shuningdek “Maktabgacha taʼlim va tarbiya toʻgʻrisida”gi Oʻzbekiston Respublikasi <a href="https://lex.uz/uz/docs/-4646908">Qonuni</a> bilan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013234" id="-5013234">9-modda. Umumiy oʻrta va oʻrta maxsus taʼlim</div></div><div class="ACT_TEXT"><div name="-5013236" id="-5013236">Umumiy oʻrta va oʻrta maxsus taʼlim umumtaʼlim oʻquv dasturlarini, zarur bilim, malaka hamda koʻnikmalarni oʻzlashtirishga qaratilgan.</div></div><div class="ACT_TEXT"><div name="-5013238" id="-5013238">Umumiy oʻrta taʼlim (I — XI sinflar) bosqichlari quyidagilardan iborat:</div></div><div class="ACT_TEXT"><div name="-5013239" id="-5013239">boshlangʻich taʼlim (I — IV sinflar);</div></div><div class="ACT_TEXT"><div name="-5013241" id="-5013241">tayanch oʻrta taʼlim (V — IX sinflar);</div></div><div class="ACT_TEXT"><div name="-5013243" id="-5013243">oʻrta taʼlim (X — XI sinflar).</div></div><div class="ACT_TEXT"><div name="-5013245" id="-5013245">Umumiy oʻrta taʼlim tashkilotining birinchi sinfiga bolalar ular yetti yoshga toʻladigan yilda qabul qilinadi. </div></div><div class="ACT_TEXT"><div name="-5013247" id="-5013247">Boshlangʻich taʼlim taʼlim oluvchilarda umumiy oʻrta taʼlimni davom ettirish uchun zarur boʻlgan savodxonlik, bilim, malaka va koʻnikmalar asoslarini shakllantirishga qaratilgan. </div></div><div class="ACT_TEXT"><div name="-5013248" id="-5013248">Tayanch oʻrta taʼlim oʻquv dasturiga muvofiq taʼlim oluvchilarga bilim, malaka va koʻnikmalarning zaruriy hajmini beradi, ularda mustaqil fikrlash va tahlil qilish qobiliyatini rivojlantiradi.</div></div><div class="ACT_TEXT"><div name="-5013249" id="-5013249">Tayanch oʻrta taʼlim doirasida (VII sinfdan soʻng) taʼlim oluvchilarda kasblar boʻyicha birlamchi bilim va koʻnikmalarni shakllantirish uchun ularni professional tashxislash va kasb-hunarga yoʻnaltirish boʻyicha choralar amalga oshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013250" id="-5013250">Oʻrta taʼlim oʻquv dasturiga muvofiq taʼlim oluvchilar tomonidan zarur bilim, malaka va koʻnikmalar oʻzlashtirilishini, shuningdek taʼlimning keyingi turi tanlanishini hamda yuqori malaka talab qilinmaydigan kasblar egallanishini taʼminlaydi.</div></div><div class="BY_DEFAULT"><div name="-5591351" id="-5591351"></div></div><div class="ACT_TEXT"><div name="-5591354" id="-5591354">Professional tashxislash va kasb-hunarga yoʻnaltirish, shuningdek taʼlim oluvchilarni yuqori malaka talab qilinmaydigan kasblarga tayyorlash tartibi qonunchilikda belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591357" id="-5591357"><em>(</em>9-moddaning sakkizinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405549">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5013253" id="-5013253">Umumiy oʻrta taʼlim umumiy oʻrta taʼlim tashkilotlarida uzluksiz tarzda, majburiy boʻlgan oʻn bir yil davomida amalga oshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013254" id="-5013254">Oʻrta maxsus taʼlim akademik litseylarda toʻqqiz yillik tayanch oʻrta taʼlim asosida ikki yil mobaynida amalga oshiriladi va taʼlim oluvchilarning intellektual qobiliyatlarining jadal rivojlanishini, shuningdek chuqur, tabaqalashtirilgan, kasb-xunarga va shaxsga yoʻnaltirilgan taʼlim olishini taʼminlaydi.</div></div><div class="BY_DEFAULT"><div name="-7098457" id="-7098457"></div></div><div class="ACT_TEXT"><div name="-7098458" id="-7098458">Nodavlat umumiy oʻrta taʼlim tashkilotlari oʻz faoliyatini litsenziya asosida, davlat taʼlim standartiga muvofiq tashkil etadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098460" id="-7098460">(9-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094145">Qonuniga </a>asosan oʻn birinchi qism bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013255" id="-5013255">Nodavlat taʼlim tashkilotlarida umumiy oʻrta va oʻrta maxsus taʼlim toʻlov-shartnoma asosida amalga oshirilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-5013256" id="-5013256">Iqtidorli va isteʼdodli bolalarning qobiliyatini rivojlantirish uchun Prezident, ijod va boshqa ixtisoslashtirilgan maktablar, shuningdek maktab-internatlar tashkil etilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-5013257" id="-5013257">Jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalar, shuningdek uzoq vaqt davolanishga muhtoj boʻlgan bolalar davlat ixtisoslashtirilgan taʼlim muassasalarida, umumiy oʻrta va oʻrta maxsus taʼlim tashkilotlarida inklyuziv shaklda yoki uy sharoitlarida yakka tartibda taʼlim oladi.</div></div><div class="ACT_TEXT"><div name="-5013258" id="-5013258">Umumiy oʻrta taʼlim tashkilotlarining sinflarida (guruhlarida) taʼlim oluvchilar soni oʻttiz besh nafardan oshmasligi kerak.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013259" id="-5013259">10-modda. Professional taʼlim</div></div><div class="ACT_TEXT"><div name="-5013262" id="-5013262">Professional taʼlim egallanadigan kasb va mutaxassislik boʻyicha quyidagi darajalarni oʻz ichiga oladi:</div></div><div class="ACT_TEXT"><div name="-5013265" id="-5013265">boshlangʻich professional taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013291" id="-5013291">oʻrta professional taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013292" id="-5013292">oʻrta maxsus professional taʼlim.</div></div><div class="ACT_TEXT"><div name="-5013293" id="-5013293">Boshlangʻich professional taʼlim kasb-hunar maktablarida IX sinf bitiruvchilari negizida bepul asosda kunduzgi taʼlim shakli boʻyicha umumtaʼlim fanlarining va mutaxassislik fanlarining ikki yillik integratsiyalashgan dasturlari asosida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5013294" id="-5013294">Oʻrta professional taʼlim kollejlarda davlat buyurtmasi yoki toʻlov-shartnoma asosida kasblar hamda mutaxassisliklarning murakkabligidan kelib chiqqan holda, davomiyligi ikki yilgacha boʻlgan kunduzgi, kechki va sirtqi taʼlim shakllari boʻyicha umumiy oʻrta, oʻrta maxsus taʼlim hamda boshlangʻich professional taʼlim negizida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5013297" id="-5013297">Oʻrta maxsus professional taʼlim texnikumlarda umumiy oʻrta, oʻrta maxsus, boshlangʻich professional va oʻrta professional taʼlim negizida davlat buyurtmasi yoki toʻlov-shartnoma asosida kasblar hamda mutaxassisliklarning murakkabligidan kelib chiqqan holda, davomiyligi kamida ikki yil boʻlgan kunduzgi, kechki va sirtqi taʼlim shakllari boʻyicha amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5013299" id="-5013299">Ushbu Qonun kuchga kirguniga qadar oʻrta maxsus, kasb-hunar taʼlimi (toʻqqiz yillik umumiy oʻrta va uch yillik oʻrta maxsus, kasb-hunar taʼlimi) olgan fuqarolar ham oʻrta professional va oʻrta maxsus professional taʼlim olish huquqiga ega.</div></div><div class="ACT_TEXT"><div name="-5013300" id="-5013300">Kasb-hunar maktablari, kollejlar va texnikumlar taʼlim oluvchilarning oʻzi tanlagan kasbga va mutaxassislikka ega boʻlishini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-5013301" id="-5013301">Fuqarolar shartnoma asosida ikkinchi va undan keyingi professional taʼlimni olish huquqiga ega.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013303" id="-5013303">11-modda. Oliy taʼlim</div></div><div class="ACT_TEXT"><div name="-5013305" id="-5013305">Oliy taʼlim bakalavriat taʼlim yoʻnalishlari va magistratura mutaxassisliklari boʻyicha yuqori malakali kadrlar tayyorlanishini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-5013309" id="-5013309">Oliy maʼlumotli kadrlarni tayyorlash oliy taʼlim tashkilotlarida (universitetlar, akademiyalar, institutlar, oliy maktablar) amalga oshiriladi. Umumiy oʻrta (oʻn bir yillik taʼlim), oʻrta maxsus (toʻqqiz yillik tayanch oʻrta va ikki yillik oʻrta maxsus taʼlim), boshlangʻich professional taʼlim (toʻqqiz yillik tayanch oʻrta va ikki yillik boshlangʻich professional taʼlim) olgan shaxslar, shuningdek ushbu Qonun kuchga kirguniga qadar oʻrta maxsus, kasb-hunar taʼlimi (toʻqqiz yillik umumiy oʻrta va uch yillik oʻrta maxsus, kasb-hunar taʼlimi) olgan shaxslar oliy maʼlumot olish huquqiga ega.</div></div><div class="ACT_TEXT"><div name="-5013310" id="-5013310">Oliy taʼlim ikki bosqichga — bakalavriat va magistratura bosqichiga ega.</div></div><div class="ACT_TEXT"><div name="-5013311" id="-5013311">Bakalavriat oliy taʼlim yoʻnalishlaridan biri boʻyicha chuqurlashtirilgan bilim, malaka va koʻnikmalar beradigan, oʻqish davomiyligi kamida uch yil boʻlgan tayanch oliy taʼlimdir.</div></div><div class="ACT_TEXT"><div name="-5013315" id="-5013315">Magistratura tegishli bakalavriat negizidagi aniq mutaxassislik boʻyicha oʻqish davomiyligi kamida bir yil boʻlgan oliy taʼlimdir.</div></div><div class="BY_DEFAULT"><div name="-7098463" id="-7098463"></div></div><div class="ACT_TEXT"><div name="-7098464" id="-7098464">Magistratura mutaxassisliklarining va ularga muvofiq boʻlgan bakalavriat taʼlim yoʻnalishlarining roʻyxati taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organi tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098466" id="-7098466">(11-moddaning oltinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094148">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013318" id="-5013318">Fuqarolar shartnoma asosida ikkinchi va undan keyingi oliy maʼlumotni olish huquqiga ega.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013319" id="-5013319">12-modda. Oliy taʼlimdan keyingi taʼlim</div></div><div class="ACT_TEXT"><div name="-5013322" id="-5013322">Oliy taʼlimdan keyingi taʼlimni oliy taʼlim va ilmiy tashkilotlarda olish mumkin.</div></div><div class="ACT_TEXT"><div name="-5013323" id="-5013323">Oliy taʼlimdan keyingi taʼlim doktorlik dissertatsiyasini tayyorlash va himoya qilish maqsadida mutaxassislikni chuqur oʻrganishni va ilmiy izlanishlar olib borishni nazarda tutadigan tayanch doktorantura, doktorantura va mustaqil izlanuvchanlik asosida ilmiy darajaga ega ilmiy va ilmiy-pedagogik kadrlar tayyorlashni taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-5013324" id="-5013324">Tayanch doktorantura falsafa doktori (Doctor of Philosophy (PhD) ilmiy darajasiga daʼvogar izlanuvchilar uchun ishlab chiqarishdan ajralgan holda tashkil etiladigan oliy malakali ilmiy va ilmiy-pedagog kadrlar ixtisosligi boʻyicha oliy taʼlimdan keyingi taʼlim shakli hisoblanadi.</div></div><div class="ACT_TEXT"><div name="-5013325" id="-5013325">Doktorantura fan doktori (Doctor of Science (DSc) ilmiy darajasiga daʼvogar izlanuvchilar uchun ishlab chiqarishdan ajralgan holda tashkil etiladigan oliy malakali ilmiy va ilmiy-pedagog kadrlar ixtisosligi boʻyicha oliy taʼlimdan keyingi taʼlim shakli hisoblanadi.</div></div><div class="ACT_TEXT"><div name="-5013328" id="-5013328">Mustaqil izlanuvchilik falsafa doktori (Doctor of Philosophy (PhD) yoki fan doktori (Doctor of Science (DSc) ilmiy darajalariga daʼvogar izlanuvchilar uchun ishlab chiqarishdan ajralmagan holda tashkil etiladigan oliy malakali ilmiy va ilmiy-pedagog kadrlar ixtisosligi boʻyicha oliy taʼlimdan keyingi taʼlim shakli hisoblanadi.</div></div><div class="BY_DEFAULT"><div name="-5591359" id="-5591359"></div></div><div class="ACT_TEXT"><div name="-5591360" id="-5591360">Ilmiy va ilmiy-pedagogik kadrlar tayyorlash, ilmiy darajalar va ilmiy unvonlar berish tartibi, shuningdek harbiy, tibbiyot va boshqa taʼlim tashkilotlarida oliy taʼlimdan keyingi taʼlim olish xususiyatlari qonunchilikda belgilanadi.</div></div><div class="ACT_TEXT"><div name="-5591361" id="-5591361">Oliy taʼlimdan keyingi taʼlimning davom etish muddati qonunchilikda belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591369" id="-5591369"><em>(</em>12-moddaning oltinchi va yettinchi qismlari <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405552">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5013332" id="-5013332">13-modda. Kadrlarni qayta tayyorlash va ularning malakasini oshirish </div></div><div class="ACT_TEXT"><div name="-5013333" id="-5013333">Kadrlarni qayta tayyorlash tayanch mutaxassisliklar va kasblarga muvofiq boʻlgan yoʻnalishlar boʻyicha faoliyatni amalga oshirish uchun qoʻshimcha kasbiy bilim, malaka va koʻnikmalarning zarur hajmi egallanishini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-5013334" id="-5013334">Kadrlar malakasini oshirish kasbiy bilim, malaka va koʻnikmalarning chuqurlashtirilishi hamda yangilab borilishini taʼminlaydi, kadrlarning toifasi, darajasi, razryadi va lavozimi oshishiga xizmat qiladi. </div></div><div class="ACT_TEXT"><div name="-5013335" id="-5013335">Kadrlarni qayta tayyorlash va ularning malakasini oshirish shakllari va muddatlari tegishli davlat taʼlim talablari bilan belgilanadi.</div></div><div class="BY_DEFAULT"><div name="-7803142" id="-7803142"></div></div><div class="CLAUSE_DEFAULT"><div name="-7803144" id="-7803144">14-modda. Qoʻshimcha taʼlim</div></div><div class="ACT_TEXT"><div name="-7803145" id="-7803145">Qoʻshimcha taʼlim bolalar va katta yoshdagilarning ijodiy qobiliyatini shakllantirishga hamda kasbiy koʻnikmalarini rivojlantirishga, intellektual va jismoniy takomillashuvga boʻlgan individual ehtiyojlarini qanoatlantirishga, sogʻlom turmush tarzini shakllantirishga, sogʻligʻini mustahkamlashga va boʻsh vaqtlarini samarali tashkil etishga qaratilgan boʻlib, u quyidagi turlarni oʻz ichiga oladi:</div></div><div class="ACT_TEXT"><div name="-7803146" id="-7803146">bolalar uchun qoʻshimcha taʼlimni;</div></div><div class="ACT_TEXT"><div name="-7803147" id="-7803147">katta yoshdagilar uchun qoʻshimcha taʼlimni.</div></div><div class="ACT_TEXT"><div name="-7803148" id="-7803148">Bolalar uchun qoʻshimcha taʼlim uzluksiz taʼlim berishning tarkibiy qismi sifatida ularning isteʼdodi va qobiliyatini rivojlantirish, maʼnaviy ehtiyojlarini qanoatlantirish maqsadida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-7803149" id="-7803149">Bunda davlat organlari, nodavlat notijorat tashkilotlari, shuningdek tijorat tashkilotlari madaniy-estetik, ilmiy, texnikaviy, sport va boshqa yoʻnalishlarda bolalar uchun qoʻshimcha taʼlim tashkilotlarini tashkil etishi mumkin.</div></div><div class="ACT_TEXT"><div name="-7803150" id="-7803150">Bolalar uchun qoʻshimcha taʼlim tashkilotlari jumlasiga bolalar va oʻsmirlar ijodiyoti saroylari, uylari, klublari va markazlari, “Barkamol avlod” bolalar maktablari, bolalar-oʻsmirlar sport maktablari, bolalar musiqa va sanʼat maktablari, studiyalar, axborot-kutubxona hamda sogʻlomlashtirish muassasalari kiradi.</div></div><div class="ACT_TEXT"><div name="-7803151" id="-7803151">Katta yoshdagilar uchun qoʻshimcha taʼlim ularning taʼlimga boʻlgan ehtiyojlarini qanoatlantirish, qoʻshimcha bilim va koʻnikmalarni egallashiga koʻmaklashish uchun tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-7803153" id="-7803153">Qoʻshimcha taʼlim berish tartibi taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803155" id="-7803155">(14-modda Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789616">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="BY_DEFAULT"><div name="-7204054" id="-7204054"></div></div><div class="CLAUSE_DEFAULT"><div name="-7204061" id="-7204061">14<sup>1</sup>-modda. Maʼrifiy faoliyat</div></div><div class="ACT_TEXT"><div name="-7204066" id="-7204066">Maʼrifiy faoliyat shaxsning shaxsiy, intellektual va maʼnaviy jihatdan kamol topishi, ijtimoiy va iqtisodiy faolligini oshirish, intellektual va ijodiy salohiyatini namoyon etish, individual salohiyatini, imkoniyatlarini, muloqot qilish qobiliyatlarini yaxshilash uchun zarur koʻnikmalar va malakalarni shakllantirishga qaratilgan, davlat taʼlim standartlari bilan qamrab olinmaydigan faoliyat turi hisoblanadi.</div></div><div class="ACT_TEXT"><div name="-7204070" id="-7204070">Maʼrifiy faoliyat qonunchilik hujjatlarida nazarda tutilgan talablar hisobga olingan holda, respublika ijro etuvchi hokimiyat organlari, mahalliy davlat hokimiyati organlari, fuqarolarning oʻzini oʻzi boshqarish organlari, jismoniy va yuridik shaxslar tomonidan amalga oshirilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-7204073" id="-7204073">Jinoyat ishi boʻyicha ayblanuvchi tariqasida jalb etilgan (sud hukmi qonuniy kuchga kirguniga yoxud reabilitatsiya qiluvchi asoslarga binoan uni jinoiy javobgarlikdan ozod etish toʻgʻrisida qaror qabul qilinguniga qadar), jinsiy erkinlikka qarshi jinoyatlarni, oilaga, yoshlarga va axloqqa qarshi jinoyatlarni, tinchlikka va insoniyatning xavfsizligiga qarshi jinoyatlarni, Oʻzbekiston Respublikasiga qarshi jinoyatlarni, firibgarlikni hamda boshqaruv tartibiga qarshi jinoyatlarni, giyohvandlik vositalari, ularning analoglari yoki psixotrop moddalar bilan qonunga xilof ravishda muomala qilish bilan bogʻliq jinoyatlarni sodir etganligi uchun sudlanganlik holati tugallanmagan yoki olib tashlanmagan shaxslar, sud tomonidan muomalaga layoqatsiz yoki muomala layoqati cheklangan deb topilgan shaxslar, shuningdek psixiatriya yoki narkologiya muassasalarida hisobda turgan shaxslar maʼrifiy faoliyatni amalga oshirishi mumkin emas.</div></div><div class="ACT_TEXT"><div name="-7204075" id="-7204075">Maʼrifiy faoliyatni amalga oshirish tartibi, shakllari, talablari va shartlari Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7204090" id="-7204090">(14<sup>1</sup>-modda Oʻzbekiston Respublikasining 2024-yil 5-noyabrdagi OʻRQ-990-sonli <a href="https://lex.uz/uz/docs/-7196863?ONDATE=06.02.2025 00#-7197742">Qonuniga </a>asosan kiritilgan — Qonunchilik maʼlumotlari milliy bazasi, 05.11.2024-y., 03/24/990/0892-son — Kuchga kirish sanasi — 2025-yil 6-fevral)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013344" id="-5013344">15-modda. Taʼlim olish shakllari</div></div><div class="ACT_TEXT"><div name="-5013350" id="-5013350">Taʼlim olish shakllari quyidagilardan iborat:</div></div><div class="ACT_TEXT"><div name="-5013351" id="-5013351">ishlab chiqarishdan ajralgan holda taʼlim olish (kunduzgi);</div></div><div class="ACT_TEXT"><div name="-5013353" id="-5013353">ishlab chiqarishdan ajralmagan holda taʼlim olish (sirtqi, kechki, masofaviy);</div></div><div class="ACT_TEXT"><div name="-5013355" id="-5013355">dual taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013356" id="-5013356">oilada taʼlim olish va mustaqil taʼlim olish;</div></div><div class="ACT_TEXT"><div name="-5013357" id="-5013357">katta yoshdagilarni oʻqitish va ularga taʼlim berish;</div></div><div class="ACT_TEXT"><div name="-5013358" id="-5013358">inklyuziv taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013359" id="-5013359">eksternat tartibidagi taʼlim;</div></div><div class="ACT_TEXT"><div name="-5013360" id="-5013360">mudofaa, xavfsizlik va huquqni muhofaza qilish faoliyati sohasida kadrlar tayyorlash.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013361" id="-5013361">16-modda. Masofaviy taʼlim</div></div><div class="ACT_TEXT"><div name="-5013362" id="-5013362">Masofaviy taʼlim oʻquv rejalari va oʻquv dasturlariga muvofiq taʼlim oluvchilar tomonidan zarur bilim, malaka va koʻnikmalarni axborot-kommunikatsiya texnologiyalaridan hamda Internet jahon axborot tarmogʻidan foydalangan holda masofadan turib olishga qaratilgan.</div></div><div class="ACT_TEXT"><div name="-5013363" id="-5013363">Masofaviy taʼlimni tashkil etish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013367" id="-5013367">17-modda. Dual taʼlim</div></div><div class="ACT_TEXT"><div name="-5013368" id="-5013368">Dual taʼlim taʼlim oluvchilar tomonidan zarur bilim, malaka va koʻnikmalarni olishga qaratilgan boʻlib, ularning nazariy qismi taʼlim tashkiloti negizida, amaliy qismi esa taʼlim oluvchining ish joyida amalga oshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013369" id="-5013369">Dual taʼlimni tashkil etish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013370" id="-5013370">18-modda. Oilada taʼlim olish va mustaqil taʼlim olish</div></div><div class="ACT_TEXT"><div name="-5013371" id="-5013371">Davlat oilada taʼlim olishga va mustaqil taʼlim olishga koʻmaklashadi. Bolalarning oilada taʼlim olishi va mustaqil taʼlim olish uslubiy va maslahat yordami koʻrsatilgan holda tegishli oʻquv dasturlari boʻyicha amalga oshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013373" id="-5013373">Oilada taʼlim olish va mustaqil taʼlim olish tartibi, shuningdek taʼlim oluvchilarning toifalari taʼlim sohasidagi vakolatli davlat boshqaruvi organlari tomonidan belgilanadi.</div></div><div class="ACT_TEXT"><div name="-5013374" id="-5013374">Oilada taʼlim olish bolalar, oila, davlat va jamiyat manfaatlarini hisobga olgan holda davlat taʼlim muassasasi hamda taʼlim oluvchilarning ota-onasi yoki boshqa qonuniy vakillari oʻrtasidagi shartnoma asosida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5013376" id="-5013376">Mustaqil taʼlim olish yakka tartibda amalga oshiriladi hamda taʼlim oluvchilarni kasbiy, intellektual, maʼnaviy va madaniy rivojlantirishga xizmat qiladi.</div></div><div class="ACT_TEXT"><div name="-5013378" id="-5013378">Oilada taʼlim olgan va mustaqil taʼlim olgan shaxslarga davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjatni berish davlat taʼlim muassasalarining tasdiqlangan oʻquv dasturiga muvofiq eksternat tartibida amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013380" id="-5013380">19-modda. Katta yoshdagilarni oʻqitish va ularga taʼlim berish</div></div><div class="ACT_TEXT"><div name="-5013381" id="-5013381">Katta yoshdagilarni oʻqitish va ularga taʼlim berish butun umr davomida oʻqitishning markaziy tarkibiy qismi boʻlib, taʼlim berish hamda oʻqitishning jamiyat hayotida va mehnat faoliyatida katta yoshdagilarning ishtirok etishini taʼminlashga qaratilgan barcha shakllarini oʻz ichiga oladi, shuningdek rasmiy, norasmiy va informal oʻqitish jarayonlarining butun majmuini qamrab oladi.</div></div><div class="ACT_TEXT"><div name="-5013382" id="-5013382">Rasmiy taʼlim davlat taʼlim muassasalari hamda davlat tomonidan tan olingan akkreditatsiyadan oʻtgan nodavlat taʼlim tashkilotlari ishtirokidagi institutsionallashtirilgan (muayyan qoidalar va normalarni mujassamlashtiruvchi), aniq maqsadga yoʻnaltirilgan va rejalashtirilgan taʼlimdir.</div></div><div class="ACT_TEXT"><div name="-5013384" id="-5013384">Norasmiy taʼlim taʼlim xizmatlari taqdim etilishini taʼminlovchi shaxs yoki tashkilot tomonidan institutsionallashtirilgan (muayyan qoidalar va normalarni mujassamlashtiruvchi), aniq maqsadga yoʻnaltirilgan va rejalashtirilgan boʻlib, shaxsni butun hayoti davomida oʻqitishdagi rasmiy taʼlimga qoʻshimcha va (yoki) uning muqobilidir.</div></div><div class="ACT_TEXT"><div name="-5013386" id="-5013386">Informal taʼlim aniq maqsadga yoʻnaltirilgan, ammo institutsionallashtirilmagan (muayyan qoidalar va normalarni mujassamlashtirmagan), rasmiy yoki norasmiy taʼlimdan koʻra kamroq tashkillashtirilgan va tarkiblashtirilgandir hamda oiladagi, ish joyidagi, yashash joyidagi va kundalik hayotdagi oʻquv faoliyatini oʻz ichiga olishi mumkin. </div></div><div class="CLAUSE_DEFAULT"><div name="-5013387" id="-5013387">20-modda. Inklyuziv taʼlim</div></div><div class="ACT_TEXT"><div name="-5013388" id="-5013388">Inklyuziv taʼlim alohida taʼlim ehtiyojlari va individual imkoniyatlarning xilma-xilligini hisobga olgan holda barcha taʼlim oluvchilar uchun taʼlim tashkilotlarida taʼlim olishga boʻlgan teng imkoniyatlarni taʼminlashga qaratilgan. </div></div><div class="ACT_TEXT"><div name="-5013389" id="-5013389">Jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalar (shaxslar) uchun taʼlim tashkilotlarida inklyuziv taʼlim tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-5013390" id="-5013390">Inklyuziv taʼlimni tashkil etish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013391" id="-5013391">21-modda. Eksternat tartibidagi taʼlim </div></div><div class="ACT_TEXT"><div name="-5013392" id="-5013392">Eksternat tartibidagi taʼlim olish oʻquv dasturlarini mustaqil ravishda oʻzlashtirishni oʻz ichiga olib, uning yakunlari boʻyicha taʼlim oluvchilardan davlat taʼlim muassasalarida yakuniy va davlat attestatsiyalaridan oʻtishni talab etadi.</div></div><div class="ACT_TEXT"><div name="-5013393" id="-5013393">Eksternat tartibidagi taʼlim olishni tashkil etish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013395" id="-5013395">22-modda. Mudofaa, xavfsizlik va huquqni muhofaza qilish faoliyati sohasida kadrlarni tayyorlash </div></div><div class="BY_DEFAULT"><div name="-5591377" id="-5591377"></div></div><div class="ACT_TEXT"><div name="-5591380" id="-5591380">Mudofaa, xavfsizlik va huquqni muhofaza qilish faoliyati sohasida kadrlarni tayyorlash ularning oʻziga xos xususiyatlaridan kelib chiqqan holda qonunchilikka muvofiq amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591387" id="-5591387"><em>(</em>22-moddaning matni <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405557">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5013397" id="-5013397">3-bob. Taʼlim tizimini boshqarish</div></div><div class="CLAUSE_DEFAULT"><div name="-5013398" id="-5013398">23-modda. Oʻzbekiston Respublikasi Vazirlar Mahkamasining taʼlim sohasidagi vakolatlari </div></div><div class="ACT_TEXT"><div name="-5013400" id="-5013400">Oʻzbekiston Respublikasi Vazirlar Mahkamasi:</div></div><div class="ACT_TEXT"><div name="-5013403" id="-5013403">taʼlim sohasidagi yagona davlat siyosatini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-5013405" id="-5013405">taʼlim sohasidagi davlat dasturlarini tasdiqlaydi va ularning amalga oshirilishini taʼminlaydi;</div></div><div class="BY_DEFAULT"><div name="-7098468" id="-7098468"></div></div><div class="ACT_TEXT"><div name="-7098469" id="-7098469">taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlariga rahbarlik qiladi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098471" id="-7098471">(23-modda birinchi qismining toʻrtinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094151">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7098475" id="-7098475"></div></div><div class="ACT_TEXT"><div name="-7098476" id="-7098476">taʼlim tashkilotlarini attestatsiyadan va davlat akkreditatsiyasidan, kompleks va maxsus davlat akkreditatsiyasidan oʻtkazish tartibini tasdiqlash, pedagog kadrlarni va ilmiy xodimlarni attestatsiyadan oʻtkazish, nodavlat taʼlim tashkilotlariga taʼlim xizmatlari koʻrsatish faoliyatini amalga oshirish huquqini beradigan litsenziyalar (bundan buyon matnda litsenziya deb yuritiladi) berish vakolatli organni ushbu sohada faoliyat boshlash toʻgʻrisida xabardor qilish, taʼlim toʻgʻrisidagi hujjatlarga apostil qoʻyish tartibini belgilaydi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098477" id="-7098477">(23-modda birinchi qismining beshinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094152">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7098478" id="-7098478"></div></div><div class="ACT_TEXT"><div name="-7098480" id="-7098480">pedagogik kadrlarni taʼlim tashkilotlariga (bundan moliyaviy mustaqillik berilgan davlat oliy taʼlim tashkilotlari mustasno) ishga qabul qilish va ular faoliyatini baholash tartibini belgilaydi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098484" id="-7098484">(23-modda birinchi qismining oltinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094154">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013413" id="-5013413">xorijiy davlatlarning taʼlim muassasalariga Oʻzbekiston Respublikasi hududida taʼlim faoliyati bilan shugʻullanish huquqiga doir ruxsatnomalar beradi;</div></div><div class="ACT_TEXT"><div name="-5013414" id="-5013414">xorijiy davlatlarda olingan taʼlim toʻgʻrisidagi hujjatlarni tan olish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-5013418" id="-5013418">davlat namunasidagi taʼlim toʻgʻrisidagi hujjatlarni tasdiqlaydi va davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjatlar berish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-5013419" id="-5013419">eksternat tartibida oʻqitishga yoʻl qoʻyilmaydigan taʼlim yoʻnalishlari, mutaxassisliklar va kasblar roʻyxatini tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-5013420" id="-5013420">faqat davlat taʼlim muassasalarida oʻqitiladigan taʼlim yoʻnalishlari, mutaxassisliklar va kasblar roʻyxatini tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-5013423" id="-5013423">davlat taʼlim muassasalari va tashkilotlariga qabul qilish tartibini belgilaydi;</div></div><div class="BY_DEFAULT"><div name="-7098488" id="-7098488"></div></div><div class="ACT_TEXT"><div name="-7098491" id="-7098491">davlat oliy taʼlim tashkilotlari rektorlarini, shuningdek davlat ishtirokida tashkil etiladigan oliy taʼlim tashkilotlari (davlat ulushi boʻlgan nodavlat oliy taʼlim tashkilotlari, qoʻshma taʼlim tashkilotlari, davlat-xususiy sheriklik asosida tashkil etiladigan taʼlim tashkilotlari va boshqalar) rektorlarini (rahbarlarini) lavozimga tayinlaydi hamda egallab turgan lavozimidan ozod etadi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098496" id="-7098496">(23-modda birinchi qismining oʻn uchinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094155">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013426" id="-5013426">taʼlim oluvchilarni akkreditatsiya qilingan bir taʼlim tashkilotidan boshqasiga koʻchirish, shuningdek ularni oʻqishdan chetlashtirish va qayta tiklash tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-5013427" id="-5013427">taʼlim tashkilotlari reytingini aniqlash tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-5013428" id="-5013428">kadrlarni qayta tayyorlash va ularning malakasini oshirish tartibini belgilaydi;</div></div><div class="BY_DEFAULT"><div name="-7204099" id="-7204099"></div></div><div class="ACT_TEXT"><div name="-7204100" id="-7204100">maʼrifiy faoliyatni amalga oshirish tartibini belgilaydi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7204104" id="-7204104">(23-moddaning birinchi qismi Oʻzbekiston Respublikasining 2024-yil 5-noyabrdagi OʻRQ-990-sonli <a href="https://lex.uz/uz/docs/-7196863?ONDATE=06.02.2025 00#-7197754">Qonuniga </a>asosan oʻn yettinchi xatboshi bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 05.11.2024-y., 03/24/990/0892-son — Kuchga kirish sanasi — 2025-yil 6-fevral)</div></div><div class="ACT_TEXT"><div name="-5013429" id="-5013429">mehnat bozori talablarini prognoz va tahlil qilish asosida taʼlim tashkilotlarida kadrlarni tayyorlash boʻyicha davlat buyurtmalarini shakllantiradi;</div></div><div class="BY_DEFAULT"><div name="-7098500" id="-7098500"></div></div><div class="ACT_TEXT"><div name="-7098503" id="-7098503">taʼlim tashkilotlariga nisbatan moddiy-texnik, infratuzilmaviy va parametrik talablarni belgilaydi (bundan oʻrta maxsus, professional va oliy taʼlim tashkilotlari mustasno);</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098507" id="-7098507">(23-modda birinchi qismining oʻn sakkizinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094157">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7098508" id="-7098508"></div></div><div class="ACT_TEXT"><div name="-7098510" id="-7098510">darsliklar va oʻquv qoʻllanmalarini tayyorlash hamda nashr etish tartibini, shuningdek ularni yetkazib berishga va ulardan taʼlim tashkilotlarida foydalanishga qoʻyiladigan talablarni belgilaydi (bundan oʻrta maxsus, professional va oliy taʼlim tashkilotlari mustasno).</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098515" id="-7098515">(23-modda birinchi qismining oʻn toʻqqizinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094158">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-5591406" id="-5591406"></div></div><div class="ACT_TEXT"><div name="-5591408" id="-5591408">Oʻzbekiston Respublikasi Vazirlar Mahkamasi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591410" id="-5591410"><em>(</em>23-moddaning ikkinchi xatboshisi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405561">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098541" id="-7098541">(24-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094159">Qonuniga </a>asosan oʻz kuchini yoʻqotgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098544" id="-7098544">(25-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094159">Qonuniga </a>asosan oʻz kuchini yoʻqotgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7098676" id="-7098676"></div></div><div class="CLAUSE_DEFAULT"><div name="-7098678" id="-7098678">26-modda. Taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari</div></div><div class="ACT_TEXT"><div name="-7098679" id="-7098679">Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi hamda Oliy taʼlim, fan va innovatsiyalar vazirligi taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlaridir.</div></div><div class="ACT_TEXT"><div name="-7098680" id="-7098680">Taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari oʻz vakolatlari doirasida:</div></div><div class="ACT_TEXT"><div name="-7098681" id="-7098681">taʼlim sohasidagi yagona davlat siyosatini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-7098682" id="-7098682">iqtidorli yoshlarni aniqlash, tanlash, oʻqitish va tarbiyalash sohasida davlat siyosatini ishlab chiqadi va amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-7098683" id="-7098683">taʼlim sohasidagi tarmoq davlat dasturlarini ishlab chiqadi, tasdiqlaydi va amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-7098684" id="-7098684">taʼlim tashkilotlari faoliyatini muvofiqlashtiradi va ularga uslubiy rahbarlik qiladi;</div></div><div class="ACT_TEXT"><div name="-7098685" id="-7098685">davlat taʼlim standartlari (shu jumladan maktabgacha taʼlim va tarbiya davlat standarti) va davlat taʼlim talablarida kadrlarning maʼlumoti darajasiga hamda kasbiy tayyorgarligi sifatiga qoʻyilgan talablarning taʼlim tashkilotlari tomonidan bajarilishi ustidan nazoratni amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-7098686" id="-7098686">davlat taʼlim standartlari (shu jumladan maktabgacha taʼlim va tarbiya davlat standarti) hamda davlat taʼlim talablari ishlab chiqilishini taʼminlaydi va ularni tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-7098687" id="-7098687">taʼlim oluvchilarning bilim, koʻnikma va malakalarini baholash tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-7098689" id="-7098689">oʻrta maxsus taʼlim yoʻnalishlari, professional taʼlimning kasblar va mutaxassisliklari, oliy taʼlimning bakalavriat taʼlim yoʻnalishlari va magistratura mutaxassisliklari, shuningdek bilim sohalari va taʼlim sohalari roʻyxatini tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-7098690" id="-7098690">taʼlim-tarbiya jarayoniga oʻqitishning ilgʻor shakllari, yangi pedagogik texnologiyalar, oʻqitishning texnik va axborot vositalari joriy etilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-7098692" id="-7098692">taʼlim tashkilotlarida kadrlarning kasbiy tayyorgarligi sifatini oshirishga qaratilgan chora-tadbirlarni ishlab chiqadi, oʻquv dasturlarini takomillashtiradi;</div></div><div class="BY_DEFAULT"><div name="-7803160" id="-7803160"></div></div><div class="ACT_TEXT"><div name="-7803163" id="-7803163">taʼlim tashkilotlarini (bundan qoʻshimcha taʼlim xizmatlarini koʻrsatuvchi nodavlat taʼlim tashkilotlari mustasno) attestatsiyadan va davlat akkreditatsiyasidan, kompleks va maxsus davlat akkreditatsiyasidan, shuningdek taʼlim tashkilotlarining pedagog kadrlarini attestatsiyadan oʻtkazadi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803168" id="-7803168">(26-modda ikkinchi qismining oʻn ikkinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789627">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-7098696" id="-7098696">taʼlim tashkilotlarida taʼlim-tarbiya jarayonining sifati monitoringini amalga oshiradi;</div></div><div class="BY_DEFAULT"><div name="-7803169" id="-7803169"></div></div><div class="ACT_TEXT"><div name="-7803170" id="-7803170">maktabgacha, umumiy oʻrta, oʻrta maxsus, professional va qoʻshimcha taʼlim tashkilotlarining pedagog xodimlariga lavozimlar va malaka toifalarini berish jarayoni ustidan nazoratni amalga oshiradi, shuningdek unda ishtirok etadi;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803171" id="-7803171">(26-modda ikkinchi qismining oʻn toʻrtinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789628">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-7098699" id="-7098699">oʻquv adabiyotlarini tayyorlash va nashr qilishni tashkil etadi (bundan moliyaviy mustaqillik berilgan davlat oliy taʼlim tashkilotlari mustasno);</div></div><div class="ACT_TEXT"><div name="-7098700" id="-7098700">oʻzlashtirishni baholashga, oʻquv jarayonini, taʼlim oluvchilarning yakuniy davlat attestatsiyasini tashkil etishga oid normativ-huquqiy hujjatlarni tasdiqlaydi, shuningdek eksternat tartibida taʼlim oluvchilarning toifalarini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-7098701" id="-7098701">nodavlat taʼlim tashkilotlariga litsenziyalar beradi, faoliyatini xabardor qilish tartibida amalga oshiradigan shaxslardan xabarnomalar qabul qiladi va ularning reyestrini yuritadi;</div></div><div class="ACT_TEXT"><div name="-7098702" id="-7098702">taʼlim tashkilotlarining reytingini aniqlaydi;</div></div><div class="ACT_TEXT"><div name="-7098703" id="-7098703">davlat oliy taʼlim tashkilotlarining rektorlarini tayinlash toʻgʻrisida Oʻzbekiston Respublikasi Vazirlar Mahkamasiga takliflar kiritadi;</div></div><div class="ACT_TEXT"><div name="-7098705" id="-7098705">taʼlim tashkilotlarining rahbar va pedagog kadrlarini tayyorlashni, qayta tayyorlashni hamda ularning malakasini oshirishni tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-7098706" id="-7098706">taʼlim tashkilotlarida moddiy-texnika resurslaridan foydalanishga doir talablarni ishlab chiqadi;</div></div><div class="ACT_TEXT"><div name="-7098707" id="-7098707">oʻrta maxsus, professional va oliy taʼlim tashkilotlariga nisbatan moddiy-texnik, infratuzilmaviy va parametrik talablarni belgilaydi;</div></div><div class="ACT_TEXT"><div name="-7098708" id="-7098708">oʻrta maxsus, professional va oliy taʼlim tashkilotlari uchun darsliklar va oʻquv qoʻllanmalarini tayyorlash hamda nashr etish tartibini, shuningdek ularni yetkazib berishga va ulardan taʼlim tashkilotlarida foydalanishga qoʻyiladigan talablarni belgilaydi;</div></div><div class="ACT_TEXT"><div name="-7098709" id="-7098709">taʼlim toʻgʻrisidagi qonunchilikning aniqlangan buzilishlari toʻgʻrisida tegishli respublika ijro etuvchi hokimiyat organlariga va taʼlim tashkilotlariga taqdimnomalar kiritadi;</div></div><div class="ACT_TEXT"><div name="-7098710" id="-7098710">taʼlim sohasidagi normativ-huquqiy hujjatlarni ishlab chiqishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-7098712" id="-7098712">taʼlim sohasida xalqaro hamkorlikni amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-7098713" id="-7098713">Taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="ACT_TEXT"><div name="-7098715" id="-7098715">Qasddan sodir etilgan jinoyat uchun ilgari sudlangan shaxslar taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlarining hamda ular hududiy boʻlinmalarining rahbarlik lavozimlariga tayinlanishi taqiqlanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098722" id="-7098722">(26-modda  Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094160">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7983674" id="-7983674"></div></div><div class="CLAUSE_DEFAULT"><div name="-7983675" id="-7983675">27-modda. Mahalliy davlat hokimiyati organlarining taʼlim sohasidagi vakolatlari</div></div><div class="ACT_TEXT"><div name="-7983679" id="-7983679">Mahalliy davlat hokimiyati vakillik organlari taʼlim sohasidagi vakolatli davlat boshqaruvi organlari bilan kelishilgan holda davlat taʼlim muassasalarini tashkil etadi, qayta tashkil etadi va tugatadi, bundan respublika tasarrufidagi taʼlim muassasalari mustasno.</div></div><div class="ACT_TEXT"><div name="-7983680" id="-7983680">Mahalliy ijro etuvchi hokimiyat organlari:</div></div><div class="ACT_TEXT"><div name="-7983681" id="-7983681">oʻz vakolatlari doirasida tegishli hududda davlat taʼlim muassasalari uchun moliyalashtirish hajmini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-7983682" id="-7983682">fuqarolarning oʻzini oʻzi boshqarish organlari, fuqarolik jamiyati institutlari bilan taʼlim tashkilotlarini rivojlantirish masalalari yuzasidan hamkorlik qiladi;</div></div><div class="ACT_TEXT"><div name="-7983683" id="-7983683">davlat umumiy oʻrta taʼlim muassasalariga biriktirilgan hududlarni (mikrouchastkalarni) belgilaydi;</div></div><div class="ACT_TEXT"><div name="-7983684" id="-7983684">taʼlim sohasida xalqaro hamkorlikni amalga oshirishda taʼlim tashkilotlariga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-7983685" id="-7983685">taʼlim oluvchilar uchun sifatli taʼlimni, tarbiyani taʼminlash, ularning isteʼdodini shakllantirish va namoyon etish maqsadida joylarda ularga zarur sharoitlar yaratish boʻyicha dasturlarni ishlab chiqadi;</div></div><div class="ACT_TEXT"><div name="-7983686" id="-7983686">oʻz vakolatlari doirasida taʼlim sohasidagi davlat-xususiy sheriklikni rivojlantiradi va nodavlat taʼlim tashkilotlari tarmogʻini kengaytirishga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-7983687" id="-7983687">umumiy oʻrta taʼlim tashkilotlari bitiruvchilari bandligini taʼminlashga koʻmaklashadi.</div></div><div class="ACT_TEXT"><div name="-7983688" id="-7983688">Mahalliy davlat hokimiyati organlari qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7983710" id="-7983710">(27-modda Oʻzbekiston Respublikasining 2025-yil 30-dekabrdagi OʻRQ-1109-sonli <a href="https://lex.uz/uz/docs/-7962424?ONDATE=30.12.2025 00#-7965318">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 30.12.2025-y., 03/25/1109/1241-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013527" id="-5013527">28-modda. Taʼlim tashkilotini boshqarish</div></div><div class="ACT_TEXT"><div name="-5013529" id="-5013529">Taʼlim tashkilotini boshqarishni tegishincha quyidagilar amalga oshiradi:</div></div><div class="ACT_TEXT"><div name="-5013530" id="-5013530">pedagogik kengash;</div></div><div class="ACT_TEXT"><div name="-5013533" id="-5013533">kuzatuv (vasiylik) kengashi;</div></div><div class="ACT_TEXT"><div name="-5013534" id="-5013534">oliy taʼlim tashkilotining kengashi;</div></div><div class="ACT_TEXT"><div name="-5013536" id="-5013536">taʼlim tashkilotining rahbari.</div></div><div class="ACT_TEXT"><div name="-5013537" id="-5013537">Taʼlim tashkilotlarida jamoatchilik boshqaruvi organlari tashkil etilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-5013538" id="-5013538">Taʼlim tashkilotlarini boshqarishda va kadrlar tayyorlashda kadrlar talabgorlari ishtirok etadi.</div></div><div class="BY_DEFAULT"><div name="-6789289" id="-6789289"></div></div><div class="ACT_TEXT"><div name="-6789291" id="-6789291">Qasddan sodir etilgan jinoyat uchun ilgari sudlangan shaxslar taʼlim tashkilotlarining rahbarlik lavozimlariga tayinlanishi mumkin emas.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-6789293" id="-6789293">(28-modda Oʻzbekiston Respublikasining 2024-yil 1-fevraldagi OʻRQ-901-sonli <a href="https://lex.uz/uz/docs/-6786401?ONDATE=01.02.2024 00#-6787113">Qonuniga </a>asosan toʻrtinchi qism bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 01.02.2024-y., 03/24/901/0082-son)</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5013539" id="-5013539">4-bob. Taʼlim faoliyatini tashkil etish va uning nazoratini amalga oshirish </div></div><div class="CLAUSE_DEFAULT"><div name="-5013541" id="-5013541">29-modda. Taʼlim tashkilotlarining huquqiy maqomi</div></div><div class="ACT_TEXT"><div name="-5013542" id="-5013542">Oʻzbekiston Respublikasining taʼlim tashkilotlari va ularning filiallari, shuningdek xorijiy davlatlar taʼlim tashkilotlarining filiallari yuridik shaxs maqomi bilan tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-5013547" id="-5013547">Oilaviy nodavlat maktabgacha taʼlim tashkiloti shaklidagi taʼlim xizmatlari yakka tartibdagi tadbirkorlar sifatida roʻyxatga olingan jismoniy shaxslar tomonidan amalga oshiriladi.</div></div><div class="BY_DEFAULT"><div name="-5685046" id="-5685046"></div></div><div class="ACT_TEXT"><div name="-5685048" id="-5685048">Nodavlat taʼlim tashkilotlari litsenziya olingan kundan eʼtiboran taʼlim faoliyati bilan shugʻullanishga haqli bundan ushbu Qonunning <a href="https://lex.uz/uz/docs/-5013007#-5685141">57<sup>1</sup>-moddasida</a> nazarda tutilgan hollar mustasno.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5685052" id="-5685052">(29-moddaning uchinchi qismi Oʻzbekiston Respublikasining 2021-yil 12-oktabrdagi OʻRQ-721-sonli <a href="https://lex.uz/uz/docs/-5674701?ONDATE=12.10.2021 00#-5675923">Qonuni</a> tahririda — Qonunchilik maʼlumotlari milliy bazasi, 12.10.2021-y., 03/21/721/0952-son)</div></div><div class="ACT_TEXT"><div name="-5013552" id="-5013552">Taʼlim tashkilotlari oʻz faoliyatini ustav va (yoki) boshqa taʼsis hujjatlari asosida yuritadi.</div></div><div class="ACT_TEXT"><div name="-5013555" id="-5013555">Taʼlim tashkilotlari oʻquv-tarbiya va oʻquv-ilmiy-ishlab chiqarish majmualariga birlashishga haqli. </div></div><div class="ACT_TEXT"><div name="-5013558" id="-5013558">Taʼlim tashkilotlarida siyosiy partiyalarning tashkiliy tuzilmalarini tashkil etishga yoʻl qoʻyilmaydi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013561" id="-5013561">30-modda. Taʼlim tashkilotlarini tashkil etish, qayta tashkil etish va tugatish </div></div><div class="ACT_TEXT"><div name="-5013588" id="-5013588">Davlat oliy taʼlim, oʻrta maxsus, professional taʼlim muassasalari va ularning filiallari, shuningdek davlat ishtirokidagi oliy, oʻrta maxsus, professional taʼlim tashkilotlari va ularning filiallari Oʻzbekiston Respublikasi Prezidentining yoki Oʻzbekiston Respublikasi Vazirlar Mahkamasining qarorlari bilan tashkil etiladi. </div></div><div class="ACT_TEXT"><div name="-5013589" id="-5013589">Iqtisodiyotning va ijtimoiy sohaning oliy maʼlumotli malakali kadrlarga boʻlgan ehtiyojlarini, shuningdek aholining oliy taʼlim olishga boʻlgan ehtiyojini qanoatlantirish maqsadida mamlakat hududida xorijiy oliy taʼlim tashkilotlarining filiallari (markazlari, taʼlim kampuslari) va boshqa boʻlinmalari tashkil etilishi mumkin. </div></div><div class="ACT_TEXT"><div name="-5013590" id="-5013590">Xorijiy oliy taʼlim tashkilotlarining boʻlinmalari Oʻzbekiston Respublikasida yuridik shaxs maqomi bilan tashkil etiladi. </div></div><div class="ACT_TEXT"><div name="-5013591" id="-5013591">Xorijiy oliy taʼlim tashkilotlarining, shuningdek xalqaro tashkilotlarning taʼlim muassasalari filiallari (markazlari, taʼlim kampuslari) va boshqa boʻlinmalari faoliyatini tashkil etish masalalari boʻyicha Oʻzbekiston Respublikasining xalqaro shartnomalariga muvofiq Oʻzbekiston Respublikasi Prezidentining yoki Vazirlar Mahkamasining qarorlari qabul qilinishi mumkin. </div></div><div class="BY_DEFAULT"><div name="-5013592" id="-5013592"></div></div><div class="BY_DEFAULT"><div name="-7098734" id="-7098734"></div></div><div class="ACT_TEXT"><div name="-7098736" id="-7098736">Kadrlarni qayta tayyorlash va ularning malakasini oshirish boʻyicha davlat taʼlim tashkilotlari:</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098747" id="-7098747">(30-modda beshinchi qismining birinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094199">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013596" id="-5013596">Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan institutlar va markazlar shaklida;</div></div><div class="BY_DEFAULT"><div name="-7098926" id="-7098926"></div></div><div class="ACT_TEXT"><div name="-7098930" id="-7098930">tegishli vazirliklar va idoralar tomonidan Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi bilan kelishilgan holda oliy taʼlim tashkilotlarining fakultetlari va kurslari shaklida tashkil etiladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098934" id="-7098934">(30-modda beshinchi qismining uchinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094200">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-5013598" id="-5013598"></div></div><div class="BY_DEFAULT"><div name="-7803173" id="-7803173"></div></div><div class="ACT_TEXT"><div name="-7803175" id="-7803175">Davlat umumiy oʻrta va qoʻshimcha taʼlim muassasalari:</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803179" id="-7803179">(30-modda oltinchi qismining birinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789630">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="BY_DEFAULT"><div name="-6685710" id="-6685710"></div></div><div class="ACT_TEXT"><div name="-6685720" id="-6685720">respublika boʻysunuvida vazirliklar va idoralar tomonidan Qoraqalpogʻiston Respublikasi Vazirlar Kengashi, viloyatlar va Toshkent shahar hokimliklari bilan kelishgan holda; </div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-6685725" id="-6685725">(30-modda oltinchi qismining ikkinchi xatboshisi Oʻzbekiston Respublikasining 2023-yil 28-noyabrdagi OʻRQ-880-sonli <a href="https://lex.uz/uz/docs/-6678807?ONDATE=29.11.2023 01#-6679920">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 29.11.2023-y., 03/23/880/0905-son)</div></div><div class="BY_DEFAULT"><div name="-7803202" id="-7803202"></div></div><div class="ACT_TEXT"><div name="-7803211" id="-7803211">Qoraqalpogʻiston Respublikasi, viloyatlar va Toshkent shahri boʻysunuvida tegishincha Qoraqalpogʻiston Respublikasi Vazirlar Kengashi, viloyatlar va Toshkent shahar hokimliklari tomonidan taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari bilan kelishilgan holda;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803215" id="-7803215">(30-modda oltinchi qismining uchinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789631">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="BY_DEFAULT"><div name="-7803217" id="-7803217"></div></div><div class="ACT_TEXT"><div name="-7803219" id="-7803219">tumanlar va shaharlar boʻysunuvida tumanlar va shaharlar hokimliklari tomonidan taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari bilan kelishilgan holda tashkil etiladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803225" id="-7803225">(30-modda oltinchi qismining toʻrtinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789632">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-5013606" id="-5013606">Nodavlat taʼlim muassasalarini tashkil etish ularning taʼsischilari tomonidan amalga oshiriladi. </div></div><div class="BY_DEFAULT"><div name="-5591498" id="-5591498"></div></div><div class="ACT_TEXT"><div name="-5591499" id="-5591499">Taʼlim tashkilotlarini qayta tashkil etish va tugatish qonunchilikda belgilangan tartibda amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591505" id="-5591505"><em>(</em>30-moddaning sakkizinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405575">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="BY_DEFAULT"><div name="-7098982" id="-7098982"></div></div><div class="ACT_TEXT"><div name="-7098983" id="-7098983">Taʼlim tashkilotlarini tashkil etish, qayta tashkil etish va tugatish toʻgʻrisidagi maʼlumotlar davlat statistika organlariga, Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligiga, Oliy taʼlim, fan va innovatsiyalar vazirligiga hamda Kambagʻallikni qisqartirish va bandlik vazirligining hududiy organlariga taqdim etiladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7098992" id="-7098992">(30-moddaning toʻqqizinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094205">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013611" id="-5013611">31-modda. Nodavlat taʼlim tashkilotlari </div></div><div class="BY_DEFAULT"><div name="-7803232" id="-7803232"></div></div><div class="ACT_TEXT"><div name="-7803239" id="-7803239">Nodavlat taʼlim tashkilotlari oʻz faoliyatini litsenziya asosida amalga oshiradi, bundan qoʻshimcha taʼlimni, kadrlarni qayta tayyorlash va ularning malakasini oshirishni amalga oshiruvchi taʼlim tashkilotlari mustasno.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803246" id="-7803246">(31-moddaning birinchi qismi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789633">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-5013614" id="-5013614">Nodavlat taʼlim tashkilotlari litsenziya talablariga va shartlariga muvofiq taʼlim xizmatlari koʻrsatadi. </div></div><div class="ACT_TEXT"><div name="-5013616" id="-5013616">Davlat taʼlim standartlari va davlat taʼlim talablariga muvofiq taʼlim xizmatlarini koʻrsatuvchi nodavlat taʼlim tashkilotlari bitiruvchilarga davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjatlarni beradi. </div></div><div class="BY_DEFAULT"><div name="-5685059" id="-5685059"></div></div><div class="ACT_TEXT"><div name="-5685061" id="-5685061">Kadrlar malakasini oshirish va ularni qayta tayyorlash boʻyicha nodavlat taʼlim xizmatlarini koʻrsatuvchi taʼlim tashkilotlari tomonidan bitiruvchilarga davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjat berilishi mumkin. Bunda kadrlar malakasini oshirish va ularni qayta tayyorlash boʻyicha nodavlat taʼlim xizmatlarini koʻrsatuvchi taʼlim tashkilotlari belgilangan tartibda attestatsiyadan va davlat akkreditatsiyasidan oʻtishi kerak.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5685062" id="-5685062">(31-modda Oʻzbekiston Respublikasining 2021-yil 12-oktabrdagi OʻRQ-721-sonli<a href="https://lex.uz/uz/docs/5674701?ONDATE=12.10.2021 00#5675921"></a> <a href="https://lex.uz/uz/docs/-5674701?ONDATE=12.10.2021 00#-5675927">Qonuniga</a> asosan toʻrtinchi qism bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 12.10.2021-y., 03/21/721/0952-son)</div></div><div class="ACT_TEXT"><div name="-5013617" id="-5013617">Mustaqil ishlab chiqilgan va litsenziyada koʻrsatilgan oʻquv dasturlari boʻyicha taʼlim xizmatlari koʻrsatadigan nodavlat taʼlim tashkilotlari bitiruvchilarga Oʻzbekiston Respublikasida tan olinadigan taʼlim toʻgʻrisidagi hujjatlarni beradi.</div></div><div class="ACT_TEXT"><div name="-5013618" id="-5013618">Nodavlat taʼlim tashkilotlari normativ-huquqiy hujjatlar talablariga muvofiq taʼlim-tarbiya jarayonini tashkil etish uchun zarur shart-sharoitlar yaratish va yuqori kasbiy mahoratga ega boʻlgan pedagog kadrlar va boshqa kadrlarni jalb qilish boʻyicha chora-tadbirlar koʻradi.</div></div><div class="ACT_TEXT"><div name="-5013619" id="-5013619">Nodavlat taʼlim tashkilotlari tomonidan ishlab chiqilgan oʻquv dasturlari boʻyicha oʻqitish taʼlim oluvchi yoxud uning ota-onasi yoki boshqa qonuniy vakillari va nodavlat taʼlim tashkiloti oʻrtasida tuziladigan, oʻqitish muddatlari, shartlari va toʻlovlari, tomonlarning huquq va majburiyatlari hamda boshqa shartlar belgilanadigan shartnoma asosida amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013621" id="-5013621">32-modda. Taʼlim tashkilotining ustavi </div></div><div class="ACT_TEXT"><div name="-5013623" id="-5013623">Taʼlim tashkilotining ustavi taʼlim turlarining oʻziga xos xususiyatlarini inobatga olgan holda ishlab chiqiladi.</div></div><div class="ACT_TEXT"><div name="-5013625" id="-5013625">Taʼlim tashkilotining ustavida, qoida tariqasida, quyidagilar koʻrsatiladi:</div></div><div class="ACT_TEXT"><div name="-5013627" id="-5013627">taʼlim turi va shakli;</div></div><div class="ACT_TEXT"><div name="-5013630" id="-5013630">taʼlim tashkilotining maqsad va vazifalari;</div></div><div class="ACT_TEXT"><div name="-5013631" id="-5013631">oʻquv-tarbiyaviy va ilmiy-metodik ishlarni tashkil etish hamda mazmuni;</div></div><div class="ACT_TEXT"><div name="-5013633" id="-5013633">taʼlim tashkilotiga qabul qilish tartibi;</div></div><div class="ACT_TEXT"><div name="-5013637" id="-5013637">taʼlim tashkilotining tuzilmasi, boshqaruv organlari va jamoatchilik tuzilmalari; </div></div><div class="ACT_TEXT"><div name="-5013638" id="-5013638">taʼlim oluvchilar, pedagog kadrlar, oʻquv-tarbiya ishlari boʻyicha xodimlar, maʼmuriy-boshqaruv xodimlarining maqomi, huquqlari va majburiyatlari; </div></div><div class="ACT_TEXT"><div name="-5013641" id="-5013641">taʼlim tashkilotining mol-mulki va vositalari;</div></div><div class="ACT_TEXT"><div name="-5013643" id="-5013643">taʼlim tashkilotini tashkil etish, qayta tashkil etish va tugatish tartibi.</div></div><div class="ACT_TEXT"><div name="-5013646" id="-5013646">Taʼlim tashkilotining namunaviy ustavi:</div></div><div class="BY_DEFAULT"><div name="-7803272" id="-7803272"></div></div><div class="ACT_TEXT"><div name="-7803273" id="-7803273">umumiy oʻrta taʼlim tashkilotlari, Prezident, ijod va ixtisoslashtirilgan maktablar hamda bolalar uchun qoʻshimcha taʼlim tashkilotlari uchun — Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi tomonidan;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803280" id="-7803280">(32-modda uchinchi qismining ikkinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789635">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099014" id="-7099014">(32-modda uchinchi qismining uchinchi xatboshisi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094210">Qonuniga </a>asosan chiqarilgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7803282" id="-7803282"></div></div><div class="ACT_TEXT"><div name="-7803287" id="-7803287">oliy taʼlim tashkilotlari huzuridagi ixtisoslashtirilgan maktablar, oʻrta maxsus, professional va oliy taʼlim tashkilotlari, shuningdek katta yoshdagilar uchun qoʻshimcha taʼlim tashkilotlari uchun — Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi tomonidan;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803288" id="-7803288">(32-modda uchinchi qismining uchinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789636">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="BY_DEFAULT"><div name="-6685736" id="-6685736"></div></div><div class="ACT_TEXT"><div name="-6685738" id="-6685738">kadrlarni qayta tayyorlash va ularning malakasini oshirish boʻyicha taʼlim tashkilotlari uchun — tegishli vazirliklar va idoralar tomonidan ishlab chiqiladi. </div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-6685744" id="-6685744">(32-modda uchinchi qismining beshinchi xatboshisi Oʻzbekiston Respublikasining 2023-yil 28-noyabrdagi OʻRQ-880-sonli <a href="https://lex.uz/uz/docs/-6678807?ONDATE=29.11.2023 01#-6679921">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 29.11.2023-y., 03/23/880/0905-son)</div></div><div class="ACT_TEXT"><div name="-5013656" id="-5013656">Taʼlim tashkilotining ustavi taʼlim tashkilotining taʼsischilari tomonidan tasdiqlanadi va hududiy tegishlilik boʻyicha Davlat xizmatlari markazi tomonidan roʻyxatga olinadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013658" id="-5013658">33-modda. Taʼlim berish tili</div></div><div class="ACT_TEXT"><div name="-5013659" id="-5013659">Taʼlim tashkilotlarida oʻqitish tilidan foydalanish tartibi “Davlat tili haqida”gi Oʻzbekiston Respublikasi <a href="https://lex.uz/uz/docs/-121051">Qonuni</a> bilan tartibga solinadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013660" id="-5013660">34-modda. Davlat taʼlim standartlari va davlat taʼlim talablari </div></div><div class="ACT_TEXT"><div name="-5013661" id="-5013661">Davlat taʼlim standartlari umumiy oʻrta, oʻrta maxsus, professional hamda oliy taʼlim mazmuni va sifatiga oid talablarni belgilaydi. </div></div><div class="ACT_TEXT"><div name="-5013664" id="-5013664">Davlat taʼlim talablari:</div></div><div class="BY_DEFAULT"><div name="-7803291" id="-7803291"></div></div><div class="ACT_TEXT"><div name="-7803294" id="-7803294">qoʻshimcha taʼlim, oliy taʼlimdan keyingi taʼlim, shuningdek kadrlarni qayta tayyorlash va ularning malakasini oshirish mazmunini;</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803298" id="-7803298">(34-modda ikkinchi qismining ikkinchi xatboshisi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789637">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-5013666" id="-5013666">taʼlim tuzilmasini va taʼlimni amalga oshirish shartlarini;</div></div><div class="ACT_TEXT"><div name="-5013668" id="-5013668">taʼlim oluvchilarning jismoniy, shaxsiy, intellektual, ilmiy va kasbga oid sifatlari toʻgʻrisidagi normalarni belgilaydi. </div></div><div class="ACT_TEXT"><div name="-5013671" id="-5013671">Maktabgacha taʼlim tashkilotlarida maktabgacha taʼlim va tarbiyaning davlat standarti qoʻllaniladi. </div></div><div class="ACT_TEXT"><div name="-5013674" id="-5013674">Davlat taʼlim standartlarini va (yoki) davlat taʼlim talablarini bajarish barcha taʼlim tashkilotlari uchun majburiydir, bundan ushbu moddaning <a href="https://lex.uz/uz/docs/-5013007#-5013677">beshinchi qismida </a>nazarda tutilgan hollar mustasno.</div></div><div class="BY_DEFAULT"><div name="-7099101" id="-7099101"></div></div><div class="ACT_TEXT"><div name="-7099114" id="-7099114">Oʻrta maxsus, professional, oliy taʼlim xizmatlarini koʻrsatuvchi hamda faoliyatini xabardor qilish tartibida amalga oshiradigan nodavlat taʼlim tashkilotlari mustaqil ishlab chiqilgan va litsenziyada yoki xabarnomada koʻrsatilgan taʼlim dasturlari asosida taʼlim faoliyatini amalga oshirishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099119" id="-7099119">(34-moddaning beshinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094215">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099124" id="-7099124"></div></div><div class="ACT_TEXT"><div name="-7099128" id="-7099128">Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi davlat taʼlim standartlari, malaka talablari, oliy taʼlim, oʻrta maxsus taʼlim hamda professional taʼlimning oʻquv rejalari va oʻquv dasturlari ishlab chiqilishini taʼminlaydi. Ushbu maqsadlar uchun Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi tayanch davlat oliy taʼlim va professional taʼlim tashkilotlarini belgilaydi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099137" id="-7099137">(34-moddaning oltinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094215">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013682" id="-5013682">Tayanch davlat oliy taʼlim va professional taʼlim muassasalari kadrlarning talabgorlari ishtirokida davlat taʼlim standartlarini, malaka talablarini, oʻquv rejalari va oʻquv dasturlarini tayyorlashni amalga oshiradi. Davlat taʼlim standartlari kasbiy standartlar asosida ishlab chiqiladi.</div></div><div class="BY_DEFAULT"><div name="-7099148" id="-7099148"></div></div><div class="ACT_TEXT"><div name="-7099153" id="-7099153">Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi umumiy oʻrta taʼlimning davlat taʼlim standartlari ishlab chiqilishini taʼminlaydi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099160" id="-7099160">(34-moddaning sakkizinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094218">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099168" id="-7099168"></div></div><div class="ACT_TEXT"><div name="-7099169" id="-7099169">Oliy, professional, oʻrta maxsus va umumiy oʻrta taʼlimning davlat taʼlim standartlari, malaka talablari, oʻquv rejalari va oʻquv dasturlari tegishincha Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi hamda Maktabgacha va maktab taʼlimi vazirligi tomonidan tasdiqlanadi. Tegishli vakolatlar berilgan boshqa vazirliklar va idoralar davlat taʼlim standartlarini tegishincha Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi hamda Maktabgacha va maktab taʼlimi vazirligi bilan kelishilgan holda ishlab chiqadi hamda tasdiqlaydi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099170" id="-7099170">(34-moddaning toʻqqizinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094219">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013693" id="-5013693">Davlat taʼlim talablari taʼlim sohasidagi tegishli vakolatli davlat boshqaruvi organlari tomonidan ishlab chiqiladi va tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-5013694" id="-5013694">Jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan shaxslarni oʻqitish maxsus oʻquv dasturlari asosida amalga oshiriladi. </div></div><div class="BY_DEFAULT"><div name="-7099172" id="-7099172"></div></div><div class="ACT_TEXT"><div name="-7099173" id="-7099173">Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi davlat oliy taʼlim tashkilotlariga mustaqil ishlab chiqilgan va tasdiqlangan oʻquv dasturlari, malaka talablari hamda oʻquv rejalari asosida taʼlim xizmatlari koʻrsatish boʻyicha vakolatlarni berishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099174" id="-7099174">(34-moddaning oʻn ikkinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094221">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013699" id="-5013699">35-modda. Taʼlim jarayoniga oʻquv rejalari va oʻquv dasturlarini joriy etish </div></div><div class="ACT_TEXT"><div name="-5013702" id="-5013702">Oʻquv rejalari va oʻquv dasturlari tegishli taʼlim bosqichlarining maqsad hamda vazifalari asosida ishlab chiqiladi. </div></div><div class="BY_DEFAULT"><div name="-7099177" id="-7099177"></div></div><div class="ACT_TEXT"><div name="-7099179" id="-7099179">Tegishli davlat taʼlim tashkilotlaridagi oʻquv rejalari va oʻquv dasturlarining mazmuni, ularni ishlab chiqish hamda joriy etish tartibi Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi hamda Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099180" id="-7099180">(35-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094224">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099183" id="-7099183"></div></div><div class="ACT_TEXT"><div name="-7099184" id="-7099184">Moliyaviy mustaqillik berilgan davlat oliy taʼlim tashkilotlari oʻquv rejalari va oʻquv dasturlarini kasbiy standartlar asosida mustaqil tasdiqlashga, shuningdek taʼlim tilini hamda bakalavriat taʼlim yoʻnalishlarining va magistratura mutaxassisliklarining xususiyatlarini inobatga olgan holda taʼlim shaklini belgilashga haqli.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099187" id="-7099187">(35-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094231">Qonuniga </a>asosan uchinchi qism bilan toʻldirilgan — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013709" id="-5013709">Umumtaʼlim fanlarining oʻquv dasturlari shaxsni har tomonlama kamol toptirishga, taʼlim oluvchilarda bilim, malaka, koʻnikmalarni, saviyani shakllantirishga va ularning qobiliyatini rivojlantirishga qaratilgan boʻlishi kerak. </div></div><div class="ACT_TEXT"><div name="-5013715" id="-5013715">Kasbga oid fanlarning oʻquv dasturlari taʼlim oluvchilar tomonidan tegishli kasblar va mutaxassisliklarni egallashga qaratilgan. </div></div><div class="ACT_TEXT"><div name="-5013718" id="-5013718">Taʼlim jarayoniga oʻquv rejalari va oʻquv dasturlarini joriy etish taʼlim tashkilotlari tomonidan amalga oshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013721" id="-5013721">Oʻquv rejalari va oʻquv dasturlarini joriy etish jarayonida zamonaviy pedagogik texnologiyalar, oʻqitishning innovatsion shakllari va usullari, axborot-kommunikatsiya texnologiyalari qoʻllaniladi. </div></div><div class="ACT_TEXT"><div name="-5013724" id="-5013724">Taʼlim jarayoniga oʻquv rejalari va oʻquv dasturlarini joriy etish chogʻida taʼlim tashkilotlari kredit-modul tizimiga asoslangan oʻqitish texnologiyalaridan foydalanishi mumkin.</div></div><div class="ACT_TEXT"><div name="-5013726" id="-5013726">Oʻquv rejasida, qoida tariqasida, taʼlim jarayonining jadvali, oʻqitishning boshlanishi, muddati va davriyligi, oʻquv yillari, choraklar, semestrlar, amaliyot, taʼtillar hamda attestatsiya, ajratilgan haftalar soni, oʻrganiladigan fanlar (modullar) va ularga ajratilgan soatlar (kreditlar) hamda boshqa zarur parametrlar aks ettiriladi. </div></div><div class="ACT_TEXT"><div name="-5013728" id="-5013728">Professional va oliy taʼlim, kadrlarni qayta tayyorlash va ularning malakasini oshirishga doir oʻquv rejalarda taʼlim oluvchilar uchun amaliyot oʻtash nazarda tutiladi. </div></div><div class="BY_DEFAULT"><div name="-7099197" id="-7099197"></div></div><div class="ACT_TEXT"><div name="-7099201" id="-7099201">Taʼlim oluvchilarning amaliyotni oʻtash tartibi va uni tashkil etish taʼlim tashkilotlari tomonidan mustaqil belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099203" id="-7099203">(35-moddaning oʻn birinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094247">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013733" id="-5013733">Professional va oliy taʼlimga doir oʻquv rejalari davlat taʼlim standartlariga muvofiq mutaxassislik fanlaridan, shuningdek umumkasbiy, matematika, tabiiy-ilmiy, gumanitar va qoʻshimcha fanlardan shakllantiriladi. </div></div><div class="ACT_TEXT"><div name="-5013735" id="-5013735">Oʻquv rejalariga davlat boshqaruvi organlarining topshiriqlariga asosan va ushbu Qonunda nazarda tutilmagan boshqa yoʻl bilan qoʻshimcha fanlarni kiritishga yoʻl qoʻyilmaydi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013738" id="-5013738">36-modda. Taʼlim sohasidagi eksperimental va innovatsion faoliyat </div></div><div class="ACT_TEXT"><div name="-5013739" id="-5013739">Taʼlim sohasidagi eksperimental va innovatsion faoliyat taʼlimni modernizatsiya qilish maqsadida amalga oshiriladi hamda yangi taʼlim texnologiyalari va resurslarini ishlab chiqishga, ularni sinovdan oʻtkazishga hamda taʼlim jarayoniga joriy etishga qaratilgan. Eksperimental va innovatsion faoliyatni amalga oshirish tartibi va shartlari Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi. </div></div><div class="ACT_TEXT"><div name="-5013741" id="-5013741">Taʼlim sohasidagi vakolatli davlat boshqaruvi organlari va mahalliy davlat hokimiyati organlari innovatsion oʻquv dasturlari va loyihalarini amalga oshirish hamda ularning natijalarini amaliyotga joriy etish uchun oʻz vakolatlari doirasida shart-sharoitlar yaratadi. </div></div><div class="ACT_TEXT"><div name="-5013743" id="-5013743">Iqtisodiy rivojlanish va innovatsion faoliyat ehtiyojlaridan kelib chiqqan holda, davlat tomonidan oliy taʼlim tashkilotlari olimlarining ilmiy-tadqiqot ishlari natijalarini ishlab chiqarish jarayoniga joriy etish uchun tegishli shart-sharoitlar, shuningdek oliy taʼlim tashkilotlari taʼlim jarayonining yanada takomillashtirilgan shakllariga bosqichma-bosqich oʻtishi uchun imkoniyatlar yaratiladi. </div></div><div class="ACT_TEXT"><div name="-5013746" id="-5013746">Taʼlim tashkilotlari eksperimental va innovatsion faoliyatda masofaviy taʼlim texnologiyalaridan foydalanishi mumkin. </div></div><div class="CLAUSE_DEFAULT"><div name="-5013748" id="-5013748">37-modda. Taʼlim tashkilotlari faoliyatining ochiqligi va shaffofligi </div></div><div class="ACT_TEXT"><div name="-5013750" id="-5013750">Taʼlim tashkilotlari faoliyatining ochiqligi va shaffofligi ularning rasmiy veb-saytlarida Internet jahon tarmogʻida joylashtiriladigan taʼlim tashkilotlari faoliyati toʻgʻrisidagi ochiq axborot resurslari bilan taʼminlanadi. </div></div><div class="ACT_TEXT"><div name="-5013751" id="-5013751">Taʼlim tashkilotlari rasmiy veb-saytlarida quyidagilarni joylashtiradi:</div></div><div class="ACT_TEXT"><div name="-5013752" id="-5013752">taʼlim tashkilotining ustavi; </div></div><div class="ACT_TEXT"><div name="-5013756" id="-5013756">taʼlim berish tillari haqida maʼlumot;</div></div><div class="ACT_TEXT"><div name="-5013758" id="-5013758">davlat taʼlim standartlari, davlat taʼlim talablari;</div></div><div class="ACT_TEXT"><div name="-5013759" id="-5013759">taʼlim faoliyatining moddiy-texnika taʼminoti haqida maʼlumot;</div></div><div class="ACT_TEXT"><div name="-5013760" id="-5013760">litsenziya (nodavlat taʼlim tashkilotlari uchun);</div></div><div class="ACT_TEXT"><div name="-5013761" id="-5013761">taʼlim tashkilotining reytingi;</div></div><div class="ACT_TEXT"><div name="-5013762" id="-5013762">taʼlim faoliyatini amalga oshirish uchun davlat akkreditatsiyasi toʻgʻrisidagi sertifikat;</div></div><div class="ACT_TEXT"><div name="-5013763" id="-5013763">ilmiy tadqiqotlar yoʻnalishlari va natijalari, shuningdek ularni amalga oshirish uchun ilmiy-tadqiqot bazasi toʻgʻrisidagi maʼlumot (oliy taʼlim uchun); </div></div><div class="ACT_TEXT"><div name="-5013764" id="-5013764">taʼlim oluvchilarga stipendiyalar berish tartibi, ularga ijtimoiy yordam koʻrsatishning mavjudligi va shartlari toʻgʻrisidagi maʼlumot;</div></div><div class="ACT_TEXT"><div name="-5013765" id="-5013765">vaqtincha yashash joylarining mavjudligi va yashash joylarining soni, shuningdek toʻlov miqdori toʻgʻrisidagi maʼlumot;</div></div><div class="ACT_TEXT"><div name="-5013767" id="-5013767">pedagoglar va taʼlim oluvchilarning soni, shuningdek pedagoglarning ilmiy salohiyati toʻgʻrisidagi maʼlumot.</div></div><div class="ACT_TEXT"><div name="-5013769" id="-5013769">Taʼlim tashkilotlarining rasmiy veb-saytlariga joylashtiriladigan axborotning ishonchligini taʼminlash uchun taʼlim tashkilotlarining rahbarlari shaxsan javobgardir. </div></div><div class="BY_DEFAULT"><div name="-5591506" id="-5591506"></div></div><div class="ACT_TEXT"><div name="-5591507" id="-5591507">Ayrim taʼlim tashkilotlarining faoliyati toʻgʻrisidagi axborotdan foydalanish qonunchilikda belgilangan hollarda va tartibda cheklanishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591510" id="-5591510"><em>(</em>37-moddaning toʻrtinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405576">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5013773" id="-5013773">38-modda. Taʼlim tashkilotlariga oʻqishga qabul qilish</div></div><div class="BY_DEFAULT"><div name="-5591518" id="-5591518"></div></div><div class="ACT_TEXT"><div name="-5591520" id="-5591520">Taʼlim tashkilotlariga oʻqishga qabul qilish barcha talabgorlar uchun taʼlim olishga doir teng imkoniyatlarning taʼminlanishi prinsipi asosida amalga oshiriladi, shaxslarning ayrim toifalari bundan mustasno, ularga qonunchilikka muvofiq imtiyozlar berilishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591523" id="-5591523"><em>(</em>38-moddaning birinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405579">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="BY_DEFAULT"><div name="-7803301" id="-7803301"></div></div><div class="ACT_TEXT"><div name="-7803304" id="-7803304">Taʼlim tashkilotlari talabgorlarni va (yoki) ularning ota-onasini yoki boshqa qonuniy vakillarini ustav, litsenziya yoki xabarnoma qabul qilinganligi toʻgʻrisidagi tasdiqnoma (nodavlat taʼlim tashkilotlari uchun), davlat akkreditatsiyasi toʻgʻrisidagi sertifikat (bundan qoʻshimcha nodavlat taʼlim xizmatlarini koʻrsatuvchi nodavlat taʼlim tashkilotlari mustasno), oʻquv dasturi hamda taʼlim faoliyatini tartibga soluvchi boshqa hujjatlar, oʻquvchilarning huquqlari va majburiyatlari bilan tanishtirishi shart.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803306" id="-7803306">(38-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789638">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-5013778" id="-5013778">Jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalar oʻqishga oʻz ota-onasining yoki boshqa qonuniy vakillarining roziligiga va tibbiy-psixologik-pedagogik komissiyaning xulosasiga binoan qabul qilinadi. </div></div><div class="BY_DEFAULT"><div name="-7099211" id="-7099211"></div></div><div class="ACT_TEXT"><div name="-7099216" id="-7099216">Ayrim taʼlim tashkilotlariga (oliy taʼlim tashkilotlariga, akademik litseylarga, Prezident, ijod, ixtisoslashtirilgan maktablar va boshqalarga) oʻqishga qabul qilish tanlov asosida amalga oshiriladi. Taʼlim tashkilotlariga tanlov asosida oʻqishga qabul qilish chogʻida tanlov ishtirokchilariga tanlovni oʻtkazish tartibi toʻgʻrisidagi axborot taqdim etiladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099221" id="-7099221">(38-moddaning toʻrtinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094249">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099228" id="-7099228"></div></div><div class="ACT_TEXT"><div name="-7099232" id="-7099232">Davlat oliy taʼlim va professional taʼlim tashkilotlariga oʻqishga qabul qilish davlat granti va (yoki) toʻlov-shartnoma asosida amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099233" id="-7099233">(38-moddaning beshinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094250">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099234" id="-7099234"></div></div><div class="ACT_TEXT"><div name="-7099235" id="-7099235">Davlat taʼlim muassasalari va tashkilotlariga oʻqishga qabul qilish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099236" id="-7099236">(38-moddaning oltinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094251">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099237" id="-7099237"></div></div><div class="ACT_TEXT"><div name="-7099238" id="-7099238">Nodavlat taʼlim tashkilotlariga oʻqishga qabul qilish tartibi taʼlim tashkilotlariga oʻqishga qabul qilishga oid amaldagi normativ-huquqiy hujjatlarda nazarda tutilgan qoidalarni inobatga olgan holda, ushbu taʼlim tashkilotlari tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099240" id="-7099240">(38-moddaning yettinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094254">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013789" id="-5013789">Chet ellik fuqarolarni Oʻzbekiston Respublikasining davlat taʼlim muassasalariga qabul qilish toʻlov-shartnoma asosida (bundan davlat granti ajratilgan hollar mustasno) amalga oshiriladi.</div></div><div class="BY_DEFAULT"><div name="-7099242" id="-7099242"></div></div><div class="ACT_TEXT"><div name="-7099244" id="-7099244">Oliy taʼlim tashkilotlariga davlat granti asosida oʻqishga qabul qilish parametrlari Oʻzbekiston Respublikasi Prezidenti tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099245" id="-7099245">(38-moddaning toʻqqizinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094257">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099246" id="-7099246"></div></div><div class="ACT_TEXT"><div name="-7099249" id="-7099249">Oliy taʼlim tashkilotlariga oʻqishga qabul qilish chogʻida imtiyozli kontingent uchun qoʻshimcha qabul parametrlari belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099251" id="-7099251">(38-moddaning oʻninchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094262">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013795" id="-5013795">39-modda. Davlat taʼlim muassasalariga oʻqishga maqsadli qabul qilish </div></div><div class="ACT_TEXT"><div name="-5013796" id="-5013796">Davlat taʼlim muassasalariga oʻqishga maqsadli qabul qilish tegishli hududlarning, sohalar va tarmoqlarning kadrlarga boʻlgan ehtiyojlaridan kelib chiqqan holda ular uchun belgilangan taʼlim oluvchilarni qabul qilish parametrlari doirasida amalga oshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013797" id="-5013797">Davlat taʼlim muassasalariga oʻqishga maqsadli qabul qilish kadrlar buyurtmachilari, davlat taʼlim muassasalari va fuqarolar oʻrtasida tuziladigan shartnomalar asosida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5013798" id="-5013798">Davlat taʼlim muassasalariga maqsadli qabul qilish tartibida oʻqishga kirish umumiy asoslarda tanlov natijalariga muvofiq amalga oshiriladi. </div></div><div class="CLAUSE_DEFAULT"><div name="-5013799" id="-5013799">40-modda. Taʼlim toʻgʻrisidagi hujjat </div></div><div class="ACT_TEXT"><div name="-5013801" id="-5013801">Akkreditatsiya qilingan taʼlim tashkilotlarining davlat taʼlim standartlariga va davlat taʼlim talablariga muvofiq taʼlim olgan bitiruvchilariga davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjat (shahodatnoma, diplom, sertifikat, guvohnoma) beriladi. Davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjat oilada taʼlim olgan yoki mustaqil taʼlim olgan hamda akkreditatsiya qilingan davlat taʼlim muassasalarining tegishli oʻquv dasturlari boʻyicha eksternat tartibida yakuniy va davlat attestatsiyasidan oʻtgan shaxslarga ham beriladi.</div></div><div class="ACT_TEXT"><div name="-5013802" id="-5013802">Oʻrta maxsus taʼlim, professional taʼlim hamda oliy taʼlim toʻgʻrisidagi diplomga oʻzlashtirilgan fanlar roʻyxati, ularning hajmlari va fanlar boʻyicha baholari yozilgan varaqa ilova qilinadi. </div></div><div class="ACT_TEXT"><div name="-5013803" id="-5013803">Tegishli ilmiy darajani olish uchun dissertatsiya himoya qilgan shaxslarga falsafa doktori (Doctor of Philosophy (PhD) yoki fan doktori (Doctor of Science (DSc) ilmiy darajasi beriladi va davlat tomonidan tasdiqlangan namunadagi diplom topshiriladi. </div></div><div class="ACT_TEXT"><div name="-5013805" id="-5013805">Oʻzbekiston Respublikasining va xorijiy davlatlarning hukumatlari oʻrtasidagi ikki tomonlama bitimlar asosida taʼlim toʻgʻrisidagi hujjatlarni oʻzaro tan olish amalga oshirilishi mumkin. </div></div><div class="ACT_TEXT"><div name="-5013806" id="-5013806">Uzluksiz taʼlimning tegishli turini tamomlamagan shaxslarga belgilangan namunadagi maʼlumotnoma beriladi. </div></div><div class="ACT_TEXT"><div name="-5013813" id="-5013813">Davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjat, shuningdek nodavlat taʼlim tashkilotlari tomonidan beriladigan Oʻzbekiston Respublikasida tan olinadigan taʼlim toʻgʻrisidagi hujjat uzluksiz taʼlimning keyingi turi (darajasi) boʻyicha oʻqishni davom ettirish yoki tegishli mutaxassislik va kasb boʻyicha ishlash huquqini beradi.</div></div><div class="ACT_TEXT"><div name="-5013814" id="-5013814">Xorijiy davlatlarning va Oʻzbekiston Respublikasining oliy taʼlim tashkilotlari oʻrtasida tuzilgan shartnoma asosida ularning bitiruvchilariga Oʻzbekiston Respublikasi hududida oliy maʼlumot toʻgʻrisidagi hujjat sifatida tan olinadigan ikki tomonlama diplom (Double Diploma) berilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013815" id="-5013815">41-modda. Taʼlim tashkilotlarining reytingi</div></div><div class="ACT_TEXT"><div name="-5013816" id="-5013816">Taʼlim tashkilotlarining reytingi:</div></div><div class="ACT_TEXT"><div name="-5013817" id="-5013817">taʼlim tashkilotlari oʻrtasida sogʻlom raqobat muhitini shakllantirish;</div></div><div class="ACT_TEXT"><div name="-5013820" id="-5013820">ilmiy-pedagogik faoliyat darajasining oʻsishini va sifatining oshishini ragʻbatlantirish;</div></div><div class="ACT_TEXT"><div name="-5013822" id="-5013822">pedagog xodimlarning ilmiy salohiyatidan samarali foydalanish;</div></div><div class="ACT_TEXT"><div name="-5013823" id="-5013823">oʻqitish sifatining yuqori koʻrsatkichlariga erishish;</div></div><div class="ACT_TEXT"><div name="-5013825" id="-5013825">mehnat bozorida talab yuqori boʻlgan malakali kadrlar tayyorlash maqsadlarida belgilanadi.</div></div><div class="ACT_TEXT"><div name="-5013826" id="-5013826">Reytingni belgilash uchun taʼlim tashkiloti tomonidan taqdim etilgan maʼlumotlarning ishonchliligi uchun taʼlim tashkilotining rahbari shaxsan javobgar boʻladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013827" id="-5013827">42-modda. Taʼlim tizimidagi monitoring </div></div><div class="ACT_TEXT"><div name="-5013831" id="-5013831">Taʼlim tizimidagi monitoring taʼlimning holatini, taʼlim natijalarining oʻzgarishi surʼatlarini, taʼlim faoliyatini amalga oshirish uchun yaratilgan shart-sharoitlarni oʻrganish va kuzatishni, shuningdek taʼlim oluvchilarning kontingenti toʻgʻrisidagi maʼlumotlarni va boshqaruv qarorlari qabul qilinishini tahlil etishni oʻz ichiga oladi. </div></div><div class="BY_DEFAULT"><div name="-7099286" id="-7099286"></div></div><div class="ACT_TEXT"><div name="-7099289" id="-7099289">Taʼlim tashkilotlarining monitoringi taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari va ularning hududiy boʻlinmalari tomonidan amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099296" id="-7099296">(42-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094264">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099298" id="-7099298"></div></div><div class="ACT_TEXT"><div name="-7099300" id="-7099300">Taʼlim holatining tahlili va uni rivojlantirish istiqbollari toʻgʻrisidagi axborot taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlarining va ular hududiy boʻlinmalarining, shuningdek taʼlim tashkilotlarining rasmiy veb-saytlariga joylashtiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099301" id="-7099301">(42-moddaning uchinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094264">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099302" id="-7099302"></div></div><div class="ACT_TEXT"><div name="-7099304" id="-7099304">Taʼlim tizimidagi maʼlumotlar jumlasiga rasmiy statistika maʼlumotlari, taʼlim tizimi monitoringi natijalari, taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlarining va ular hududiy boʻlinmalarining, mahalliy davlat hokimiyati organlarining hamda taʼlim tashkilotlarining maʼlumotlari kiradi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099307" id="-7099307">(42-moddaning toʻrtinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094264">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5013842" id="-5013842">43-modda. Taʼlim sohasidagi davlat nazorati </div></div><div class="ACT_TEXT"><div name="-5013843" id="-5013843">Taʼlim sohasidagi davlat nazorati berilayotgan taʼlimning mazmuni va sifati davlat taʼlim standartlariga, davlat taʼlim talablari va oʻquv dasturlariga, shuningdek ushbu Qonun talablariga muvofiqligini aniqlash yoʻli bilan amalga oshiriladi.</div></div><div class="BY_DEFAULT"><div name="-7099316" id="-7099316"></div></div><div class="ACT_TEXT"><div name="-7099317" id="-7099317">Taʼlim tashkilotlari taʼlim sifati ustidan nazoratni amalga oshirishda taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlariga koʻmaklashadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099323" id="-7099323">(43-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094270">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099324" id="-7099324"></div></div><div class="ACT_TEXT"><div name="-7099328" id="-7099328">Taʼlim tashkilotlari tomonidan berilayotgan taʼlimning mazmuni va sifati taʼlim toʻgʻrisidagi qonunchilikka nomuvofiqligi aniqlangan hollarda taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari nomuvofiqlikni bartaraf etish yuzasidan ularga taqdimnoma kiritadi. Aniqlangan nomuvofiqlik bartaraf etilmagan taqdirda taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari taʼlim tashkilotining davlat akkreditatsiyasi toʻgʻrisidagi sertifikatini qonunchilikka muvofiq bekor qilishga haqli.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099331" id="-7099331">(43-moddaning uchinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094270">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5013846" id="-5013846">Taʼlim sifati ustidan nazorat qilish vakolatlariga ega boʻlmagan organlar tomonidan taʼlim tashkilotlarining taʼlim sifatini, taʼlim jarayoni tashkil etilishini, pedagog xodimlarining mehnat faoliyatini, taʼlim oluvchilarining oʻzlashtirishini tekshirishga yoʻl qoʻyilmaydi.</div></div><div class="BY_DEFAULT"><div name="-7099332" id="-7099332"></div></div><div class="ACT_TEXT"><div name="-7099335" id="-7099335">Taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari Oʻzbekiston Respublikasi Prezidenti huzuridagi Tadbirkorlik subyektlarining huquqlari va qonuniy manfaatlarini himoya qilish boʻyicha vakilni xabardor qilgan holda nodavlat taʼlim tashkilotlarida taʼlim sifati, shuningdek litsenziyalash, ruxsat berish va xabardor qilish talablari hamda shartlariga rioya etilishi ustidan nazorat va monitoringni amalga oshiradi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099342" id="-7099342">(43-moddaning beshinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094275">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-6789297" id="-6789297">(5-bob Oʻzbekiston Respublikasining 2024-yil 1-fevraldagi OʻRQ-901-sonli <a href="https://lex.uz/uz/docs/-6786401?ONDATE=01.02.2024 00#-6787119">Qonuniga </a>asosan oʻz kuchini yoʻqotgan — Qonunchilik maʼlumotlari milliy bazasi, 01.02.2024-y., 03/24/901/0082-son)</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5013933" id="-5013933">6-bob. Taʼlim oluvchilarning, ular ota-onasining hamda boshqa qonuniy vakillarining huquq va majburiyatlari </div></div><div class="CLAUSE_DEFAULT"><div name="-5013934" id="-5013934">47-modda. Taʼlim oluvchilarning huquqlari</div></div><div class="ACT_TEXT"><div name="-5013936" id="-5013936">Taʼlim oluvchilar quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-5013937" id="-5013937">bepul asosda umumiy oʻrta, oʻrta maxsus taʼlim va boshlangʻich professional taʼlim olish;</div></div><div class="ACT_TEXT"><div name="-5013938" id="-5013938">yashash joyidagi (mikrohududdagi) davlat umumiy oʻrta taʼlim muassasasiga qabul qilinish;</div></div><div class="ACT_TEXT"><div name="-5013939" id="-5013939">taʼlim olish shakllarini erkin tanlash;</div></div><div class="ACT_TEXT"><div name="-5013940" id="-5013940">davlat taʼlim standartlari, davlat taʼlim talablari va oʻquv dasturlariga muvofiq sifatli taʼlim olish;</div></div><div class="ACT_TEXT"><div name="-5013941" id="-5013941">taʼlim olish uchun oʻzining ruhiy xususiyatlari va fiziologik rivojlanishi inobatga olingan holda zarur shart-sharoitlarga ega boʻlish, shuningdek bepul psixologik-tibbiy xizmatlardan foydalanish;</div></div><div class="ACT_TEXT"><div name="-5013942" id="-5013942">davlat taʼlim muassasasi tomonidan belgilangan tartibga muvofiq, professional taʼlim va oliy taʼlimning davlat taʼlim standartlari talablariga binoan ishlab chiqilgan, oʻzi oladigan taʼlimning mazmunini shakllantirishda ishtirok etish;</div></div><div class="ACT_TEXT"><div name="-5013943" id="-5013943">pedagog xodimlar va taʼlim-tarbiya jarayonining boshqa ishtirokchilari tomonidan hayoti va sogʻligʻiga qilinadigan har qanday jismoniy hamda ruhiy zoʻravonlikdan, shaxsi haqoratlanishidan himoyalanish;</div></div><div class="ACT_TEXT"><div name="-5013945" id="-5013945">taʼlim olish davrida dam olish va boshqa ijtimoiy ehtiyojlar uchun taʼtillar olish;</div></div><div class="ACT_TEXT"><div name="-5013946" id="-5013946">akademik taʼtillar va stipendiyalar olish, oʻqishni tiklash va oʻqishini boshqa taʼlim tashkilotlariga, bir taʼlim shaklidan, kasbdan, taʼlim yoʻnalishidan, mutaxassisligidan boshqasiga koʻchirish; </div></div><div class="ACT_TEXT"><div name="-5013947" id="-5013947">taʼlim tashkilotini boshqarishga doir masalalarni muhokama qilishda ishtirok etish;</div></div><div class="ACT_TEXT"><div name="-5013948" id="-5013948">taʼlim olish jarayonida taʼlim tashkilotining oʻquv, uslubiy, ilmiy-ishlab chiqarish, madaniy, sport va maishiy obyektlari xizmatlaridan bepul foydalanish;</div></div><div class="ACT_TEXT"><div name="-5013950" id="-5013950">taʼlim tashkilotining ilmiy-tadqiqot, tajriba-konstruktorlik, ilmiy-texnikaviy, eksperimental va innovatsion faoliyatida ishtirok etish.</div></div><div class="BY_DEFAULT"><div name="-5591691" id="-5591691"></div></div><div class="ACT_TEXT"><div name="-5591694" id="-5591694">Taʼlim oluvchilar qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591698" id="-5591698"><em>(</em>47-moddaning ikkinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405588">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5013953" id="-5013953">Taʼlim tashkilotlarida taʼlim oluvchilarni taʼlim olish bilan bogʻliq boʻlmagan ishlarga jalb etish taqiqlanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013954" id="-5013954">48-modda. Taʼlim oluvchilarning majburiyatlari </div></div><div class="ACT_TEXT"><div name="-5013955" id="-5013955">Taʼlim oluvchilar:</div></div><div class="ACT_TEXT"><div name="-5013956" id="-5013956">oʻquv dasturlari asosida bilim, malaka va koʻnikmalarni oʻzlashtirishi, mashgʻulotlarga qatnashishi, ularga mustaqil tayyorgarlik koʻrishi, pedagog xodimlarning topshiriqlarini bajarishi;</div></div><div class="ACT_TEXT"><div name="-5013957" id="-5013957">taʼlim-tarbiya jarayonining boshqa ishtirokchilariga nisbatan jismoniy va (yoki) ruhiy zoʻravonlik ishlatmasligi va ularning oʻz majburiyatlarini bajarishiga toʻsqinlik qilmasligi; </div></div><div class="ACT_TEXT"><div name="-5013958" id="-5013958">ustav (taʼsis hujjati) talablariga, ichki tartib-qoidalariga, vaqtincha yashash joylari qoidalariga va taʼlim faoliyatini tashkil etish hamda amalga oshirishga oid boshqa ichki hujjatlar talablariga rioya etishi;</div></div><div class="ACT_TEXT"><div name="-5013959" id="-5013959">axloqiy, maʼnaviy va jismoniy kamol topishga hamda oʻz dunyoqarashini kengaytirishga intilishi;</div></div><div class="ACT_TEXT"><div name="-5013960" id="-5013960">taʼlim-tarbiya jarayoni ishtirokchilarining shaʼni, qadr-qimmati va ishchanlik obroʻsini hurmat qilishi; </div></div><div class="ACT_TEXT"><div name="-5013961" id="-5013961">taʼlim tashkilotining mol-mulkini, moddiy va madaniy boyliklarini asrashi shart.</div></div><div class="BY_DEFAULT"><div name="-5591702" id="-5591702"></div></div><div class="ACT_TEXT"><div name="-5591706" id="-5591706">Taʼlim oluvchilarning zimmasida qonunchilikka muvofiq boshqa majburiyatlar ham boʻlishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591714" id="-5591714"><em>(</em>48-moddaning ikkinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405590">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5013963" id="-5013963">49-modda. Taʼlim oluvchilarning kiyim-boshiga nisbatan qoʻyiladigan talablar </div></div><div class="BY_DEFAULT"><div name="-7099346" id="-7099346"></div></div><div class="ACT_TEXT"><div name="-7099348" id="-7099348">Taʼlim tashkilotlarida (bundan oʻrta maxsus, professional va oliy taʼlim tashkilotlari mustasno) taʼlim oluvchilarning kiyim-boshiga doir talablar Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099349" id="-7099349">(49-moddaning birinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094280">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7803307" id="-7803307"></div></div><div class="ACT_TEXT"><div name="-7803309" id="-7803309">Qoʻshimcha taʼlim, kadrlar malakasini oshirish va ularni qayta tayyorlash turlari boʻyicha nodavlat taʼlim xizmatlarini koʻrsatuvchi nodavlat taʼlim tashkilotlari taʼlim oluvchilarning kiyim-boshiga doir talablarni mustaqil belgilashga haqli.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803310" id="-7803310">(49-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789639">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-5013965" id="-5013965">Taʼlim oluvchilarning ayrim toifalari Oʻzbekiston Respublikasi Davlat budjeti mablagʻlari hisobidan kiyim-bosh bilan taʼminlanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013966" id="-5013966">50-modda. Taʼlim tashkilotlarida taʼlim oluvchilarni vaqtincha yashash joylari bilan taʼminlash </div></div><div class="ACT_TEXT"><div name="-5013967" id="-5013967">Kunduzgi taʼlim shaklidagi taʼlim tashkilotida taʼlim oluvchilarga, shuningdek sirtqi taʼlim shaklida yakuniy va oraliq attestatsiya davrida vaqtincha yashash joylari, ular mavjud boʻlgan taqdirda beriladi.</div></div><div class="ACT_TEXT"><div name="-5013968" id="-5013968">Vaqtincha yashash joylari taʼlim oluvchilarga taʼlim tashkiloti tomonidan belgilangan tartibga muvofiq beriladi. </div></div><div class="ACT_TEXT"><div name="-5013969" id="-5013969">Vaqtincha yashash joylariga muhtojlar mavjud boʻlgan hollarda, ushbu joylardan boshqa maqsadlarda foydalanishga yoʻl qoʻyilmaydi.</div></div><div class="ACT_TEXT"><div name="-5013970" id="-5013970">Vaqtincha yashash joylaridan foydalanish uchun taʼlim tashkiloti bilan tuzilgan shartnomaga muvofiq haq toʻlanadi.</div></div><div class="ACT_TEXT"><div name="-5013972" id="-5013972">Vaqtincha yashash joyidan foydalanganlik uchun toʻlov miqdori taʼlim tashkiloti tomonidan belgilanadi.</div></div><div class="ACT_TEXT"><div name="-5013978" id="-5013978">Davlat taʼlim muassasalari ayrim turdagi taʼlim oluvchilar uchun vaqtincha yashash joyidan foydalanganlik uchun toʻlov qiymatini kamaytirishga yoki ularni toʻlovdan toʻliq ozod qilishga haqli. Yetim bolalar va ota-ona qaramogʻidan mahrum boʻlgan bolalar, shuningdek oʻqitish davrida yetim boʻlib qolgan bolalar, jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalar (shaxslar) vaqtincha yashash joyidan foydalanganlik uchun haq toʻlashdan ozod qilinadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5013979" id="-5013979">51-modda. Voyaga yetmagan taʼlim oluvchilar ota-onasining hamda boshqa qonuniy vakillarining huquq va majburiyatlari </div></div><div class="ACT_TEXT"><div name="-5013980" id="-5013980">Voyaga yetmagan taʼlim oluvchilarning ota-onasi va boshqa qonuniy vakillari bolaning oʻqishi, tarbiyalanishi, jismoniy, maʼnaviy va intellektual rivojlanishi uchun masʼuldir. </div></div><div class="BY_DEFAULT"><div name="-7983716" id="-7983716"></div></div><div class="ACT_TEXT"><div name="-7983717" id="-7983717">Mahalliy ijro etuvchi hokimiyat organlari, fuqarolarning oʻzini oʻzi boshqarish organlari va taʼlim tashkilotlari voyaga yetmagan taʼlim oluvchilarni tarbiyalashda, ularning jismoniy hamda ruhiy sogʻligʻini muhofaza qilish va mustahkamlashda, shuningdek individual qobiliyatlarini rivojlantirishda ularning ota-onasiga hamda boshqa qonuniy vakillariga koʻmaklashadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7983721" id="-7983721">(51-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2025-yil 30-dekabrdagi OʻRQ-1109-sonli <a href="https://lex.uz/uz/docs/-7962424?ONDATE=30.12.2025 00#-7965329">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 30.12.2025-y., 03/25/1109/1241-son)</div></div><div class="ACT_TEXT"><div name="-5013982" id="-5013982">Voyaga yetmagan taʼlim oluvchilarning ota-onasi va boshqa qonuniy vakillari quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-5013983" id="-5013983">jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalarga, shuningdek uzoq vaqt davolanishga muhtoj boʻlgan bolalarga oilada taʼlim olish imkoniyatini berish;</div></div><div class="ACT_TEXT"><div name="-5013984" id="-5013984">oilada taʼlim olayotgan bolaning fikrini inobatga olgan holda uning oʻqishini taʼlimning har qanday bosqichida taʼlim tashkilotida davom ettirish toʻgʻrisida qaror qabul qilish;</div></div><div class="ACT_TEXT"><div name="-5013985" id="-5013985">taʼlim tashkilotlari bilan hamkorlik qilish, taʼlim-tarbiya jarayonini takomillashtirish, moddiy-texnika bazasini rivojlantirish, taʼlim tashkilotlariga xayriya yordami koʻrsatish boʻyicha takliflar kiritish;</div></div><div class="ACT_TEXT"><div name="-5013988" id="-5013988">taʼlim tashkilotining ustavi va (yoki) boshqa taʼsis hujjati, litsenziyasi, davlat akkreditatsiyasi toʻgʻrisidagi sertifikati, davlat taʼlim standartlari, davlat taʼlim talablari, malaka talablari, oʻquv rejalari va oʻquv dasturlari bilan tanishish;</div></div><div class="ACT_TEXT"><div name="-5013989" id="-5013989">taʼlimning mazmuni, qoʻllanilayotgan taʼlim va tarbiya usullari, taʼlim texnologiyalari bilan, shuningdek oʻz bolalarining oʻquv fanlarini oʻzlashtirishi natijalari bilan tanishish;</div></div><div class="ACT_TEXT"><div name="-5013991" id="-5013991">taʼlim oluvchilarning huquqlari va qonuniy manfaatlarini himoya qilish;</div></div><div class="ACT_TEXT"><div name="-5013994" id="-5013994">taʼlim tashkilotini boshqarishga doir masalalarni muhokama qilishda ishtirok etish.</div></div><div class="BY_DEFAULT"><div name="-5591718" id="-5591718"></div></div><div class="ACT_TEXT"><div name="-5591723" id="-5591723">Voyaga yetmagan taʼlim oluvchilarning ota-onasi va boshqa qonuniy vakillari qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591729" id="-5591729"><em>(</em>51-moddaning toʻrtinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405592">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5013997" id="-5013997">Voyaga yetmagan taʼlim oluvchilarning ota-onasi va boshqa qonuniy vakillari:</div></div><div class="ACT_TEXT"><div name="-5013999" id="-5013999">oʻz bolalarini insonparvarlik, vatanparvarlik, mehnatsevarlik, maʼnaviy, milliy va umuminsoniy qadriyatlarni hurmat qilish ruhida tarbiyalashi;</div></div><div class="ACT_TEXT"><div name="-5014001" id="-5014001">bolalarining umumiy oʻrta, oʻrta maxsus taʼlim yoki boshlangʻich professional taʼlim olishini taʼminlashi;</div></div><div class="ACT_TEXT"><div name="-5014004" id="-5014004">bolalarining oʻquv mashgʻulotlariga qatnashishini taʼminlash va oʻzlashtirishi ustidan nazoratni amalga oshirish; </div></div><div class="ACT_TEXT"><div name="-5014005" id="-5014005">oʻz bolalarining intellektual, maʼnaviy va jismoniy rivojlanishi uchun shart-sharoitlar yaratishi;</div></div><div class="ACT_TEXT"><div name="-5014006" id="-5014006">taʼlim tashkilotining taʼlim-tarbiya jarayonini tartibga soluvchi ichki tartib-qoidalariga rioya etishi; </div></div><div class="ACT_TEXT"><div name="-5014007" id="-5014007">jismoniy va yuridik shaxslar bilan munosabatlarda, shu jumladan sudda maxsus vakolatlarsiz oʻz bolalarining taʼlim sohasidagi huquqlari va qonuniy manfaatlarini himoya qilishi;</div></div><div class="ACT_TEXT"><div name="-5014009" id="-5014009">taʼlim-tarbiya jarayoni ishtirokchilarining shaʼni va qadr-qimmatini hurmat qilishi shart.</div></div><div class="BY_DEFAULT"><div name="-5591732" id="-5591732"></div></div><div class="ACT_TEXT"><div name="-5591733" id="-5591733">Voyaga yetmagan taʼlim oluvchilarning ota-onasi va boshqa qonuniy vakillari zimmasida qonunchilikka muvofiq boshqa majburiyatlar ham boʻlishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591736" id="-5591736"><em>(</em>51-moddaning oltinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405592">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5014011" id="-5014011">7-bob. Taʼlim-tarbiya jarayoni ishtirokchilarini ijtimoiy himoya qilish </div></div><div class="CLAUSE_DEFAULT"><div name="-5014012" id="-5014012">52-modda. Taʼlim oluvchilarni ijtimoiy himoya qilish</div></div><div class="BY_DEFAULT"><div name="-5591739" id="-5591739"></div></div><div class="ACT_TEXT"><div name="-5591742" id="-5591742">Taʼlim tashkilotlarida taʼlim oluvchilar qonunchilikka muvofiq imtiyozlar, stipendiyalar va vaqtincha yashash joylari bilan taʼminlanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591743" id="-5591743"><em>(</em>52-moddaning birinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405595">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5014014" id="-5014014">Toʻlov-shartnoma asosida taʼlim oluvchilarga imtiyozli bank kreditlari berilishi mumkin.</div></div><div class="BY_DEFAULT"><div name="-5591744" id="-5591744"></div></div><div class="ACT_TEXT"><div name="-5591745" id="-5591745">Nodavlat taʼlim tashkilotlari taʼlim oluvchilarni ijtimoiy himoya qilishni qonunchilikka, oʻz ustaviga va (yoki) boshqa taʼsis hujjatiga muvofiq amalga oshiradi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591748" id="-5591748"><em>(</em>52-moddaning uchinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405595">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5014016" id="-5014016">Davlat ijtimoiy himoya qilishni taʼminlash maqsadida kam taʼminlangan oilalardagi bolalar, jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalar (shaxslar) uchun, shuningdek mazkur toifadagi taʼlim oluvchilarning kasbiy oʻsishi uchun shart-sharoitlar yaratadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014017" id="-5014017">53-modda. Taʼlim tashkilotlarining xodimlarini ijtimoiy himoya qilish </div></div><div class="ACT_TEXT"><div name="-5014018" id="-5014018">Taʼlim tashkilotlarining xodimlarini ijtimoiy himoya qilish davlat tomonidan kafolatlanadi. </div></div><div class="ACT_TEXT"><div name="-5014019" id="-5014019">Taʼlim tashkilotlarining pedagog xodimlariga qisqartirilgan ish vaqti davomiyligi belgilanadi, haq toʻlanadigan har yilgi uzaytirilgan taʼtil va boshqa imtiyozlar va kafolatlar taqdim etiladi.</div></div><div class="ACT_TEXT"><div name="-5014020" id="-5014020">Taʼlim tashkilotlarining pedagog va boshqa xodimlariga sanitariya-gigiyenaga oid, epidemiyaga qarshi hamda profilaktika choralari bilan amalga oshiriladigan sogʻliqni saqlash kafolatlanadi.</div></div><div class="ACT_TEXT"><div name="-5014021" id="-5014021">Taʼlim tashkilotlari mehnatga haq toʻlash uchun mavjud boʻlgan mablagʻlar doirasida mustaqil ravishda ish haqiga, lavozim maoshlariga tabaqalashtirilgan ustamalar belgilashga va mehnatga haq toʻlash hamda uni ragʻbatlantirishning turli shakllarini qoʻllashga haqli.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014022" id="-5014022">54-modda. Yetim bolalarni va ota-onasining yoki boshqa qonuniy vakillarining qaramogʻidan mahrum boʻlgan bolalarni oʻqitish va ularning toʻliq taʼminoti </div></div><div class="ACT_TEXT"><div name="-5014023" id="-5014023">Yetim bolalarni va ota-onasining yoki boshqa qonuniy vakillarining qaramogʻidan mahrum boʻlgan bolalarni oʻqitish va ularning toʻliq taʼminoti Oʻzbekiston Respublikasi Davlat budjeti mablagʻlari hisobidan amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014024" id="-5014024">55-modda. Jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalarni (shaxslarni) oʻqitish hamda tarbiyalash </div></div><div class="BY_DEFAULT"><div name="-7803311" id="-7803311"></div></div><div class="ACT_TEXT"><div name="-7803312" id="-7803312">Davlat jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan bolalarning (shaxslarning) davlat ixtisoslashtirilgan taʼlim muassasalarida, umumiy oʻrta, oʻrta maxsus, professional taʼlim muassasalarida inklyuziv shaklda bepul umumiy oʻrta, oʻrta maxsus, professional va qoʻshimcha taʼlim olishini taʼminlaydi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803313" id="-7803313">(55-moddaning birinchi qismi Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789640">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="ACT_TEXT"><div name="-5014026" id="-5014026">Jismoniy, aqliy, sensor (sezgi) yoki ruhiy nuqsonlari boʻlgan, shuningdek uzoq vaqt davolanishga muhtoj boʻlgan bolalarni oʻqitish hamda tarbiyalash uchun davlat ixtisoslashtirilgan taʼlim muassasalari tashkil etiladi. Taʼlim oluvchilarni ushbu taʼlim muassasalariga yuborish va ulardan chetlatish ota-onasining yoki boshqa qonuniy vakillarining roziligi bilan tibbiy-psixologik-pedagogik komissiyaning xulosasiga binoan amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5014028" id="-5014028">Davlat ixtisoslashtirilgan taʼlim muassasalarida taʼlim oluvchilar davlat taʼminotida boʻladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014029" id="-5014029">56-modda. Ijtimoiy reabilitatsiyaga muhtoj boʻlgan bolalarni (shaxslarni) oʻqitish va tarbiyalash </div></div><div class="ACT_TEXT"><div name="-5014030" id="-5014030">Alohida sharoitlarda oʻqitish va tarbiyalanishga muhtoj boʻlgan bolalar (shaxslar) uchun ularning taʼlim olishini, kasbiy tayyorgarligini va ijtimoiy reabilitatsiya qilinishini taʼminlaydigan ixtisoslashtirilgan oʻquv-tarbiya muassasalari tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-5014031" id="-5014031">Ozodlikdan mahrum qilish tarzida jazoni ijro etish muassasalarida saqlanayotgan bolalarning (shaxslarning) taʼlim olishi, tarbiyalanishi va mustaqil taʼlim olishi uchun sharoitlar yaratiladi.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5014032" id="-5014032">8-bob. Nodavlat taʼlim tashkilotlari faoliyatini litsenziyalash, taʼlim tashkilotlarini attestatsiyadan va davlat akkreditatsiyasidan oʻtkazish. Xorijiy davlatda olingan taʼlim toʻgʻrisidagi hujjatni tan olish, taʼlim sohasidagi hujjatlarga apostil qoʻyish </div></div><div class="CLAUSE_DEFAULT"><div name="-5014033" id="-5014033">57-modda. Nodavlat taʼlim tashkilotlarining faoliyatini litsenziyalash </div></div><div class="BY_DEFAULT"><div name="-5685125" id="-5685125"></div></div><div class="ACT_TEXT"><div name="-5685126" id="-5685126">Nodavlat taʼlim tashkilotlarining faoliyatini litsenziyalash “Litsenziyalash, ruxsat berish va xabardor qilish tartib-taomillari toʻgʻrisida”gi Oʻzbekiston Respublikasi <a href="https://lex.uz/uz/docs/-5511879">Qonuni</a> bilan tartibga solinadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5685127" id="-5685127">(57-moddaning birinchi qismi Oʻzbekiston Respublikasining 2021-yil 12-oktabrdagi OʻRQ-721-sonli <a href="https://lex.uz/uz/docs/-5674701?ONDATE=12.10.2021 00#-5675938">Qonuni</a> tahririda — Qonunchilik maʼlumotlari milliy bazasi, 12.10.2021-y., 03/21/721/0952-son)</div></div><div class="BY_DEFAULT"><div name="-7099357" id="-7099357"></div></div><div class="ACT_TEXT"><div name="-7099360" id="-7099360">Nodavlat taʼlim tashkilotlariga litsenziya berish va qayta rasmiylashtirish, litsenziyaning amal qilishini toʻxtatib turish, shuningdek litsenziyani bekor qilish yoki uni bekor qilish toʻgʻrisidagi ariza bilan sudga murojaat qilish qonunchilikda belgilangan tartibda Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi hamda Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi tomonidan amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099365" id="-7099365">(57-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094283">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-5685131" id="-5685131"></div></div><div class="ACT_TEXT"><div name="-5685132" id="-5685132">Litsenziyalar nomuayyan muddatga, taʼlimning quyidagi turlari uchun alohida beriladi:</div></div><div class="ACT_TEXT"><div name="-5685133" id="-5685133">maktabgacha taʼlim va tarbiya (bundan oilaviy maktabgacha taʼlim mustasno);</div></div><div class="ACT_TEXT"><div name="-5685134" id="-5685134">umumiy oʻrta va oʻrta maxsus taʼlim;</div></div><div class="ACT_TEXT"><div name="-5685135" id="-5685135">professional taʼlim;</div></div><div class="ACT_TEXT"><div name="-5685136" id="-5685136">oliy taʼlim;</div></div><div class="ACT_TEXT"><div name="-5685137" id="-5685137">oliy taʼlimdan keyingi taʼlim.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5685138" id="-5685138">(57-moddaning uchinchi qismi Oʻzbekiston Respublikasining 2021-yil 12-oktabrdagi OʻRQ-721-sonli <a href="https://lex.uz/uz/docs/-5674701?ONDATE=12.10.2021 00#-5675939">Qonuni</a> tahririda — Qonunchilik maʼlumotlari milliy bazasi, 12.10.2021-y., 03/21/721/0952-son)</div></div><div class="BY_DEFAULT"><div name="-7099380" id="-7099380"></div></div><div class="CLAUSE_DEFAULT"><div name="-7099383" id="-7099383">57<sup>1</sup>-modda. Nodavlat taʼlim faoliyatini xabardor qilish tartibida amalga oshirish</div></div><div class="BY_DEFAULT"><div name="-7803315" id="-7803315"></div></div><div class="ACT_TEXT"><div name="-7803316" id="-7803316">Bolalar uchun qoʻshimcha taʼlim, oilaviy nodavlat maktabgacha taʼlim tashkiloti shaklida taʼlim xizmatlarini koʻrsatishga doir faoliyat Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligini, katta yoshdagilar uchun qoʻshimcha taʼlim, kadrlarni qayta tayyorlash va ularning malakasini oshirish shaklidagi faoliyat esa Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligini belgilangan tartibda xabardor qilish orqali amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7803317" id="-7803317">(57<sup>1</sup>-moddaning matni Oʻzbekiston Respublikasining 2025-yil 23-oktabrdagi OʻRQ-1091-sonli <a href="https://lex.uz/uz/docs/-7788351?ONDATE=24.10.2025 00#-7789641">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 24.10.2025-y., 03/25/1091/0969-son)</div></div><div class="BY_DEFAULT"><div name="-7099398" id="-7099398"></div></div><div class="CLAUSE_DEFAULT"><div name="-7099399" id="-7099399">58-modda. Taʼlim tashkilotlarini attestatsiyadan va davlat akkreditatsiyasidan, shuningdek kompleks va maxsus davlat akkreditatsiyasidan oʻtkazish</div></div><div class="ACT_TEXT"><div name="-7099400" id="-7099400">Oʻzbekiston Respublikasi hududida faoliyat koʻrsatayotgan maktabgacha, umumiy oʻrta taʼlim tashkilotlari davlat taʼlim standartlariga, davlat taʼlim talablariga hamda oʻquv dasturlariga muvofiqlik jihatidan attestatsiyadan va davlat akkreditatsiyasidan oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-7099401" id="-7099401">Oʻrta maxsus, professional, oliy taʼlimni va oliy taʼlimdan keyingi taʼlimni amalga oshiruvchi davlat va nodavlat taʼlim tashkilotlari, bitiruvchilarga davlat tomonidan tasdiqlangan namunadagi taʼlim toʻgʻrisidagi hujjatlarni beruvchi, kadrlar malakasini oshirish va ularni qayta tayyorlash boʻyicha davlat va nodavlat taʼlim tashkilotlari davlat taʼlim standartlariga, davlat taʼlim talablariga, shuningdek taʼlim dasturlariga muvofiqlik jihatidan kompleks va maxsus davlat akkreditatsiyasidan oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-7099403" id="-7099403">Attestatsiya va kompleks davlat akkreditatsiyasi ikki bosqichda — taʼlim tashkilotlari faoliyatini ichki baholash va tashqi baholash bosqichlarida oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-7099404" id="-7099404">Ichki baholash taʼlim tashkilotining oʻzini oʻzi baholashidir.</div></div><div class="ACT_TEXT"><div name="-7099405" id="-7099405">Tashqi baholash ichki baholash oʻtkazilganidan keyin taʼlim sohasidagi tegishli vakolatli respublika ijro etuvchi hokimiyat organlari yoki respublikada tan olingan xalqaro akkreditatsiya tashkilotlari tomonidan amalga oshiriladigan baholashdir.</div></div><div class="BY_DEFAULT"><div name="-7983725" id="-7983725"></div></div><div class="ACT_TEXT"><div name="-7983726" id="-7983726">Oʻzbekiston Respublikasi Prezidentining yoki Oʻzbekiston Respublikasi Vazirlar Mahkamasining qarorlari asosida tashkil etilgan, shuningdek vazirliklar, idoralar va mahalliy davlat hokimiyati vakillik organlari tomonidan tashkil etilgan taʼlim tashkilotlari tashkil etilgan kundan eʼtiboran belgilangan muddatga akkreditatsiya qilingan hisoblanadi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7983753" id="-7983753">(58-moddaning oltinchi qismi Oʻzbekiston Respublikasining 2025-yil 30-dekabrdagi OʻRQ-1109-sonli <a href="https://lex.uz/uz/docs/-7962424?ONDATE=30.12.2025 00#-7965330">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 30.12.2025-y., 03/25/1109/1241-son)</div></div><div class="ACT_TEXT"><div name="-7099407" id="-7099407">Maktabgacha, umumiy oʻrta taʼlimni amalga oshiruvchi nodavlat taʼlim tashkilotlari tegishli litsenziya olingan kundan eʼtiboran Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilangan muddat davomida akkreditatsiyadan oʻtgan deb hisoblanadi, bu muddat tugagach, ushbu Qonunda belgilangan tartibda attestatsiyadan va davlat akkreditatsiyasidan oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-7099408" id="-7099408">Taʼlim tashkilotlarini davlat akkreditatsiyasidan, shuningdek kompleks va maxsus davlat akkreditatsiyasidan oʻtkazish maqsadida taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari huzurida doimiy faoliyat koʻrsatuvchi davlat akkreditatsiya komissiyalari tuziladi.</div></div><div class="ACT_TEXT"><div name="-7099409" id="-7099409">Taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organlari respublikada tan olinadigan xalqaro akkreditatsiya tashkilotlariga qoʻyiladigan talablarni belgilaydi va ularning reyestrlarini yuritadi.</div></div><div class="ACT_TEXT"><div name="-7099410" id="-7099410">Davlat akkreditatsiyasi taʼlim tashkilotining attestatsiyasi asosida, kompleks va maxsus davlat akkreditatsiyalari esa tashqi baholash asosida amalga oshiriladi. Doimiy faoliyat koʻrsatuvchi davlat akkreditatsiya komissiyasi taʼlim tashkilotining maqomini va uning faoliyati davlat taʼlim standartlariga, davlat taʼlim talablariga va oʻquv dasturlariga muvofiqligini aniqlaydi.</div></div><div class="ACT_TEXT"><div name="-7099411" id="-7099411">Taʼlim tashkilotining davlat akkreditatsiyasi, shuningdek kompleks va maxsus davlat akkreditatsiyasi toʻgʻrisida ijobiy qaror qabul qilingan taqdirda, unga davlat akkreditatsiyasi, shuningdek kompleks va maxsus akkreditatsiyalarning amal qilish muddati koʻrsatilgan holda belgilangan namunadagi sertifikat beriladi.</div></div><div class="ACT_TEXT"><div name="-7099413" id="-7099413">Taʼlim tashkiloti qayta tashkil etilgan yoki tugatilgan hollarda davlat akkreditatsiyasi, shuningdek kompleks va maxsus davlat akkreditatsiyasi toʻgʻrisidagi sertifikatning amal qilishi taʼlim sohasidagi vakolatli respublika ijro etuvchi hokimiyat organining qarori bilan tugatiladi.</div></div><div class="ACT_TEXT"><div name="-7099414" id="-7099414">Taʼlim toʻgʻrisidagi qonunchilik talablari yoki sertifikatda koʻrsatilgan shartlar buzilganligi aniqlangan va aniqlangan qoidabuzarliklar taʼlim tashkiloti tomonidan bartaraf etilmagan hollarda taʼlim sohasidagi tegishli vakolatli respublika ijro etuvchi hokimiyat organi tomonidan davlat akkreditatsiyasi, kompleks va maxsus davlat akkreditatsiya toʻgʻrisidagi sertifikatning amal qilishini bekor qilish haqida qaror qabul qiladi.</div></div><div class="ACT_TEXT"><div name="-7099415" id="-7099415">Davlat akkreditatsiyasidan, shuningdek kompleks va maxsus davlat akkreditatsiyasidan oʻtgan taʼlim tashkilotlari Taʼlim tashkilotlarining reyestrlariga kiritiladi va bu haqdagi maʼlumotlar taʼlim sohasidagi tegishli vakolatli respublika ijro etuvchi hokimiyat organlarining rasmiy veb-saytlariga joylashtiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099419" id="-7099419">(58-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094285">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="BY_DEFAULT"><div name="-7099420" id="-7099420"></div></div><div class="CLAUSE_DEFAULT"><div name="-7099421" id="-7099421"><strong>59-modda. </strong>Taʼlim tashkilotlarining faoliyatini ichki va tashqi baholashdan oʻtkazish</div></div><div class="ACT_TEXT"><div name="-7099422" id="-7099422">Taʼlim tashkilotlarining faoliyati tashqi baholashdan oʻtkazilishidan oldin ular taʼlim sohasidagi tegishli vakolatli respublika ijro etuvchi hokimiyat organi tomonidan ishlab chiqilgan attestatsiya mezonlari va koʻrsatkichlari asosida oʻz faoliyatini mustaqil ravishda ichki baholashdan oʻtkazadi.</div></div><div class="ACT_TEXT"><div name="-7099423" id="-7099423">Taʼlim tashkilotlari oʻz faoliyati tashqi baholashdan oʻtkazilishidan ikki oy oldin ichki baholash natijalarini taʼlim sohasidagi tegishli vakolatli respublika ijro etuvchi hokimiyat organiga taqdim etadi.</div></div><div class="ACT_TEXT"><div name="-7099424" id="-7099424">Taʼlim sohasidagi tegishli vakolatli respublika ijro etuvchi hokimiyat organi taʼlim tashkilotining faoliyatini ichki baholash yakunlarini oʻrganadi va ulardan taʼlim tashkilotining faoliyatini tashqi baholash jarayonida foydalanadi.</div></div><div class="ACT_TEXT"><div name="-7099426" id="-7099426">Taʼlim tashkiloti rahbari ichki baholash natijalarining ishonchliligi uchun javobgar boʻladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099427" id="-7099427">(59-modda Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094285">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5014066" id="-5014066">60-modda. Xorijiy davlatda olingan taʼlim toʻgʻrisidagi hujjatni tan olish </div></div><div class="ACT_TEXT"><div name="-5014067" id="-5014067">Xorijiy davlatda 1992-yil 1-yanvardan keyin olingan taʼlim toʻgʻrisidagi hujjat tan olish jarayonidan oʻtkazilganidan keyin Oʻzbekiston Respublikasining butun hududida qonuniy kuchga ega hujjat sifatida tan olinadi.</div></div><div class="BY_DEFAULT"><div name="-7099435" id="-7099435"></div></div><div class="ACT_TEXT"><div name="-7099438" id="-7099438">Xorijiy davlatda olingan taʼlim toʻgʻrisidagi hujjatni tan olish tegishli vakolatli respublika ijro etuvchi hokimiyat organi tomonidan amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099441" id="-7099441">(60-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094335">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="ACT_TEXT"><div name="-5014069" id="-5014069">Xorijiy davlatda olingan taʼlim toʻgʻrisidagi hujjatni tan olish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014070" id="-5014070">61-modda. Taʼlim sohasidagi rasmiy hujjatlarga apostil qoʻyish </div></div><div class="ACT_TEXT"><div name="-5014071" id="-5014071">Taʼlim sohasidagi rasmiy hujjatlarga apostil hujjatni tasdiqlagan shaxs imzosining haqiqiyligini, shuningdek muhr yoki shtampning bosma izi haqiqiysiga muvofiqligini tasdiqlash maqsadida qoʻyiladi.</div></div><div class="ACT_TEXT"><div name="-5014072" id="-5014072">Apostilga qoʻyilgan imzo, muhr yoki shtamp qoʻshimcha ravishda tasdiqlashni talab etmaydi.</div></div><div class="BY_DEFAULT"><div name="-7099443" id="-7099443"></div></div><div class="ACT_TEXT"><div name="-7099444" id="-7099444">Taʼlim tashkilotlari tomonidan berilgan rasmiy hujjatlarga apostil qoʻyish tegishli vakolatli respublika ijro etuvchi hokimiyat organi tomonidan amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099447" id="-7099447">(61-moddaning uchinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094343">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5014074" id="-5014074">9-bob. Taʼlimni moliyalashtirish va davlat tomonidan qoʻllab-quvvatlash </div></div><div class="CLAUSE_DEFAULT"><div name="-5014075" id="-5014075">62-modda. Taʼlim tashkilotlarini moliyalashtirish</div></div><div class="BY_DEFAULT"><div name="-5591789" id="-5591789"></div></div><div class="ACT_TEXT"><div name="-5591792" id="-5591792">Davlat taʼlim muassasalarini moliyalashtirish Oʻzbekiston Respublikasining respublika budjetidan, Qoraqalpogʻiston Respublikasi budjetidan, viloyatlar va Toshkent shahar mahalliy budjetlaridan, tumanlar va shaharlar budjetlaridan, kadrlar buyurtmachilarining mablagʻlari hisobidan, shuningdek budjetdan tashqari mablagʻlar hamda qonunchilikda taqiqlanmagan boshqa manbalar hisobidan amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-5591795" id="-5591795">Nodavlat taʼlim tashkilotlarini moliyalashtirish muassislarning, kadrlar buyurtmachilarining pul va moddiy mablagʻlari hamda qonunchilikda taqiqlanmagan boshqa manbalar hisobidan amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591798" id="-5591798"><em>(</em>62-moddaning birinchi va ikkinchi qismlari <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405599">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5014080" id="-5014080">Davlat taʼlim muassasalari ustavida belgilangan vazifalarga muvofiq pulli taʼlim xizmatlari va boshqa xizmatlar koʻrsatish, shuningdek tadbirkorlik faoliyati bilan shugʻullanish huquqiga ega.</div></div><div class="ACT_TEXT"><div name="-5014081" id="-5014081">Pulli taʼlim xizmatlarini koʻrsatish davlat taʼlim muassasalarining asosiy faoliyatiga toʻsqinlik qilmasligi kerak.</div></div><div class="ACT_TEXT"><div name="-5014082" id="-5014082">Davlat taʼlim muassasalarida qoʻshimcha taʼlim xizmatlari koʻrsatganlik uchun haq undirish tartibi ular tomonidan mustaqil ravishda belgilanadi.</div></div><div class="ACT_TEXT"><div name="-5014083" id="-5014083">Davlat taʼlim muassasalari pulli taʼlim xizmatlari va boshqa xizmatlar koʻrsatish hamda tadbirkorlik faoliyati bilan shugʻullanish hisobidan olingan pul mablagʻlarini mustaqil ravishda tasarruf etishga haqli. </div></div><div class="ACT_TEXT"><div name="-5014084" id="-5014084">Taʼlim tashkilotlarini moliyalashtirishning qoʻshimcha manbalari quyidagilardan iborat: </div></div><div class="ACT_TEXT"><div name="-5014085" id="-5014085">shartnomalar asosida, shu jumladan chet ellik jismoniy yoki yuridik shaxslar bilan tuzilgan shartnomalar asosida kadrlarni tayyorlash, qayta tayyorlash va ularning malakasini oshirish hisobidan tushgan mablagʻlar;</div></div><div class="ACT_TEXT"><div name="-5014086" id="-5014086">jismoniy va yuridik shaxslarning buyurtmalari asosida ilmiy-tadqiqot, oʻquv-uslubiy va qonunda taqiqlanmagan boshqa ishlarni bajarish hisobidan tushgan mablagʻlar;</div></div><div class="ACT_TEXT"><div name="-5014087" id="-5014087">taʼlim tashkilotlari tomonidan ishlab chiqilgan mahsulotni, bajarilgan ishlarni va koʻrsatilgan xizmatlarni realizatsiya qilishdan olingan daromadlar;</div></div><div class="ACT_TEXT"><div name="-5014088" id="-5014088">binolar, inshootlar va asbob-uskunalarni ijaraga berish hisobidan tushgan mablagʻlar;</div></div><div class="ACT_TEXT"><div name="-5014089" id="-5014089">taʼlim tashkilotlarining boʻsh turgan pul mablagʻlarini bank muassasalariga depozitlarga joylashtirish hisobidan olingan pul mablagʻlari (foizlar);</div></div><div class="ACT_TEXT"><div name="-5014091" id="-5014091">davlat va xoʻjalik boshqaruvi organlari, shuningdek mahalliy davlat hokimiyati organlari tomonidan ajratiladigan mablagʻlar;</div></div><div class="ACT_TEXT"><div name="-5014092" id="-5014092">bank kreditlari va ssudalari;</div></div><div class="ACT_TEXT"><div name="-5014094" id="-5014094">jismoniy va yuridik shaxslarning xayriya mablagʻlari.</div></div><div class="BY_DEFAULT"><div name="-7099452" id="-7099452"></div></div><div class="ACT_TEXT"><div name="-7099457" id="-7099457">Maktabgacha, umumiy oʻrta, oʻrta maxsus taʼlimda va boshlangʻich professional taʼlimda ajratiladigan mablagʻlar summalari Oʻzbekiston Respublikasi Iqtisodiyot va moliya vazirligi tomonidan belgilanadi hamda ushbu mablagʻlar tarbiyalanuvchilar va taʼlim oluvchilarning oʻqish joyidagi taʼlim tashkilotlariga yoʻnaltiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7099459" id="-7099459">(62-moddaning sakkizinchi qismi Oʻzbekiston Respublikasining 2024-yil 7-sentabrdagi OʻRQ-957-sonli <a href="https://lex.uz/uz/docs/-7093724?ONDATE=09.09.2024 01#-7094346">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 09.09.2024-y., 03/24/957/0689-son)</div></div><div class="CLAUSE_DEFAULT"><div name="-5014098" id="-5014098">63-modda. Taʼlimni rivojlantirish jamgʻarmalari</div></div><div class="BY_DEFAULT"><div name="-5591800" id="-5591800"></div></div><div class="ACT_TEXT"><div name="-5591801" id="-5591801">Taʼlimni rivojlantirish jamgʻarmalari qonunchilikda belgilangan tartibda davlat muassasalari hamda tashkilotlarining, yuridik va jismoniy shaxslarning, shu jumladan chet ellik yuridik va jismoniy shaxslarning badallari hamda ajratmalari, shuningdek qonunchilikda taqiqlanmagan boshqa manbalar hisobidan tashkil etilishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591804" id="-5591804"><em>(</em>63-moddaning matni <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405601">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5014102" id="-5014102">64-modda. Taʼlim sohasidagi davlat-xususiy sheriklik</div></div><div class="ACT_TEXT"><div name="-5014104" id="-5014104">Taʼlim sohasidagi davlat-xususiy sheriklik davlat va xususiy sheriklarning muayyan muddatga yuridik jihatdan rasmiylashtirilgan, davlat-xususiy sheriklik loyihasini amalga oshirish uchun oʻz resurslarini birlashtirishiga asoslangan hamkorlikdir. </div></div><div class="ACT_TEXT"><div name="-5014105" id="-5014105">Nodavlat taʼlim tashkilotlari taʼlim sohasidagi davlat-xususiy sheriklik asosida tashkil etilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-5014107" id="-5014107">Taʼlim sohasidagi davlat-xususiy sheriklik “Davlat-xususiy sheriklik toʻgʻrisida”gi Oʻzbekiston Respublikasi<a href="https://lex.uz/uz/docs/-4329270"> Qonuni </a>prinsiplari, normalari va qoidalariga muvofiq amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014108" id="-5014108">65-modda. Taʼlim sohasiga investitsiyalarni jalb etish</div></div><div class="ACT_TEXT"><div name="-5014109" id="-5014109">Davlat taʼlim sohasini, taʼlim tashkilotlari faoliyatini rivojlantirishga, shuningdek investorlarning, shu jumladan chet ellik investorlarning ushbu sohadagi huquqlari va qonuniy manfaatlarini himoya qilishga qaratilgan investitsiyalarni jalb etish uchun qulay ijtimoiy-iqtisodiy, tashkiliy-huquqiy sharoitlar yaratilishini taʼminlaydi.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014111" id="-5014111">66-modda. Taʼlim tashkilotlarining mol-mulki</div></div><div class="BY_DEFAULT"><div name="-7373935" id="-7373935"></div></div><div class="ACT_TEXT"><div name="-7373941" id="-7373941">Taʼlim tashkilotlari oʻz mulkiga, operativ boshqaruvidagi mulkka ega boʻlishi kerak.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7373948" id="-7373948">(66-moddaning birinchi qismi Oʻzbekiston Respublikasining 2025-yil 7-fevraldagi OʻRQ-1025-sonli <a href="https://lex.uz/uz/docs/-7367697?ONDATE=08.05.2025 00#-7368286">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 07.02.2025-y., 03/25/1025/0116-son. Kuchga kirish sanasi — 2025-yil 8-may)</div></div><div class="BY_DEFAULT"><div name="-7373954" id="-7373954"></div></div><div class="ACT_TEXT"><div name="-7373962" id="-7373962">Davlat taʼlim muassasalarining operativ boshqaruvida boʻlgan obyektlarning (binolar, inshootlar, qurilayotgan binolar va inshootlarning, oʻquv, ishlab chiqarish va ijtimoiy infratuzilmalarning, taʼlim oluvchilar vaqtincha turar joy binolarining, klinik bazalar va boshqa koʻchmas mulk obyektlarining, shu jumladan taʼlim kampuslariga kiradigan mulk obyektlarining) xususiylashtirilishiga yoʻl qoʻyilmaydi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7373964" id="-7373964">(66-moddaning ikkinchi qismi Oʻzbekiston Respublikasining 2025-yil 7-fevraldagi OʻRQ-1025-sonli <a href="https://lex.uz/uz/docs/-7367697?ONDATE=08.05.2025 00#-7368286">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 07.02.2025-y., 03/25/1025/0116-son. Kuchga kirish sanasi — 2025-yil 8-may)</div></div><div class="ACT_TEXT"><div name="-5014114" id="-5014114">Taʼlim tashkilotlari qayta tashkil etilgan hollarda ularning mol-mulki yangi tashkil etilgan taʼlim tashkilotiga huquqiy vorislik asosida oʻtkaziladi.</div></div><div class="BY_DEFAULT"><div name="-5591805" id="-5591805"></div></div><div class="ACT_TEXT"><div name="-5591808" id="-5591808">Taʼlim tashkilotlari tugatilganda ularga tegishli mol-mulk kreditorlarning talablari qanoatlantirilgandan soʻng, agar qonunchilikda boshqacha qoida nazarda tutilmagan boʻlsa, muassislarga (ishtirokchilarga) qaytariladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591815" id="-5591815"><em>(</em>66-moddaning toʻrtinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405602">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5014116" id="-5014116">10-bob. Taʼlim sohasidagi xalqaro hamkorlik</div></div><div class="CLAUSE_DEFAULT"><div name="-5014117" id="-5014117">67-modda. Taʼlim tashkilotlarining xalqaro hamkorligi</div></div><div class="ACT_TEXT"><div name="-5014118" id="-5014118">Taʼlim tashkilotlari quyidagilar vositasida tegishli xorijiy mamlakatlarning taʼlim muassasalari va tashkilotlari bilan xalqaro hamkorlikni amalga oshiradi:</div></div><div class="ACT_TEXT"><div name="-5014120" id="-5014120">taʼlim muammolari yuzasidan ilmiy-texnik hamkorlikni rivojlantirish;</div></div><div class="ACT_TEXT"><div name="-5014122" id="-5014122">qoʻshma fakultetlar, oʻquv markazlari va ilmiy laboratoriyalar tashkil etish;</div></div><div class="ACT_TEXT"><div name="-5014123" id="-5014123">xalqaro darajadagi birgalikdagi taʼlim hamda ilmiy-tadqiqot loyihalari va dasturlarini tayyorlash;</div></div><div class="ACT_TEXT"><div name="-5014125" id="-5014125">hamkorlikda fundamental hamda amaliy ilmiy-tadqiqot loyihalarini amalga oshirish;</div></div><div class="ACT_TEXT"><div name="-5014126" id="-5014126">ilmiy-amaliy seminarlar, konferensiyalar va simpoziumlar oʻtkazish;</div></div><div class="ACT_TEXT"><div name="-5014128" id="-5014128">talabalar, magistrlar, doktorantlar, oʻqituvchilar va ilmiy xodimlar almashinishini amalga oshirish;</div></div><div class="ACT_TEXT"><div name="-5014129" id="-5014129">ikki tomonlama diplomlar (Double Diploma) dasturlarini joriy etish; </div></div><div class="BY_DEFAULT"><div name="-5591820" id="-5591820"></div></div><div class="ACT_TEXT"><div name="-5591821" id="-5591821">qonunchilikka muvofiq boshqa tadbirlar.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591828" id="-5591828"><em>(</em>67-modda birinchi qismining toʻqqizinchi xatboshisi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405604">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="BY_DEFAULT"><div name="-5591830" id="-5591830"></div></div><div class="ACT_TEXT"><div name="-5591834" id="-5591834">Taʼlim tashkilotlari qonunchilikka muvofiq xorijiy davlatlarning taʼlim muassasalari va tashkilotlari bilan hamkorlikda kadrlar tayyorlashni amalga oshirishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591843" id="-5591843"><em>(</em>67-moddaning ikkinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405604">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5014132" id="-5014132">68-modda. Taʼlim sohasidagi xalqaro hamkorlik</div></div><div class="BY_DEFAULT"><div name="-5591846" id="-5591846"></div></div><div class="ACT_TEXT"><div name="-5591848" id="-5591848">Taʼlim sohasidagi xalqaro hamkorlik Oʻzbekiston Respublikasining xalqaro shartnomalari va qonunchilikka muvofiq amalga oshiriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591851" id="-5591851"><em>(</em>68-moddaning birinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405607">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5014137" id="-5014137">Taʼlim sohasidagi vakolatli davlat boshqaruvi organlari:</div></div><div class="ACT_TEXT"><div name="-5014139" id="-5014139">xorijiy davlatlarning tegishli vakolatli organlari, taʼlim muassasalari bilan hamkorlik qiladi;</div></div><div class="ACT_TEXT"><div name="-5014141" id="-5014141">Oʻzbekiston Respublikasida doimiy yashovchi fuqarolarni xorijiy davlatlarning taʼlim muassasalariga oʻqish uchun yuboradi;</div></div><div class="ACT_TEXT"><div name="-5014143" id="-5014143">pedagog xodimlar va taʼlim oluvchilar almashinuvini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-5014145" id="-5014145">rahbar hamda pedagog xodimlarning xorijiy davlatlarda tayyorlash, qayta tayyorlash va malakasini oshirishni tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-5014147" id="-5014147">oʻz xodimlari hamda mutaxassislarini xalqaro konferensiyalarga va stajirovkalarga yuborish, ularning xalqaro loyihalar hamda ilmiy tadqiqotlarda ishtirok etishini qoʻllab-quvvatlaydi. </div></div><div class="BY_DEFAULT"><div name="-5591853" id="-5591853"></div></div><div class="ACT_TEXT"><div name="-5591856" id="-5591856">Taʼlim sohasidagi vakolatli davlat boshqaruvi organlari qonunchilikka muvofiq taʼlim sohasidagi xalqaro hamkorlikni rivojlantirish boʻyicha boshqa tadbirlarni ham amalga oshirishi mumkin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591864" id="-5591864"><em>(</em>68-moddaning uchinchi qismi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405607">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5014152" id="-5014152">69-modda. Xorijda taʼlim olish</div></div><div class="ACT_TEXT"><div name="-5014154" id="-5014154">Oʻzbekiston Respublikasida doimiy yashovchi fuqarolar Oʻzbekiston Respublikasining xalqaro shartnomalariga muvofiq yoki yakka tartibda xorijda taʼlim olish huquqiga ega.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-5014156" id="-5014156">11-bob. Yakunlovchi qoidalar</div></div><div class="CLAUSE_DEFAULT"><div name="-5014158" id="-5014158">70-modda. Nizolarni hal etish</div></div><div class="BY_DEFAULT"><div name="-5591882" id="-5591882"></div></div><div class="ACT_TEXT"><div name="-5591883" id="-5591883">Taʼlim sohasidagi nizolar qonunchilikda belgilangan tartibda hal etiladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591884" id="-5591884"><em>(</em>70-moddaning matni <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405609">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="BY_DEFAULT"><div name="-5591888" id="-5591888"></div></div><div class="CLAUSE_DEFAULT"><div name="-5591889" id="-5591889">71-modda. Taʼlim toʻgʻrisidagi qonunchilikni buzganlik uchun javobgarlik</div></div><div class="ACT_TEXT"><div name="-5591891" id="-5591891">Taʼlim toʻgʻrisidagi qonunchilikni buzganlikda aybdor shaxslar belgilangan tartibda javobgar boʻladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591895" id="-5591895"><em>(</em>71-modda <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405610">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="CLAUSE_DEFAULT"><div name="-5014168" id="-5014168">72-modda. Oʻzbekiston Respublikasining ayrim qonun hujjatlarini oʻz kuchini yoʻqotgan deb topish </div></div><div class="ACT_TEXT"><div name="-5014169" id="-5014169">Quyidagilar oʻz kuchini yoʻqotgan deb hisoblansin:</div></div><div class="ACT_TEXT"><div name="-5014172" id="-5014172">1) Oʻzbekiston Respublikasining 1997-yil 29-avgustda qabul qilingan “Kadrlar tayyorlash milliy dasturi toʻgʻrisida”gi 463-I-sonli<a href="https://lex.uz/uz/docs/-196944"> Qonuni </a>(Oʻzbekiston Respublikasi Oliy Majlisining Axborotnomasi, 1997-yil, № 11-12, 295-modda); </div></div><div class="ACT_TEXT"><div name="-5014174" id="-5014174">2) Oʻzbekiston Respublikasining 1997-yil 29-avgustda qabul qilingan “Taʼlim toʻgʻrisida”gi 464-I-sonli <a href="https://lex.uz/uz/docs/-16188">Qonuni</a> (Oʻzbekiston Respublikasi Oliy Majlisining Axborotnomasi, 1997-yil, № 9, 225-modda); </div></div><div class="ACT_TEXT"><div name="-5014175" id="-5014175">3) Oʻzbekiston Respublikasi Oliy Majlisining 1997-yil 29-avgustdagi 465-I-sonli “Oʻzbekiston Respublikasining “Taʼlim toʻgʻrisida”gi Qonuni kuchga kirish tartibi toʻgʻrisida”gi <a href="https://lex.uz/uz/docs/-48328">Qarori</a> (Oʻzbekiston Respublikasi Oliy Majlisining Axborotnomasi, 1997-yil, № 9, 226-modda); </div></div><div class="ACT_TEXT"><div name="-5014177" id="-5014177">4) Oʻzbekiston Respublikasining 2007-yil 9-aprelda qabul qilingan “Kadrlar tayyorlash milliy dasturiga oʻzgartish kiritish toʻgʻrisida”gi OʻRQ-87-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2007-yil, № 4, 160-modda) <a href="https://lex.uz/uz/docs/-1164442?ONDATE=10.04.2007 00#-1164546">1-moddasi</a>; </div></div><div class="ACT_TEXT"><div name="-5014179" id="-5014179">5) Oʻzbekiston Respublikasining 2013-yil 7-oktabrda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish, shuningdek ayrim qonun hujjatlarini oʻz kuchini yoʻqotgan deb topish toʻgʻrisida”gi OʻRQ-355-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2013-yil, № 10, 263-modda) <a href="https://lex.uz/uz/docs/-2248652?ONDATE=08.10.2013 00#-2250001">15 </a>va <a href="https://lex.uz/uz/docs/-2248652?ONDATE=08.10.2013 00#-2250005">16-moddalari</a>; </div></div><div class="ACT_TEXT"><div name="-5014180" id="-5014180">6) Oʻzbekiston Respublikasining 2018-yil 3-yanvarda qabul qilingan “Ayrim davlat organlari faoliyati takomillashtirilishi, shuningdek fuqarolarning huquqlari va erkinliklarini himoya qilish kafolatlarini taʼminlashga doir qoʻshimcha chora-tadbirlar qabul qilinishi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-456-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2018-yil, № 1, 1-modda) <a href="https://lex.uz/uz/docs/-3486595?ONDATE=05.01.2018 02#-3487571">14 </a>va <a href="https://lex.uz/uz/docs/-3486595?ONDATE=05.01.2018 02#-3487574">15-moddalari</a>; </div></div><div class="ACT_TEXT"><div name="-5014182" id="-5014182">7) Oʻzbekiston Respublikasining 2018-yil 18-aprelda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-476-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2018-yil, № 4, 224-modda) <a href="https://lex.uz/uz/docs/-3689258?ONDATE=19.04.2018 00#-3692528">26-moddasi</a>.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014185" id="-5014185">73-modda. Ushbu Qonunning ijrosini, yetkazilishini, mohiyati va ahamiyati tushuntirilishini taʼminlash </div></div><div class="BY_DEFAULT"><div name="-6685782" id="-6685782"></div></div><div class="ACT_TEXT"><div name="-6685784" id="-6685784">Oʻzbekiston Respublikasi Adliya vazirligi, Oʻzbekiston Respublikasi Oliy va oʻrta maxsus taʼlim vazirligi, Oʻzbekiston Respublikasi Xalq taʼlimi vazirligi, Oʻzbekiston Respublikasi Maktabgacha taʼlim vazirligi hamda boshqa manfaatdor vazirliklar, idoralar va tashkilotlar ushbu Qonunning ijrosini, ijrochilarga yetkazilishini hamda mohiyati va ahamiyati aholi oʻrtasida tushuntirilishini taʼminlasin.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-6685787" id="-6685787">(73-moddaning matni Oʻzbekiston Respublikasining 2023-yil 28-noyabrdagi OʻRQ-880-sonli <a href="https://lex.uz/uz/docs/-6678807?ONDATE=29.11.2023 01#-6679927">Qonuni </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 29.11.2023-y., 03/23/880/0905-son)</div></div><div class="BY_DEFAULT"><div name="-5014189" id="-5014189"></div></div><div class="BY_DEFAULT"><div name="-5591899" id="-5591899"></div></div><div class="CLAUSE_DEFAULT"><div name="-5591900" id="-5591900">74-modda. Qonunchilikni ushbu Qonunga muvofiqlashtirish</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-5591903" id="-5591903"><em>(</em>74-moddaning nomi <em>Oʻzbekiston Respublikasining 2021-yil 21-apreldagi OʻRQ-683-sonli </em><a href="https://lex.uz/uz/docs/-5388561?ONDATE=21.04.2021 00#-5405615">Qonuni </a><em>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son) </em></div></div><div class="ACT_TEXT"><div name="-5014191" id="-5014191">Oʻzbekiston Respublikasi Vazirlar Mahkamasi:</div></div><div class="ACT_TEXT"><div name="-5014192" id="-5014192">hukumat qarorlarini ushbu Qonunga muvofiqlashtirsin;</div></div><div class="ACT_TEXT"><div name="-5014193" id="-5014193">davlat boshqaruvi organlari ushbu Qonunga zid boʻlgan oʻz normativ-huquqiy hujjatlarini qayta koʻrib chiqishlari va bekor qilishlarini taʼminlasin.</div></div><div class="CLAUSE_DEFAULT"><div name="-5014195" id="-5014195">75-modda. Ushbu Qonunning kuchga kirishi </div></div><div class="ACT_TEXT"><div name="-5014200" id="-5014200">Ushbu Qonun rasmiy eʼlon qilingan kundan eʼtiboran kuchga kiradi.</div></div><div class="SIGNATURE"><div name="-5014203" id="-5014203">Oʻzbekiston Respublikasining Prezidenti Sh. MIRZIYOYEV</div></div><div class="ACT_ESSENTIAL_ELEMENTS"><div name="-5014206" id="-5014206">Toshkent sh.,</div></div><div class="ACT_ESSENTIAL_ELEMENTS"><div name="-5014208" id="-5014208">2020-yil 23-sentabr,</div></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><div name="-5014211" id="-5014211">OʻRQ-637-son</div></div><div class="PUBLICATION_ORIGIN"><label id="s1089"></label><div name="-5013030" id="-5013030">(Qonun hujjatlari maʼlumotlari milliy bazasi, 24.09.2020-y., 03/20/637/1313-son; Qonunchilik maʼlumotlari milliy bazasi, 21.04.2021-y., 03/21/683/0375-son, 12.10.2021-y., 03/21/721/0952-son; 29.11.2023-y., 03/23/880/0905-son; 01.02.2024-y., 03/24/901/0082-son; 09.09.2024-y., 03/24/957/0689-son; 21.09.2024-y., 03/24/963/0735-son; 05.11.2024-y., 03/24/990/0892-son; 07.02.2025-y., 03/25/1025/0116-son; 24.10.2025-y., 03/25/1091/0969-son; 30.12.2025-y., 03/25/1109/1241-son)</div></div></div>
</div></body></html>