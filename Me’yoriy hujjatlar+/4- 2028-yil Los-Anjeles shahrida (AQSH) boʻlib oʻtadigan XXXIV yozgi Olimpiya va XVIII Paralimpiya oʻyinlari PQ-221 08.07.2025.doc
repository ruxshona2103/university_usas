<style type="text/css">BODY{scrollbar-base-color:scrollbar;scrollbar-highlight-color:white;scrollbar-darkshadow-color:scrollbar;scrollbar-shadow-color:white;}#divCont DIV{border:none;white-space:normal;}#divCont IMG{float:none;vertical-align:middle;}#divCont A{text-decoration:none;}#divCont A:link{color:#008080;}#divCont A:visited{color:#008080;}#divCont A:hover{color:#ff0000;}#divCont P{margin:0px;padding:0px;line-height:1.0;}#divCont LABEL{display:none;}.aExp{text-align:left;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:normal;color:red;font-weight:600;font-size:12pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.aOAD{width:100%;text-align:right;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:italic;color:#808080;font-weight:400;font-size:10pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.signCont{text-align:center;margin:0pt 0pt 12pt 0px;text-indent:0pt;}.mrkup{background-color:#00008B!important;color:#FFFFFF!important;}.mrkupNav{color:#00008B!important;}.mrkupNav SPAN{font:12px Webdings!important;padding:0px 2px!important;}.iorRN{font-weight:600;}.iorVal{text-indent:0px;margin-left:1px;}.clausePrfx{display:inline;float:left;}.clauseSuff{display:block;width:100%;text-indent:0px;}@media print{.clausePrfx{float:none;}.clauseSuff{display:inline;width:auto;}}.ACCEPTING_BODY{text-align:center; text-indent:0; margin:0 0 0 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman";font-variant:normal; line-height:normal;text-transform:uppercase;}.ACT_ESSENTIAL_ELEMENTS{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.ACT_ESSENTIAL_ELEMENTS_NUM{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;padding-bottom: 20px;}.ACT_FORM{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_FORM_LAW{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TEXT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.ACT_TITLE{text-align:center; text-indent:0; margin:12pt 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TITLE_APPL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 10pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TITLE{text-align:center; text-indent:0pt; margin:10pt 0pt 12pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 0pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TITLE{text-align:center; text-indent:0pt; margin:0pt 0pt 12pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.BY_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:0; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CHANGES_ORIGINS{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CLAUSE_AFTER_SRC{text-align:justify;text-justify:inter-word; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:boldl; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.CLAUSE_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT_FOR_WARNING{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.DEPARTMENTAL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.EXPLANATION{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:normal; color:#993366; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; line-height:normal;}.EXTRACT{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.FOOTNOTE{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#339966; font-weight:normal; font-size:10pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.GRIF_PARLAMENT{text-align: left; text-indent:0 mm; margin:0 0 3pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.INDEXES_ON_REF{text-align:left;text-indent:0cm;margin:3pt 0.9cm 3pt 0.95cm;font-style:normal;color:#008000;font-weight:normal;font-size:11pt;font-family:"Times New Roman"; font-variant:normal;line-height:1.0;}.IS_TABLE_FOR_LIST_TEMP{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.NEW_EDITION{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:lowercase; font-variant:normal; line-height:normal;}.OFFICIAL_SOUR_TEXT{text-align:right; font-size:8pt; font-family:Arial, Helvetica, sans-serif; border: 1px solid #A9DBFC; background-color: #E6EDFF;}.PUBLICATION_ORIGIN{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE_STAMPS_PLACEHOLDER{text-align:justify; text-justify:inter-word; text-indent:0; margin:4 10; vertical-align:text-top; flow:left;}.SIGNATURE_STAMP_TEXT{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; vertical-align:baseline!important;}.SIGNATURE_WITH_BOLD{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TABLE_STD{background:#ffffff;color:#000000;margin:4pt;font-size:12pt;width:100%;height:100%;overflow:visible;}.TEXT_15_LEFT{text-align: left; text-indent:30 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_30_LEFT{text-align: left; text-indent:45 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD{text-align:justify;  text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;text-indent:15mm;}.TEXT_BOLD_CENTER{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD_RIGHT{text-align:right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_CENTER{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_AFTER_SRC{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_DEFAULT{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_ITALIC{text-align:justify; text-indent:0; margin:0; font-style:italic; color:#000080; font-weight:italic; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal; text-indent:15mm}.TEXT_RIGHT{text-align: right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}DIV#theSysCssID TABLE{background-color:ivory;color:#000000;border-collapse:separate;font:x-small Tahoma;table-layout:auto;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theSysCssID TABLE TD,TH{border:1px solid #000000;cursor:auto;min-height:8pt;padding:1px 1px 1px 2px;vertical-align:top;white-space:normal;word-wrap:break-word;display:block!important;visibility:visible!important;}DIV#theNormCssID TABLE{background-color:#f5f5f5;color:red;border:1px solid red;font:small Verdana;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNormCssID TABLE TD,TH{border:1px solid red;cursor:auto;min-height:8pt;padding:2px 2px 2px 3px;vertical-align:top;white-space:normal;word-wrap:normal;display:block!important;visibility:visible!important;}DIV#theDefCssID TABLE{background-color:#ffffff;color:#000000;border:1px solid #000000;border-collapse:collapse;font:normal normal normal small/normal Times New Roman;table-layout:fixed;text-align:left;text-decoration:none;text-indent:0;text-transform:none;width:100%;word-spacing:normal;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theDefCssID TABLE TD,TH{background-color:#ffffff;color:#000000;border:1px solid #000000;cursor:auto!important;font:normal normal normal small/normal Times New Roman;min-height:8pt;padding:1px 1px 1px 2px;text-align:left;text-decoration:none;text-indent:0;text-transform:none;vertical-align:top;white-space:normal;word-wrap:break-word;word-spacing:normal;display:block!important;visibility:visible!important;}DIV#theNotCssID TABLE{position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNotCssID TABLE TD,TH,CAPTION{display:block!important;visibility:visible!important;}A#tabBoxDisable TABLE TD,TH{color:#808080;border-color:#808080;}.tabBox{display:inline-block;} .OFFICIAL_SOUR_TEXT{display:none;}</style>
</head>
<body lang='uz-Latn-UZ'><div class=WordSection1>
﻿<div id="divCont" style="background:#ffffff;border:none;margin:auto;"><div class="ACCEPTING_BODY"><div name="-7618175" id="-7618175">Oʻzbekiston Respublikasi Prezidentining</div></div><div class="ACT_FORM"><div name="-7618176" id="-7618176">qarori</div></div><div class="ACT_TITLE"><div name="-7618177" id="-7618177">2028-yil Los-Anjeles shahrida (AQSH) boʻlib oʻtadigan XXXIV yozgi Olimpiya va XVIII Paralimpiya oʻyinlariga Oʻzbekiston sportchilarini kompleks tayyorlash toʻgʻrisida</div></div><div class="BY_DEFAULT"><div name="-7618179" id="-7618179"></div></div><div class="ACT_TEXT"><div name="-7618180" id="-7618180">Olimpiya va paralimpiya sport turlarini rivojlantirish orqali nufuzli xalqaro sport musobaqalari, shu jumladan, 2028-yil Los-Anjeles shahrida (AQSH) boʻlib oʻtadigan XXXIV yozgi Olimpiya va XVIII Paralimpiya oʻyinlarida (keyingi oʻrinlarda — Olimpiya va Paralimpiya oʻyinlari) sportchilarimizning har tomonlama muvaffaqiyatli ishtirok etishini taʼminlash maqsadida qaror qilaman:</div></div><div class="TEXT_CENTER"><div name="-7618182" id="-7618182"><strong>I. Maqsadlar va ustuvor vazifalar</strong></div></div><div class="ACT_TEXT"><div name="-7618183" id="-7618183">1. Quyidagilar Oʻzbekiston sportchilarini Olimpiya va Paralimpiya oʻyinlariga tayyorlashning asosiy maqsadlari va ustuvor vazifalari etib belgilansin:</div></div><div class="ACT_TEXT"><div name="-7618184" id="-7618184">(a) olimpiya va paralimpiya sport turlarini ularning amaldagi natijalaridan kelib chiqib, toifalarga ajratgan holda (ustuvor, istiqbolli va rivojlanayotgan) qisqa va uzoq muddatli strategiyalarni belgilash orqali differensial yondashuv asosida rivojlantirish;</div></div><div class="ACT_TEXT"><div name="-7618185" id="-7618185">(b) sportning ustuvor toifadagi boks, dzyudo, taekvondo, erkin kurash, ogʻir atletika turlari boʻyicha medallar sonini oshirish;</div></div><div class="ACT_TEXT"><div name="-7618186" id="-7618186">(v) sportning istiqbolli toifadagi yunon-rum, ayollar kurashi, kamondan otish, qilichbozlik, oʻq otish, yengil atletika, velosport, eshkak eshish, suzish va sinxron suzish kabi 18 ta turi boʻyicha litsenziyalarni koʻpaytirish hamda medallar uchun kurashish;</div></div><div class="ACT_TEXT"><div name="-7618187" id="-7618187">(g) sportning rivojlanayotgan toifadagi triatlon, voleybol, stol tennisi, basketbol, zamonaviy besh kurash kabi 21 ta turi boʻyicha litsenziyalarni qoʻlga kiritish;</div></div><div class="ACT_TEXT"><div name="-7618188" id="-7618188">(d) jamoaviy sport turlari, ot sporti, murakkab texnik sport turlarini rivojlantirish orqali natijador sport turlari geografiyasini kengaytirish;</div></div><div class="ACT_TEXT"><div name="-7618189" id="-7618189">(e) xalqaro sport tashkilotlari bilan hamkorlikni rivojlantirish va ular faoliyatida Oʻzbekiston sport hamjamiyati vakillari ishtirokini kengaytirish.</div></div><div class="TEXT_CENTER"><div name="-7618190" id="-7618190"><strong>II. Tashkiliy chora-tadbirlar</strong></div></div><div class="ACT_TEXT"><div name="-7618191" id="-7618191">2. Ushbu qaror bilan belgilangan maqsad va ustuvor vazifalarga erishish uchun quyidagilar tasdiqlansin:</div></div><div class="ACT_TEXT"><div name="-7618192" id="-7618192">(a) 2028-yil Los-Anjeles shahrida (AQSH) boʻlib oʻtadigan XXXIV yozgi Olimpiya va XVIII Paralimpiya oʻyinlariga Oʻzbekiston sportchilarini tayyorlash dasturi (keyingi oʻrinlarda — Dastur) <a href="https://lex.uz/docs/-7617536#-7618383">1-ilovaga</a> muvofiq;</div></div><div class="ACT_TEXT"><div name="-7618193" id="-7618193">(b) 2028-yil Los-Anjeles shahrida (AQSH) boʻlib oʻtadigan XXXIV yozgi Olimpiya va XVIII Paralimpiya oʻyinlariga tayyorgarlik koʻrish hamda milliy terma jamoa aʼzolarining kontingenti boʻyicha maqsadli koʻrsatkichlar <a href="https://lex.uz/docs/-7617536#-7618390">2</a> va <a href="https://lex.uz/docs/-7617536#-7618400">2a-ilovalarga</a> muvofiq;</div></div><div class="ACT_TEXT"><div name="-7618194" id="-7618194">(v) 2028-yil Los-Anjeles shahrida (AQSH) boʻlib oʻtadigan XXXIV yozgi Olimpiya va XVIII Paralimpiya oʻyinlariga Oʻzbekiston sportchilarini tayyorlash uchun Sport vazirligi, Milliy olimpiya va paralimpiya qoʻmitalari, sport federatsiyalari (uyushmalari)ga biriktiriladigan sport bazalari roʻyxati <a href="https://lex.uz/docs/-7617536#-7618410">3-ilovaga</a> muvofiq;</div></div><div class="ACT_TEXT"><div name="-7618195" id="-7618195">(g) Olimpiya va Paralimpiya oʻyinlariga Oʻzbekiston sportchilarini tayyorlash boʻyicha respublika komissiyasi (keyingi oʻrinlarda — Respublika komissiyasi) tarkibi <a href="https://lex.uz/docs/-7617536#-7618422">4-ilovaga</a> muvofiq;</div></div><div class="ACT_TEXT"><div name="-7618196" id="-7618196">(d) olimpiya harakatini rivojlantirish boʻyicha kompleks chora-tadbirlarning amalga oshirilishini tashkil qilish maqsadida Sport vazirligi va Oʻzbekiston Milliy olimpiya qoʻmitasining hududlarga biriktiriladigan masʼullari roʻyxati <a href="https://lex.uz/docs/-7617536#-7618444">5-ilovaga</a> muvofiq.</div></div><div class="ACT_TEXT"><div name="-7618197" id="-7618197">3. Belgilansinki, mazkur qarorning <a href="https://lex.uz/docs/-7617536#-7618410">3-ilovasiga</a> muvofiq biriktirilayotgan sport bazalaridan sport federatsiyalari (uyushmalari)ning belgilangan tartibda foydalanishi uchun zarur shart-sharoitlar (elektr energiyasi, gaz, suv, taʼmirlash ishlari) yaratiladi. Bunda ushbu sport bazalarida zarur shart-sharoitlarni yaratish bilan bogʻliq xarajatlar sport bazalarini balansda saqlovchilarning mablagʻlari hisobidan moliyalashtiriladi.</div></div><div class="TEXT_CENTER"><div name="-7618199" id="-7618199"><strong>III. </strong><strong>Nufuzli xalqaro sport musobaqalariga tayyorgarlik koʻrish</strong></div></div><div class="ACT_TEXT"><div name="-7618204" id="-7618204">4. Nufuzli xalqaro sport musobaqalariga tayyorgarlik koʻrishda olimpiya va paralimpiya sport turlarini rivojlantirishning quyidagi tartibi joriy etilsin:</div></div><div class="ACT_TEXT"><div name="-7618205" id="-7618205">(a) Olimpiya va Paralimpiya oʻyinlarida erishgan natijalardan kelib chiqib, sport turlari ustuvor, istiqbolli va rivojlanayotgan toifalarga ajratiladi;</div></div><div class="ACT_TEXT"><div name="-7618206" id="-7618206">(b) ustuvor, istiqbolli va rivojlanayotgan toifalardagi sport turlari roʻyxati har toʻrt yilda Olimpiya va Paralimpiya oʻyinlari oʻtkazilgan kalendar yilning yakuniga qadar qayta koʻrib chiqiladi va tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-7618207" id="-7618207">5. Shunday tartib oʻrnatilsinki, unga muvofiq:</div></div><div class="ACT_TEXT"><div name="-7618209" id="-7618209">(a) Oʻzbekiston Milliy olimpiya va paralimpiya qoʻmitalari tashabbusi bilan milliy terma jamoalar uchun ilgʻor xorijiy davlatlar terma jamoalari bilan tashkil etiladigan qoʻshma oʻquv-mashgʻulot yigʻinlarida chet ellik sportchi va trenerlarning ishtiroki bilan bogʻliq xarajatlar tashabbuskorlar hamda tegishli sport federatsiyalari (uyushmalari)ning mablagʻlari hisobidan moliyalashtiriladi;</div></div><div class="ACT_TEXT"><div name="-7618212" id="-7618212">(b) Respublika komissiyasiga milliy terma jamoalarni tayyorlash uchun jalb etiladigan Oʻzbekistonda tugʻilgan yoki Oʻzbekiston fuqaroligiga ega va ilgʻor xorij tajribasini oʻzlashtirgan yuqori malakali trenerlar, sport mutaxassislari va tibbiyot xodimlarining mehnatiga haq toʻlash miqdorlarini tegishliligiga koʻra Oʻzbekiston Milliy olimpiya va paralimpiya qoʻmitalariga ajratilgan mablagʻlar doirasida belgilash huquqi beriladi;</div></div><div class="ACT_TEXT"><div name="-7618215" id="-7618215">(v) zaruratga koʻra, milliy terma jamoalarning 2026-yilda Aichi va Nagoya shaharlarida (Yaponiya) boʻlib oʻtadigan XX yozgi Osiyo va V yozgi Paraosiyo oʻyinlariga tayyorgarligi va ishtiroki bilan bogʻliq xarajatlar Olimpiya va Paralimpiya oʻyinlariga tayyorgarlik maqsadlariga ajratiladigan Davlat budjeti va homiylik mablagʻlari hisobidan moliyalashtiriladi.</div></div><div class="TEXT_CENTER"><div name="-7618218" id="-7618218"><strong>IV. Nodavlat jismoniy tarbiya-sport tashkilotlarini qoʻllab-quvvatlash</strong></div></div><div class="ACT_TEXT"><div name="-7618221" id="-7618221">6. Oʻzbekiston Respublikasi Prezidentining 2024-yil 18-dekabrdagi “Yoshlarning sport bilan muntazam shugʻullanishi uchun qoʻshimcha shart-sharoitlar yaratish toʻgʻrisida”gi PQ-443-son <a href="https://lex.uz/docs/-7266934">qaroriga</a> muvofiq jismoniy tarbiya va sport sohasida faoliyat yurituvchi tashkilotlar reyestrini (keyingi oʻrinlarda — Reyestr) yuritish tartibi joriy etilgani maʼlumot uchun qabul qilinsin.</div></div><div class="ACT_TEXT"><div name="-7618223" id="-7618223">7. Belgilab qoʻyilsinki:</div></div><div class="ACT_TEXT"><div name="-7618225" id="-7618225">(a) Reyestrga kiritilgan nodavlat<strong> </strong>jismoniy tarbiya-sport tashkilotlarining sportchilariga<strong> </strong>barcha rasmiy sport musobaqalarida tegishli nodavlat jismoniy tarbiya-sport tashkiloti nomidan ishtirok etish huquqi beriladi hamda yaxshi natija koʻrsatgan sportchilar terma jamoalarga qabul qilinishi mumkin boʻladi;</div></div><div class="ACT_TEXT"><div name="-7618228" id="-7618228">(b) Reyestrga kiritilgan nodavlat jismoniy tarbiya-sport tashkilotlari olimpiya va paralimpiya sport turlari boʻyicha<strong> </strong>sportchilarni tayyorlashda:</div></div><div class="ACT_TEXT"><div name="-7618231" id="-7618231">(i) davlat sport-taʼlim tashkilotlarining sport inshootlaridan tadbirlardan boʻsh vaqtlarda reja-jadval asosida begʻaraz asosda foydalanadi;</div></div><div class="ACT_TEXT"><div name="-7618232" id="-7618232">(ii) yoshlarning qamrov darajasidan kelib chiqib, Sport vazirligiga rivojlantirish dasturlari uchun ajratilgan mablagʻlar, Sportni qoʻllab-quvvatlash jamgʻarmasi hamda Davlat budjeti mablagʻlari hisobidan begʻaraz asosda sport jihozlari va inventarlari bilan taʼminlanadi;</div></div><div class="ACT_TEXT"><div name="-7618233" id="-7618233">(v) sportchilarni tayyorlash boʻyicha xizmat koʻrsatuvchi barcha darajadagi jismoniy tarbiya-sport tashkilotlari uchun sportchi tayyorlash boʻyicha minimal talab va shartlar bosqichma-bosqich belgilanadi;</div></div><div class="ACT_TEXT"><div name="-7618234" id="-7618234">(g) mazkur bandning <a href="https://lex.uz/docs/-7617536#-7618225">“a”</a> va <a href="https://lex.uz/docs/-7617536#-7618228">“b” kichik bandlarida</a> nazarda tutilgan chora-tadbirlar Davlat budjetidan moliyalashtiriladigan nodavlat jismoniy tarbiya-sport tashkilotlariga nisbatan tatbiq etilmaydi.</div></div><div class="TEXT_CENTER"><div name="-7618236" id="-7618236"><strong>V. Olimpiya oʻyinlariga Oʻzbekiston sportchilari zaxirasini kengaytirish</strong></div></div><div class="ACT_TEXT"><div name="-7618239" id="-7618239">8. Belgilansinki:</div></div><div class="ACT_TEXT"><div name="-7618243" id="-7618243">(a) 2025-yildan boshlab:</div></div><div class="ACT_TEXT"><div name="-7618247" id="-7618247">(i) Olimpiya oʻyinlariga Oʻzbekiston sportchilari zaxirasini kengaytirishga yoʻnaltirilgan iqtidorli sportchilarni eng quyi boʻgʻindan boshlab saralash va ularni professional tayyorlash uchun bosqichma-bosqich olimpiya sport turlari boʻyicha oʻsmirlar va yoshlar oʻrtasidagi Oʻzbekiston chempionatlarini uch bosqichli “Yangi Oʻzbekiston Olimpiya choʻqqilari” sport musobaqalari shaklida oʻtkazib borish tizimi yoʻlga qoʻyiladi;</div></div><div class="ACT_TEXT"><div name="-7618249" id="-7618249">(ii) “Yangi Oʻzbekiston Olimpiya choʻqqilari” sport musobaqalarida tashkiliy-huquqiy shaklidan qatʼi nazar, yoshlarni sport bilan doimiy shugʻullantirish xizmatini koʻrsatadigan jismoniy va yuridik shaxslarning sport tayyorgarligiga ega boʻlgan sportchilari ishtirok etishiga ruxsat beriladi;</div></div><div class="ACT_TEXT"><div name="-7618250" id="-7618250">(iii) “Yangi Oʻzbekiston Olimpiya choʻqqilari” sport musobaqalarining respublika final (uchinchi) bosqichi har yili Olimpiya shaharchasida “Prezident Olimpiadasi” sifatida oʻtkaziladi;</div></div><div class="ACT_TEXT"><div name="-7618251" id="-7618251">(iv) Qoraqalpogʻiston Respublikasi Vazirlar Kengashi Raisi, viloyatlar va Toshkent shahri, tuman va shaharlar hokimlari mazkur musobaqalarning birinchi va ikkinchi bosqichlarini yuqori saviyada tashkil etish va oʻtkazish hamda gʻolib va sovrindorlarni ragʻbatlantirish uchun masʼul hisoblanadi;</div></div><div class="ACT_TEXT"><div name="-7618252" id="-7618252">(v) “Yangi Oʻzbekiston Olimpiya choʻqqilari” sport musobaqalarini, qoʻshma oʻquv-mashgʻulot yigʻinlarini tashkil etish va oʻtkazish bilan bogʻliq xarajatlar har yilgi sport va ommaviy jismoniy tarbiya tadbirlarining respublika va hududiy kalendar rejalari doirasida moliyalashtiriladi;</div></div><div class="ACT_TEXT"><div name="-7618255" id="-7618255">(b) “Yangi Oʻzbekiston Olimpiya choʻqqilari” sport musobaqalarining respublika final bosqichida saralangan sportchilar ularning xohishidan kelib chiqib, quyidagi sport-taʼlim tashkilotlariga milliy terma jamoalarga zaxira sifatida tayyorlash uchun yoʻnaltirib boriladi:</div></div><div class="ACT_TEXT"><div name="-7618257" id="-7618257">(i) birinchi va ikkinchi oʻrinlarni qoʻlga kiritgan sportchilar — Respublika olimpiya va paralimpiya sport turlariga tayyorlash markazi (keyingi oʻrinda — Markaz)ga;</div></div><div class="ACT_TEXT"><div name="-7618259" id="-7618259">(ii) uchinchi oʻrinni qoʻlga kiritgan sportchilar — hududiy olimpiya va paralimpiya sport turlariga tayyorlash markazlariga.</div></div><div class="ACT_TEXT"><div name="-7618262" id="-7618262">Bunda doimiy ravishda birinchi, ikkinchi va uchinchi oʻrinlarni qoʻlga kiritgan sportchilar oʻrtasida qoʻshma oʻquv-mashgʻulot yigʻinlari va nazorat bellashuvlari oʻtkazib boriladi;</div></div><div class="ACT_TEXT"><div name="-7618263" id="-7618263">(v) 2025/2026 oʻquv yilidan boshlab:</div></div><div class="ACT_TEXT"><div name="-7618324" id="-7618324">(i) Markazda oʻqish jarayoni 2 ta bosqichda amalga oshiriladi, yaʼni birinchi bosqichda 8 — 11-sinflar uchun Olimpiya va Paralimpiya maktabi, ikkinchi bosqichda 1-2-kurslar uchun Olimpiya va Paralimpiya kolleji faoliyat koʻrsatadi;</div></div><div class="ACT_TEXT"><div name="-7618325" id="-7618325">(ii) Olimpiya shaharchasi sport inshootlari Markazga mustaqil va Oʻzbekiston davlat sport akademiyasi bilan qoʻshma oʻquv-yigʻin mashgʻulotlarini oʻtkazib borish uchun tadbirlardan boʻsh vaqtlarda begʻaraz asosda biriktiriladi;</div></div><div class="ACT_TEXT"><div name="-7618326" id="-7618326">(iii) Markaz tomonidan oʻquvchi-sportchilarni tayyorlash uchun jalb etiladigan trenerlar, shuningdek, milliy terma jamoalar trenerlari bilan mehnat shartnomalari muayyan muddatga tuziladi va ular tayyorlagan oʻquvchi-sportchilar erishadigan natijalardan kelib chiqib, shartnoma muddatini uzaytirish yoki bekor qilish masalasi hal etiladi;</div></div><div class="ACT_TEXT"><div name="-7618327" id="-7618327">(g) 2026-yildan boshlab:</div></div><div class="ACT_TEXT"><div name="-7618330" id="-7618330">(i) Markaz faoliyatini moliyalashtirish respublika budjetiga oʻtkaziladi;</div></div><div class="ACT_TEXT"><div name="-7618331" id="-7618331">(ii) Markaz oʻquvchi-sportchilari kontingenti 800 nafarga yetkaziladi;</div></div><div class="ACT_TEXT"><div name="-7618332" id="-7618332">(iii) Markazning Olimpiya va Paralimpiya kolleji oʻquvchi-sportchilariga Sport vazirligining stipendiyasi uchun nazarda tutilgan mablagʻlar doirasida oylik stipendiya taʼsis etiladi;</div></div><div class="ACT_TEXT"><div name="-7618333" id="-7618333">(d)<strong> </strong>Olimpiya oʻyinlari va ushbu musobaqa dasturiga kiritilgan sport turlari boʻyicha jahon chempionatlari gʻolib va sovrindorlari oliy harbiy (ixtisoslashtirilgan) taʼlim muassasalariga toʻgʻridan-toʻgʻri qabul qilinadi;</div></div><div class="ACT_TEXT"><div name="-7618334" id="-7618334">(e) olimpiya va paralimpiya sport turlariga tayyorlash markazlariga terma jamoalar sportchilarini ilgʻor xorijiy mamlakatlar tajribasi asosida tayyorlash uchun, zaruratga koʻra, har yili Oʻzbekiston Milliy olimpiya va paralimpiya qoʻmitalariga Olimpiya va Paralimpiya oʻyinlariga tayyorgarlik koʻrish uchun ajratiladigan Davlat budjeti va homiylik mablagʻlari hisobidan chet ellik sport mutaxassislari jalb etib boriladi.</div></div><div class="ACT_TEXT"><div name="-7618335" id="-7618335">9. Trenerlarning yuqori mahoratli sportchilarni tayyorlashdagi xizmatlari uchun ragʻbatlantirish tizimini takomillashtirish maqsadida olimpiya va paralimpiya sport turlariga tayyorlash markazlari hamda oliy sport va sport turlari boʻyicha mahorat maktablariga qabul qilingan oʻquvchi-sportchi tomonidan qoʻlga kiritilgan sport natijalari uchun belgilanadigan ustamaning 10 foiz qismini uni sport maktabida tayyorlagan trenerga toʻlab borish tartibi joriy etilsin.</div></div><div class="TEXT_CENTER"><div name="-7618339" id="-7618339"><strong>VI. Olimpiya sport turlariga tayyorlashning ixtisoslashtirilgan milliy vertikal-integratsiyalashgan tizimi</strong></div></div><div class="ACT_TEXT"><div name="-7618340" id="-7618340">10. Oʻzbekiston Milliy olimpiya qoʻmitasi, Sport vazirligi, Qoraqalpogʻiston Respublikasi Vazirlar Kengashi, viloyatlar va Toshkent shahri hokimliklarining quyidagi takliflariga rozilik berilsin:</div></div><div class="ACT_TEXT"><div name="-7618341" id="-7618341">(a)<strong> </strong>Oʻzbekiston Milliy olimpiya qoʻmitasining Qoraqalpogʻiston Respublikasi, viloyatlar va Toshkent shahri boʻlinmalarini tashkil etish;</div></div><div class="ACT_TEXT"><div name="-7618342" id="-7618342">(b) Qoraqalpogʻiston Respublikasi Vazirlar Kengashi Raisi, viloyatlar va Toshkent shahri hokimlarini Olimpiya harakatini rivojlantirish boʻyicha Oʻzbekiston Respublikasi Prezidentining joylardagi maxsus vakili hamda Oʻzbekiston Milliy olimpiya qoʻmitasining hududiy boʻlinmalari rahbarlari etib belgilash.</div></div><div class="ACT_TEXT"><div name="-7618343" id="-7618343">11. Belgilansinki:</div></div><div class="ACT_TEXT"><div name="-7618344" id="-7618344">(a) Oʻzbekiston Milliy olimpiya qoʻmitasi hududiy boʻlinmalari faoliyati uchun zarur boʻlgan 2,5 tadan shtat birliklari Davlat budjeti mablagʻlari hisobidan moliyalashtiriladi;</div></div><div class="ACT_TEXT"><div name="-7618345" id="-7618345">(b) Oʻzbekiston Milliy olimpiya qoʻmitasi hamda Adaptiv sport turlari assotsiatsiyasi hududiy boʻlinmalari mos ravishda olimpiya va paralimpiya sport turlariga tayyorlash markazlariga begʻaraz asosda joylashtiriladi;</div></div><div class="ACT_TEXT"><div name="-7618346" id="-7618346">(v) Olimpiya va Paralimpiya harakatini rivojlantirish boʻyicha Qoraqalpogʻiston Respublikasi Vazirlar Kengashi Raisi, viloyatlar va Toshkent shahri hokimlari rahbarlik qiladigan hududiy kengashlar tashkil etiladi.</div></div><div class="TEXT_CENTER"><div name="-7618347" id="-7618347"><strong>VII. </strong><strong>Imtiyozlar</strong></div></div><div class="ACT_TEXT"><div name="-7618348" id="-7618348">12. Oʻzbekiston Respublikasi Prezidentining 2021-yil 5-noyabrdagi “2024-yil Parij shahrida (Fransiya) boʻlib oʻtadigan XXXIII yozgi Olimpiya va XVII Paralimpiya oʻyinlariga Oʻzbekiston sportchilarini kompleks tayyorlash toʻgʻrisida”gi PQ-5281-son <a href="https://lex.uz/docs/-5713410">qaroriga</a> muvofiq milliy terma jamoalar sportchilari, trenerlari va boshqa mutaxassislari uchun har oylik stipendiyalar, bir martalik toʻlanadigan pul mukofotlari, qimmatbaho sovgʻalar va boshqa yordam koʻrinishida olinadigan toʻlovlar jismoniy shaxslardan olinadigan daromad soligʻiga tortilmasligi hamda ularga ijtimoiy soliq hisoblanmasligi belgilanganligi maʼlumot uchun qabul qilinsin.</div></div><div class="BY_DEFAULT"><div name="-7929573" id="-7929573"></div></div><div class="ACT_TEXT"><div name="-7929574" id="-7929574">Belgilab qoʻyilsinki, Olimpiya va Paralimpiya oʻyinlariga maqsadli tayyorgarlik koʻrish doirasida ushbu toʻlovlar boʻyicha yuzaga kelishi mumkin boʻlgan jismoniy shaxslardan olinadigan daromad soligʻi va ijtimoiy soliq summasi Iqtisodiyot va moliya vazirligi hamda Sport vazirligi tomonidan belgilanadigan tartibda Davlat budjetidan qoplab beriladi.</div></div><div class="CHANGES_ORIGINS"><label id="s1104"></label><div name="-7929575" id="-7929575">(12-bandning ikkinchi xatboshisi Oʻzbekiston Respublikasi Prezidentining 2025-yil 11-dekabrdagi PQ-373-sonli <a href="https://lex.uz/docs/-7904671?ONDATE=12.12.2025 00#-7920643">qarori </a>tahririda — Qonunchilik maʼlumotlari milliy bazasi, 12.12.2025-y., 07/25/373/1157-son)</div></div><div class="ACT_TEXT"><div name="-7618350" id="-7618350">13. Sport vazirligi, Oʻzbekiston Milliy olimpiya qoʻmitasi, Oʻzbekiston Milliy paralimpiya qoʻmitasi, olimpiya sport turlari boʻyicha sport federatsiyalari (uyushmalari) tomonidan belgilangan tartibda shakllantiriladigan roʻyxatlar boʻyicha xorijdan olib kelinadigan, Oʻzbekiston Respublikasida ishlab chiqarilmaydigan sport anjomlari, jihozlari, uskunalari, sunʼiy sport maydonlari va ularning yordamchi uskunalari (shu jumladan, maxsus mashgʻulot trenajyorlari, zamonaviy ilmiy texnologiya vositalari), maxsus sport kiyimlari (ekipirovkalar), kompyuter texnikasi, multimedia mahsulotlari, sport tibbiyoti jihozlari, tibbiy biologik va farmakologik preparatlar 2029-yil 1-yanvarga qadar bojxona bojini toʻlashdan ozod etilsin.</div></div><div class="TEXT_CENTER"><div name="-7618351" id="-7618351"><strong>VIII. Qaror ijrosini tashkil etish, taʼminlash va nazorat</strong></div></div><div class="ACT_TEXT"><div name="-7618352" id="-7618352">14. Sport vazirligi va Oʻzbekiston Milliy olimpiya qoʻmitasi:</div></div><div class="ACT_TEXT"><div name="-7618353" id="-7618353">(a) bir oy muddatda iqtidorli sportchilarni eng quyi boʻgʻindan boshlab saralash va ularni professional tayyorlash boʻyicha uch bosqichli “Yangi Oʻzbekiston Olimpiya choʻqqilari” sport musobaqalarini tashkil etish va oʻtkazish tartibini tasdiqlash boʻyicha qoʻshma qaror qabul qilsin;</div></div><div class="ACT_TEXT"><div name="-7618354" id="-7618354">(b) Oʻzbekiston Milliy paralimpiya qoʻmitasi bilan birgalikda uch oy muddatda hududiy kengashlarning faoliyat yuritishi tartibi toʻgʻrisidagi namunaviy nizomni tasdiqlasin.</div></div><div class="ACT_TEXT"><div name="-7618355" id="-7618355">15. Milliy antidoping agentligi Sport vazirligi, Raqamli texnologiyalar vazirligi va Oʻzbekiston Milliy olimpiya qoʻmitasi bilan birgalikda 2026-yildan boshlab milliy terma jamoalar sportchilarini dopingga qarshi kurashish masalalari yuzasidan uzluksiz qoʻllab-quvvatlash va maslahat berish xizmatini koʻrsatuvchi aloqa platformasi faoliyatini yoʻlga qoʻysin.</div></div><div class="ACT_TEXT"><div name="-7618356" id="-7618356">16. Qoraqalpogʻiston Respublikasi Vazirlar Kengashi Raisi, viloyatlar va Toshkent shahri hokimlari Sport vazirligi, Oʻzbekiston Milliy olimpiya qoʻmitasi va Oʻzbekiston Milliy paralimpiya qoʻmitasi bilan birgalikda bir oy muddatda Olimpiya va Paralimpiya oʻyinlariga milliy terma jamoa sportchilarining sifatli tayyorgarlik koʻrishini taʼminlash boʻyicha quyidagilarni nazarda tutuvchi puxta ishlangan hududiy tayyorgarlik dasturlarini tasdiqlasin:</div></div><div class="ACT_TEXT"><div name="-7618359" id="-7618359">(a) milliy terma jamoa sportchilari, trenerlari va boshqa mutaxassislarini moddiy va ijtimoiy qoʻllab-quvvatlash, ularning maishiy sharoitlarini yaxshilash;</div></div><div class="ACT_TEXT"><div name="-7618360" id="-7618360">b) musobaqalarga tayyorgarlik koʻrayotgan hududiy terma jamoa sportchilari, trenerlari va boshqa sport mutaxassislarining respublika va xalqaro sport tadbirlari hamda oʻquv-mashgʻulot yigʻinlarida uzluksiz ishtirokini taʼminlash;</div></div><div class="ACT_TEXT"><div name="-7618361" id="-7618361">v) olimpiya sport turlari boʻyicha sport federatsiyalari (uyushmalari)ning hududiy boʻlinmalari faoliyatini qoʻllab-quvvatlash, moliyaviy va moddiy-texnika bazasini mustahkamlash, shuningdek, ularni hududdagi yirik tashkilotlarga biriktirish.</div></div><div class="ACT_TEXT"><div name="-7618362" id="-7618362">17. Belgilansinki, Qoraqalpogʻiston Respublikasi Vazirlar Kengashi Raisi, viloyatlar va Toshkent shahri hokimlari hududiy tayyorgarlik dasturlari toʻlaqonli amalga oshirilishi hamda Olimpiya va Paralimpiya harakatini rivojlantirish boʻyicha belgilangan koʻrsatkichlarga erishilishini taʼminlashga shaxsan masʼul va javobgar hisoblanadi.</div></div><div class="ACT_TEXT"><div name="-7618364" id="-7618364">18.<strong> </strong>Respublika komissiyasi:</div></div><div class="ACT_TEXT"><div name="-7618365" id="-7618365">(a) ikki oy muddatda:</div></div><div class="ACT_TEXT"><div name="-7618366" id="-7618366">(i) Olimpiya va Paralimpiya oʻyinlariga sport turlari boʻyicha litsenziyalarni qoʻlga kiritishning maqsadli koʻrsatkichlari (keyingi oʻrinlarda — maqsadli koʻrsatkichlar)ni tasdiqlasin;</div></div><div class="ACT_TEXT"><div name="-7618367" id="-7618367">(ii) sport federatsiyalari (uyushmalari) rahbarlariga tegishli sport turi boʻyicha maqsadli koʻrsatkichlarga erishishga masʼul ekanini koʻrsatib oʻtsin va litsenziyalarni qoʻlga kiritish boʻyicha majburiyatlarni belgilab bersin;</div></div><div class="ACT_TEXT"><div name="-7618368" id="-7618368">(iii) Olimpiya va Paralimpiya oʻyinlariga puxta tayyorgarlik koʻrish maqsadida sport federatsiyalari (uyushmalari)ga tegishli shart-sharoitlar yaratish hamda maqsadli koʻrsatkichlardagi dasturlarda qatnashish va litsenziyalarni qoʻlga kiritish boʻyicha sport federatsiyalari (uyushmalari)ga vazirlik va idoralar rahbarlarini biriktirsin;</div></div><div class="ACT_TEXT"><div name="-7618369" id="-7618369">(iv) Olimpiya va Paralimpiya oʻyinlariga puxta tayyorgarlik koʻrish uchun zarur boʻladigan budjet, budjetdan tashqari, shuningdek, homiylik mablagʻlari miqdorini tasdiqlasin;</div></div><div class="ACT_TEXT"><div name="-7618370" id="-7618370">(v) maqsadli koʻrsatkichlarga erishmagan va qoniqarsiz natijalarni koʻrsatgan, ajratilgan budjet mablagʻlaridan samarali foydalanmagan va boshqa salbiy holatlarga yoʻl qoʻygan sport federatsiyalari (uyushmalari) boshqaruvini tubdan qayta koʻrib chiqsin;</div></div><div class="ACT_TEXT"><div name="-7618371" id="-7618371">(vi) Respublika komissiyasining kengaytirilgan birinchi yigʻilishini oʻtkazsin. Bunda mazkur qarorning mazmun-mohiyati, sportga davlat tomonidan berilayotgan eʼtibor, vazifalarni soʻzsiz bajarish zarurligi, qoniqarsiz natija koʻrsatgan shaxslarga nisbatan tegishli choralar koʻrilishi koʻrsatib oʻtilsin;</div></div><div class="ACT_TEXT"><div name="-7618372" id="-7618372">(b) uch oy muddatda istiqbolli va rivojlanayotgan toifalardagi sport turlari boʻyicha milliy terma jamoalarni xalqaro nufuzli musobaqalarga samarali tayyorlashni tashkil qilish maqsadida Oʻzbekiston Milliy olimpiya hamda paralimpiya qoʻmitalari huzurida tegishli sport federatsiyalari (uyushmalari) va boshqa masʼul tashkilotlar vakillari hamda chet ellik mutaxassislardan iborat tarkibda doimiy faoliyat yurituvchi ishchi shtablar faoliyatini yoʻlga qoʻysin;</div></div><div class="ACT_TEXT"><div name="-7618373" id="-7618373">(v) Dasturda nazarda tutilgan hamda manfaatdor vazirlik va idoralarning zimmasiga yuklatilgan vazifa va topshiriqlar oʻz vaqtida, sifatli va toʻliq bajarilishi ustidan doimiy nazorat oʻrnatsin hamda Dasturga muvofiq amalga oshirilishi lozim boʻlgan ishlarning ijrosini tizimli ravishda muhokama qilish va kamchiliklarni oʻz vaqtida bartaraf etib borish choralarini koʻrsin.</div></div><div class="ACT_TEXT"><div name="-7618374" id="-7618374">19. Sport vazirligi hamda Iqtisodiyot va moliya vazirligining Oʻzbekiston Respublikasi Prezidenti farmon va qarorlari, hududlarga tashriflar bayonlari, Hukumat qarorlari hamda boshqa hujjatlarda Sport vazirligiga berilgan topshiriqlarga muvofiq yangidan qurilishi, rekonstruksiya qilinishi va kapital taʼmirlanishi belgilangan, biroq bugunga qadar davlat dasturlariga kiritilmagan sport obyektlarini keyingi yillardagi Oʻzbekiston Respublikasining ijtimoiy va ishlab chiqarish infratuzilmasini rivojlantirish dasturi loyihasiga kiritib borish toʻgʻrisidagi taklifiga rozilik berilsin.</div></div><div class="ACT_TEXT"><div name="-7618375" id="-7618375">20. Iqtisodiyot va moliya vazirligi Sport vazirligi, Oʻzbekiston Milliy olimpiya va paralimpiya qoʻmitalari, sport federatsiyalari (uyushmalari)ga zarur mablagʻlar oʻrnatilgan tartibda 2025-yildan boshlab Davlat budjetidan ajratib borilishini taʼminlasin. Bunda Davlat moliyaviy nazorat inspeksiyasi tomonidan Olimpiya va Paralimpiya oʻyinlariga tayyorgarlik koʻrish uchun ajratilgan mablagʻlardan maqsadli foydalanilishi hamda qonunchilik talablariga rioya qilinishi belgilangan tartibda nazorat qilib boriladi.</div></div><div class="ACT_TEXT"><div name="-7618376" id="-7618376">21.<strong> </strong>Oʻzbekiston Respublikasi Prezidentining ayrim qarorlariga <a href="https://lex.uz/docs/-7617536#-7618458">6-ilovaga</a> muvofiq oʻzgartirish va qoʻshimchalar kiritilsin.</div></div><div class="ACT_TEXT"><div name="-7618377" id="-7618377">22.<strong> </strong>Mazkur qarorning ijrosini samarali tashkil qilishga masʼul va shaxsiy javobgar etib sport vaziri A.I. Ikramov, Oʻzbekiston Milliy olimpiya qoʻmitasi raisining birinchi oʻrinbosari O.M. Umarov, Oʻzbekiston Milliy paralimpiya qoʻmitasi raisi M.M. Tashxodjayev hamda Qoraqalpogʻiston Respublikasi Vazirlar Kengashi Raisi, viloyatlar va Toshkent shahri hokimlari belgilansin.</div></div><div class="ACT_TEXT"><div name="-7618378" id="-7618378">23. Qaror ijrosini muhokama qilib borish, ijro uchun masʼul tashkilotlar faoliyatini muvofiqlashtirish va nazorat qilish Oʻzbekiston Respublikasi Bosh vaziri A.N. Aripov hamda Oʻzbekiston Respublikasi Prezidenti Administratsiyasi Ijtimoiy rivojlanish departamenti rahbari O.Q. Abduraxmanov zimmasiga yuklansin.</div></div><div class="SIGNATURE"><div name="-7618379" id="-7618379">Oʻzbekiston Respublikasi Prezidenti Sh. MIRZIYOYEV</div></div><div class="ACT_ESSENTIAL_ELEMENTS"><div name="-7618380" id="-7618380">Toshkent sh.,</div></div><div class="ACT_ESSENTIAL_ELEMENTS"><div name="-7618381" id="-7618381">2025-yil 8-iyul,</div></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><div name="-7618382" id="-7618382">PQ-221-son</div></div><div class="BY_DEFAULT"><div name="-7618383" id="-7618383"></div></div><div class="APPL_BANNER_LANDSCAPE_TITLE"><div name="-7618384" id="-7618384">Oʻzbekiston Respublikasi Prezidentining 2025-yil 8-iyuldagi PQ-221-son <a href="https://lex.uz/docs/-7617536">qaroriga</a><br />1-ILOVA</div></div><div class="ACT_TITLE_APPL"><div name="-7618385" id="-7618385">2028-yil Los-Anjeles shahrida (AQSH) boʻlib oʻtadigan XXXIV yozgi Olimpiya va XVIII Paralimpiya oʻyinlariga Oʻzbekiston sportchilarini tayyorlash</div></div><div class="ACT_FORM"><div name="-7618386" id="-7618386">DASTURI</div></div><div class="BY_DEFAULT"><div name="-7618387" id="-7618387"></div></div><div class="BY_DEFAULT"><div name="-7929576" id="-7929576"></div></div><div class="BY_DEFAULT"><div name="-7929577" id="-7929577"><table border="1" cellpadding="0" cellspacing="0" class="MsoNormalTable" style="width: 100.0%; border-collapse: collapse; border: none; mso-border-alt: solid windowtext .5pt; mso-yfti-tbllook: 1184; mso-padding-alt: 0cm 2.85pt 0cm 2.85pt; mso-border-insideh: .5pt solid windowtext; mso-border-insidev: .5pt solid windowtext;" width="100%"><tbody><tr style="mso-yfti-irow: 0; mso-yfti-firstrow: yes;"><td style="width: 2.74%; border: solid windowtext 1.0pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" width="2%"><p align="center" class="MsoNormal" style="text-align: center;"><strong><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR; mso-bidi-font-weight: bold;">T/r</span></strong></p></td><td style="width: 26.72%; border: solid windowtext 1.0pt; border-left: none; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" width="26%"><p align="center" class="MsoNormal" style="text-align: center;"><strong><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR; mso-bidi-font-weight: bold;">Chora-tadbirlar</span></strong></p></td><td style="width: 27.96%; border: solid windowtext 1.0pt; border-left: none; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" width="27%"><p align="center" class="MsoNormal" style="text-align: center;"><strong><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR; mso-bidi-font-weight: bold;">Amalga oshirish mexanizmlari</span></strong></p></td><td style="width: 11.54%; border: solid windowtext 1.0pt; border-left: none; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" width="11%"><p align="center" class="MsoNormal" style="text-align: center;"><strong><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR; mso-bidi-font-weight: bold;">Amalga oshirish muddatlari</span></strong></p></td><td style="width: 13.44%; border: solid windowtext 1.0pt; border-left: none; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" width="13%"><p align="center" class="MsoNormal" style="text-align: center;"><strong><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR; mso-bidi-font-weight: bold;">Moliyalashtirish manbalari</span></strong></p></td><td style="width: 17.6%; border: solid windowtext 1.0pt; border-left: none; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" width="17%"><p align="center" class="MsoNormal" style="text-align: center;"><strong><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR; mso-bidi-font-weight: bold;">Masʼul ijrochilar</span></strong></p></td></tr><tr style="mso-yfti-irow: 1;"><td style="width: 2.74%; border: solid windowtext 1.0pt; border-top: none; mso-border-top-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="2%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">1.</span></p></td><td style="width: 26.72%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="26%"><p class="MsoNormal" style="text-align: justify; text-indent: 15.35pt;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">Olimpiya va paralimpiya sport turlarini ularning amaldagi natijalaridan kelib chiqib, toifalarga ajratgan holda qisqa va uzoq muddatli strategiyalarni belgilash orqali ularni differensial yondashuv asosida rivojlantirish.</span></p></td><td style="width: 27.96%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="27%"><p class="MsoNormal" style="text-align: justify; text-indent: 15.35pt;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">1. Sport turlarini ustuvor, istiqbolli va rivojlanayotgan toifalarga ajratish hamda qisqa va uzoq muddatli strategiyalarni belgilash.</span></p><p class="MsoNormal" style="text-align: justify; text-indent: 15.35pt;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">2. Ustuvor, istiqbolli va rivojlanayotgan toifalardagi sport turlari roʻyxatini Olimpiya va Paralimpiya oʻyinlaridagi natijalardan kelib chiqib, Olimpiya va Paralimpiya oʻyinlari oʻtkazilgan har kalendar yilining yakuniga qadar qayta koʻrib chiqish va tasdiqlash.</span></p></td><td style="width: 11.54%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="11%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">Har toʻrt yilda</span></p></td><td style="width: 13.44%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="13%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">-</span></p></td><td style="width: 17.6%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="17%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">Sport vazirligi</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">(<em style="mso-bidi-font-style: normal;">A. Ikramov</em>),</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">Oʻzbekiston Milliy olimpiya qoʻmitasi</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">(<em style="mso-bidi-font-style: normal;">O. Umarov</em>),</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">Oʻzbekiston Milliy paralimpiya qoʻmitasi</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">(<em style="mso-bidi-font-style: normal;">M. Tashxodjayev</em>),</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">sport federatsiyalari</span></p><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">(uyushmalari)</span></p></td></tr><tr style="mso-yfti-irow: 2;"><td style="width: 2.74%; border: solid windowtext 1.0pt; border-top: none; mso-border-top-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="2%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">2.</span></p></td><td style="width: 26.72%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="26%"><p class="MsoNormal" style="text-align: justify; text-indent: 15.35pt;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">Milliy terma jamoalarni xalqaro nufuzli musobaqalarga samarali tayyorlashni tashkil qilish boʻyicha doimiy faoliyat yurituvchi ishchi shtablar faoliyatini yoʻlga qoʻyish.</span></p></td><td style="width: 27.96%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="27%"><p class="MsoNormal" style="text-align: justify; text-indent: 15.35pt;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">1. Istiqbolli va rivojlanayotgan toifalardagi sport turlari boʻyicha Oʻzbekiston Milliy olimpiya hamda paralimpiya qoʻmitalari huzurida doimiy faoliyat yurituvchi ishchi shtablarni tashkil qilish.</span></p><p class="MsoNormal" style="text-align: justify; text-indent: 15.35pt;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">2. Ishchi shtablar tarkibiga tegishli sport federatsiyalari (uyushmalari) va boshqa masʼul tashkilotlar vakillari hamda xorijiy mutaxassislarni kiritish.</span></p></td><td style="width: 11.54%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="11%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">2025-yil sentabr</span></p></td><td style="width: 13.44%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="13%"><p align="center" class="MsoNormal" style="text-align: center;"><span lang="UZ-CYR" style="mso-ansi-language: UZ-CYR;">-</span></p></td><td style="width: 17.6%; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; mso-border-top-alt: solid windowtext .5pt; mso-border-left-alt: solid windowtext .5pt; mso-border-alt: solid windowtext .5pt; background: white; padding: 0cm 2.85pt 0cm 2.85pt;" valign="top" width="17%"><p align="center" class="MsoNormal" style="text-align: center;"><