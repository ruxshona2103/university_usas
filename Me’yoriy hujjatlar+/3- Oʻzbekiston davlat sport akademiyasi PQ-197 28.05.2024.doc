		<tr style="mso-yfti-irow: 2; height: 6.6pt;">
			<td style="width: 3.68%; padding: .75pt .75pt .75pt .75pt; height: 6.6pt;" valign="top" width="3%">
			<p class="MsoNormal"></p>
