<style type="text/css">BODY{scrollbar-base-color:scrollbar;scrollbar-highlight-color:white;scrollbar-darkshadow-color:scrollbar;scrollbar-shadow-color:white;}#divCont DIV{border:none;white-space:normal;}#divCont IMG{float:none;vertical-align:middle;}#divCont A{text-decoration:none;}#divCont A:link{color:#008080;}#divCont A:visited{color:#008080;}#divCont A:hover{color:#ff0000;}#divCont P{margin:0px;padding:0px;line-height:1.0;}#divCont LABEL{display:none;}.aExp{text-align:left;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:normal;color:red;font-weight:600;font-size:12pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.aOAD{width:100%;text-align:right;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:italic;color:#808080;font-weight:400;font-size:10pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.signCont{text-align:center;margin:0pt 0pt 12pt 0px;text-indent:0pt;}.mrkup{background-color:#00008B!important;color:#FFFFFF!important;}.mrkupNav{color:#00008B!important;}.mrkupNav SPAN{font:12px Webdings!important;padding:0px 2px!important;}.iorRN{font-weight:600;}.iorVal{text-indent:0px;margin-left:1px;}.clausePrfx{display:inline;float:left;}.clauseSuff{display:block;width:100%;text-indent:0px;}@media print{.clausePrfx{float:none;}.clauseSuff{display:inline;width:auto;}}.ACCEPTING_BODY{text-align:center; text-indent:0; margin:0 0 0 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman";font-variant:normal; line-height:normal;text-transform:uppercase;}.ACT_ESSENTIAL_ELEMENTS{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.ACT_ESSENTIAL_ELEMENTS_NUM{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;padding-bottom: 20px;}.ACT_FORM{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_FORM_LAW{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TEXT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.ACT_TITLE{text-align:center; text-indent:0; margin:12pt 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TITLE_APPL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 10pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TITLE{text-align:center; text-indent:0pt; margin:10pt 0pt 12pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 0pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TITLE{text-align:center; text-indent:0pt; margin:0pt 0pt 12pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.BY_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:0; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CHANGES_ORIGINS{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CLAUSE_AFTER_SRC{text-align:justify;text-justify:inter-word; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:boldl; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.CLAUSE_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT_FOR_WARNING{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.DEPARTMENTAL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.EXPLANATION{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:normal; color:#993366; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; line-height:normal;}.EXTRACT{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.FOOTNOTE{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#339966; font-weight:normal; font-size:10pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.GRIF_PARLAMENT{text-align: left; text-indent:0 mm; margin:0 0 3pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.INDEXES_ON_REF{text-align:left;text-indent:0cm;margin:3pt 0.9cm 3pt 0.95cm;font-style:normal;color:#008000;font-weight:normal;font-size:11pt;font-family:"Times New Roman"; font-variant:normal;line-height:1.0;}.IS_TABLE_FOR_LIST_TEMP{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.NEW_EDITION{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:lowercase; font-variant:normal; line-height:normal;}.OFFICIAL_SOUR_TEXT{text-align:right; font-size:8pt; font-family:Arial, Helvetica, sans-serif; border: 1px solid #A9DBFC; background-color: #E6EDFF;}.PUBLICATION_ORIGIN{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE_STAMPS_PLACEHOLDER{text-align:justify; text-justify:inter-word; text-indent:0; margin:4 10; vertical-align:text-top; flow:left;}.SIGNATURE_STAMP_TEXT{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; vertical-align:baseline!important;}.SIGNATURE_WITH_BOLD{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TABLE_STD{background:#ffffff;color:#000000;margin:4pt;font-size:12pt;width:100%;height:100%;overflow:visible;}.TEXT_15_LEFT{text-align: left; text-indent:30 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_30_LEFT{text-align: left; text-indent:45 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD{text-align:justify;  text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;text-indent:15mm;}.TEXT_BOLD_CENTER{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD_RIGHT{text-align:right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_CENTER{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_AFTER_SRC{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_DEFAULT{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_ITALIC{text-align:justify; text-indent:0; margin:0; font-style:italic; color:#000080; font-weight:italic; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal; text-indent:15mm}.TEXT_RIGHT{text-align: right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}DIV#theSysCssID TABLE{background-color:ivory;color:#000000;border-collapse:separate;font:x-small Tahoma;table-layout:auto;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theSysCssID TABLE TD,TH{border:1px solid #000000;cursor:auto;min-height:8pt;padding:1px 1px 1px 2px;vertical-align:top;white-space:normal;word-wrap:break-word;display:block!important;visibility:visible!important;}DIV#theNormCssID TABLE{background-color:#f5f5f5;color:red;border:1px solid red;font:small Verdana;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNormCssID TABLE TD,TH{border:1px solid red;cursor:auto;min-height:8pt;padding:2px 2px 2px 3px;vertical-align:top;white-space:normal;word-wrap:normal;display:block!important;visibility:visible!important;}DIV#theDefCssID TABLE{background-color:#ffffff;color:#000000;border:1px solid #000000;border-collapse:collapse;font:normal normal normal small/normal Times New Roman;table-layout:fixed;text-align:left;text-decoration:none;text-indent:0;text-transform:none;width:100%;word-spacing:normal;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theDefCssID TABLE TD,TH{background-color:#ffffff;color:#000000;border:1px solid #000000;cursor:auto!important;font:normal normal normal small/normal Times New Roman;min-height:8pt;padding:1px 1px 1px 2px;text-align:left;text-decoration:none;text-indent:0;text-transform:none;vertical-align:top;white-space:normal;word-wrap:break-word;word-spacing:normal;display:block!important;visibility:visible!important;}DIV#theNotCssID TABLE{position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNotCssID TABLE TD,TH,CAPTION{display:block!important;visibility:visible!important;}A#tabBoxDisable TABLE TD,TH{color:#808080;border-color:#808080;}.tabBox{display:inline-block;} .OFFICIAL_SOUR_TEXT{display:none;}</style>
</head>
<body lang='uz-Latn-UZ'><div class=WordSection1>
﻿<div id="divCont" style="background:#ffffff;border:none;margin:auto;"><div class="ACT_FORM"><div name="-8095488" id="-8095488">Oʻzbekiston Respublikasining Qonuni</div></div><div class="ACT_TITLE"><div name="-8095489" id="-8095489">Jismoniy tarbiya va sport toʻgʻrisida</div></div><div class="GRIF_PARLAMENT"><div name="-8095490" id="-8095490">Qonunchilik palatasi tomonidan 2025-yil 23-dekabrda qabul qilingan<br />Senat tomonidan 2026-yil 5-fevralda maʼqullangan</div></div><div class="BY_DEFAULT"><div name="-8095492" id="-8095492"></div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8095493" id="-8095493"><b>1-bob. Umumiy qoidalar</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8095494" id="-8095494"><b>1-modda. Ushbu Qonunning maqsadi</b></div></div><div class="ACT_TEXT"><div name="-8095495" id="-8095495">Ushbu Qonunning maqsadi jismoniy tarbiya va sport sohasidagi munosabatlarni tartibga solishdan iborat.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095496" id="-8095496"><b>2-modda. Jismoniy tarbiya va sport toʻgʻrisidagi qonunchilik</b></div></div><div class="ACT_TEXT"><div name="-8095497" id="-8095497">Jismoniy tarbiya va sport toʻgʻrisidagi qonunchilik ushbu Qonun va boshqa qonunchilik hujjatlaridan iboratdir.</div></div><div class="ACT_TEXT"><div name="-8095498" id="-8095498">Agar Oʻzbekiston Respublikasining xalqaro shartnomasida Oʻzbekiston Respublikasining jismoniy tarbiya va sport toʻgʻrisidagi qonunchiligida nazarda tutilganidan boshqacha qoidalar belgilangan boʻlsa, xalqaro shartnoma qoidalari qoʻllaniladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095499" id="-8095499"><b>3-modda. Asosiy tushunchalar</b></div></div><div class="ACT_TEXT"><div name="-8095500" id="-8095500">Ushbu Qonunda quyidagi asosiy tushunchalar qoʻllaniladi:</div></div><div class="ACT_TEXT"><div name="-8095501" id="-8095501"><b>antidoping qoidalari</b> — Butunjahon antidoping kodeksi va milliy antidoping qoidalari;</div></div><div class="ACT_TEXT"><div name="-8095503" id="-8095503"><b>jismoniy reabilitatsiya</b> — odam organizmining buzilgan yoki vaqtincha yoʻqotilgan funksiyalarini hamda nogironligi boʻlgan shaxslarning ijtimoiy va kasbiy faoliyatga boʻlgan qobiliyatini jismoniy tarbiya va sport vositalari hamda usullaridan foydalangan holda tiklash (tuzatish va kompensatsiya qilish);</div></div><div class="ACT_TEXT"><div name="-8095504" id="-8095504"><b>jismoniy tarbiya</b> — madaniyatning insonni jismoniy tarbiyalash, jismoniy rivojlanish va jismoniy tayyorgarlik orqali jismoniy hamda intellektual jihatdan kamol toptirish, uning qobiliyatini va harakat faolligini takomillashtirish, sogʻlom turmush tarzi koʻnikmalarini shakllantirish, ijtimoiy moslashtirish maqsadida jamiyat tomonidan yaratiladigan hamda foydalaniladigan qadriyatlar, normalar va bilimlar yigʻindisidan iborat boʻlgan qismi;</div></div><div class="ACT_TEXT"><div name="-8095505" id="-8095505"><b>jismoniy tarbiyalash</b> — yuksak madaniyatga ega boʻlgan har tomonlama yetuk hamda jismonan sogʻlom insonni shakllantirish maqsadida shaxsni tarbiyalashga, uning jismoniy imkoniyatlarini rivojlantirishga, jismoniy tarbiya va sport sohasida malaka va bilimlarini oshirishga qaratilgan jarayon;</div></div><div class="ACT_TEXT"><div name="-8095506" id="-8095506"><b>jismoniy tarbiya yoki sport tadbiri tashkilotchisi</b> — oʻz tashabbusi bilan jismoniy tarbiya yoki sport tadbiri oʻtkazayotgan va (yoki) bunday tadbirni tayyorlash hamda oʻtkazishni tashkiliy, moliyaviy va moddiy jihatdan taʼminlashni amalga oshirayotgan yuridik yoki jismoniy shaxs;</div></div><div class="ACT_TEXT"><div name="-8095507" id="-8095507"><b>jismoniy tarbiya-sogʻlomlashtirish inshooti</b> — ommaviy jismoniy tarbiya tadbirlari va jismoniy tarbiya-sogʻlomlashtirish mashgʻulotlarini oʻtkazish uchun moʻljallangan, oʻziga qoʻyiladigan norma va talablarga javob beradigan yopiq yoki ochiq turdagi inshoot;</div></div><div class="ACT_TEXT"><div name="-8095508" id="-8095508"><b>jismoniy tarbiya tadbirlari — </b>aholini jismoniy tarbiya mashgʻulotlariga jalb etishga va aholi oʻrtasida sogʻlom turmush tarzini shakllantirishga qaratilgan tadbirlar;</div></div><div class="ACT_TEXT"><div name="-8095509" id="-8095509"><b>ommaviy sport</b> — sportning tashkil etilgan va (yoki) mustaqil mashgʻulotlarga, shuningdek ommaviy jismoniy tarbiya va sport tadbirlarini oʻtkazish orqali aholini jismoniy tarbiyalashga, sogʻlomlashtirishga, kamol toptirishga hamda jismoniy tarbiya va sport mashgʻulotlariga jalb etishga doir qismi;</div></div><div class="ACT_TEXT"><div name="-8095510" id="-8095510"><b>professional sport</b> — sportning sport musobaqalarini tashkil etish va oʻtkazishga doir qismi boʻlib, sportchilar ularda oʻzining asosiy faoliyati sifatida ishtirok etganligi va ularga tayyorgarlik koʻrganligi uchun mukofot va (yoki) ish haqi oladi;</div></div><div class="ACT_TEXT"><div name="-8095511" id="-8095511"><b>sport</b> — odamlarning muayyan qoidalar boʻyicha tashkil etilgan, ularning jismoniy va intellektual qobiliyatini taqqoslashdan iborat boʻlgan havaskorlik asosidagi va (yoki) professional asosdagi faoliyati, shuningdek ushbu faoliyatga tayyorgarlik koʻrish hamda bu faoliyat jarayonida odamlar oʻrtasida yuzaga keladigan munosabatlar;</div></div><div class="ACT_TEXT"><div name="-8095512" id="-8095512"><b>sportchi</b> — tanlagan sport turi yoki sport turlari bilan muntazam shugʻullanadigan, doimo oʻzining sport mahoratini oshirib boradigan va sport tadbirlarida qatnashadigan jismoniy shaxs;</div></div><div class="ACT_TEXT"><div name="-8095513" id="-8095513"><b>sport diskvalifikatsiyasi</b> — sport turining qoidalarini yoki sport musobaqalari toʻgʻrisidagi qoidalarni (nizomlarni, reglamentlarni) yoxud antidoping qoidalarini buzganlik uchun sportchini, trenerni, sport hakamini va sport sohasidagi boshqa mutaxassislarni sport musobaqalarida ishtirok etishdan chetlashtirish;</div></div><div class="ACT_TEXT"><div name="-8095514" id="-8095514"><b>sport inshooti</b> — sport tadbirlari, sport turlari boʻyicha oʻquv mashgʻulotlari va oʻquv-mashgʻulot yigʻinlarini oʻtkazish uchun moʻljallangan, belgilangan normalar va talablarga javob beradigan yopiq yoki ochiq turdagi ixtisoslashtirilgan inshoot;</div></div><div class="ACT_TEXT"><div name="-8095515" id="-8095515"><b>sport musobaqasi</b> — sportchilar yoki sport jamoalari oʻrtasida sport turi (sport turlari) boʻyicha eng yaxshi ishtirokchini (ishtirokchilarni) aniqlash maqsadida tasdiqlangan qoidalar asosida oʻtkaziladigan bellashuv;</div></div><div class="ACT_TEXT"><div name="-8095516" id="-8095516"><b>sport tadbiri</b> — tasdiqlangan qoidalar asosida tashkil etilgan, jismoniy faollik va raqobatga asoslangan musobaqa, shuningdek sogʻlom turmush tarzini targʻib qilishga, sportchilarning mahorati va salohiyatini namoyon etishga hamda aholini sportga jalb etishga qaratilgan tadbir;</div></div><div class="ACT_TEXT"><div name="-8095517" id="-8095517"><b>sport turi</b> — sport musobaqalariga oʻziga xos tarzda tayyorgarlik koʻrilishi bilan ajralib turuvchi, sport musobaqalarini oʻtkazishga va ularda ishtirok etishga doir talablar va shartlar belgilanadigan qoidalarga (nizomga, reglamentga) ega boʻlgan jismoniy tarbiya va sport sohasidagi faoliyat turi;</div></div><div class="ACT_TEXT"><div name="-8095518" id="-8095518"><b>sport turining tarmogʻi</b> — farqlovchi belgilarga ega boʻlgan hamda bitta yoki bir nechta sport musobaqalari dasturlari turlarini oʻz ichiga oladigan sport turining qismi;</div></div><div class="ACT_TEXT"><div name="-8095519" id="-8095519"><b>sport federatsiyasi (uyushmasi)</b> — mamlakatda muayyan sport turini (turlarini) rivojlantirishni, ommalashtirishni, sport tadbirlarini tashkil etish va oʻtkazishni, shuningdek Oʻzbekiston Respublikasining sport terma jamoasi aʼzoligiga nomzodlarni saralashni va tavsiya etishni oʻz faoliyatining asosiy maqsadi sifatida belgilagan, tegishli tartibda Sport federatsiyalari (uyushmalari) reyestriga kiritilgan nodavlat notijorat tashkiloti;</div></div><div class="ACT_TEXT"><div name="-8095520" id="-8095520"><b>sportning texnik va amaliy turlari</b> — sport natijalariga erishish uchun sportchi tomonidan umumiy jismoniy mashqlar majmuasidan tashqari, sport texnikasidan, moslamalaridan yoki texnikaviy vositalardan foydalana bilish hamda ularni boshqarish sohasidagi koʻnikmalar va mahorat qoʻllaniladigan, shuningdek har xil sport turlaridan olingan, amaliy ahamiyatga ega boʻlgan mashqlar birikmasidan foydalaniladigan sport turlari. Sportning texnik va amaliy turlari yoshlarni Oʻzbekiston Respublikasi Qurolli Kuchlarida xizmat qilishga tayyorlashning tarkibiy qismidir;</div></div><div class="ACT_TEXT"><div name="-8095521" id="-8095521"><b>sportning harbiy-amaliy turlari</b> — asosi harbiy xizmatchilar hamda maxsus xizmatni oʻtayotgan shaxslar tomonidan oʻz xizmat vazifalarini bajarishi bilan bogʻliq maxsus harakatlardan (shu jumladan usullardan) iborat boʻlgan sport turlari;</div></div><div class="ACT_TEXT"><div name="-8095522" id="-8095522"><b>Oʻzbekiston Respublikasining sport terma jamoalari</b> — xalqaro sport musobaqalariga tayyorgarlik koʻrish hamda ularda Oʻzbekiston Respublikasi nomidan ishtirok etish uchun turli yosh toifalari boʻyicha sportchilardan, trenerlardan, jismoniy tarbiya va sport sohasidagi boshqa mutaxassislardan iborat jamoalar;</div></div><div class="ACT_TEXT"><div name="-8095523" id="-8095523"><b>havaskorlik sporti</b> — sportning aholini ixtiyoriylik asosida sportga jalb etish orqali odamlar sogʻligʻini mustahkamlashga qaratilgan qismi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095524" id="-8095524"><b>4-modda. Jismoniy tarbiya va sport sohasidagi davlat siyosatining asosiy yoʻnalishlari</b></div></div><div class="ACT_TEXT"><div name="-8095525" id="-8095525">Jismoniy tarbiya va sport sohasidagi davlat siyosatining asosiy yoʻnalishlari quyidagilardan iborat:</div></div><div class="ACT_TEXT"><div name="-8095526" id="-8095526">jismoniy tarbiya va sportni rivojlantirishni davlat tomonidan qoʻllab-quvvatlash;</div></div><div class="ACT_TEXT"><div name="-8095527" id="-8095527">har kimning jismoniy tarbiya va sport bilan erkin shugʻullanishga boʻlgan huquqini taʼminlash;</div></div><div class="ACT_TEXT"><div name="-8095528" id="-8095528">jismoniy tarbiya va sport sohasidagi davlat hamda jamoatchilik boshqaruvini uygʻunlashtirish;</div></div><div class="ACT_TEXT"><div name="-8095529" id="-8095529">jismoniy va yuridik shaxslarning jismoniy tarbiya va sport sohasidagi huquqlarining kafolatlarini belgilash;</div></div><div class="ACT_TEXT"><div name="-8095530" id="-8095530">jismoniy tarbiya va sport sohasida kamsitishga hamda zoʻravonlikka yoʻl qoʻymaslik;</div></div><div class="ACT_TEXT"><div name="-8095531" id="-8095531">jismoniy tarbiya va sportni rivojlantirish hamda aholini sogʻlom turmush tarziga keng jalb etish;</div></div><div class="ACT_TEXT"><div name="-8095532" id="-8095532">Olimpiya va Paralimpiya harakatini rivojlantirish, sportchilar zaxirasini yaratish, shuningdek xalqaro musobaqalarda sportchilarning ishtirokini taʼminlash;</div></div><div class="ACT_TEXT"><div name="-8095533" id="-8095533">jismoniy tarbiya va sport bilan shugʻullanuvchi shaxslarning, shuningdek jismoniy tarbiya va sport tadbirlari ishtirokchilari hamda tomoshabinlarining hayoti va sogʻligʻi xavfsizligini taʼminlash;</div></div><div class="ACT_TEXT"><div name="-8095534" id="-8095534">nogironligi boʻlgan shaxslar, shuningdek ijtimoiy himoyaga muhtoj aholi oʻrtasida jismoniy tarbiya va sportni rivojlantirishga koʻmaklashish;</div></div><div class="ACT_TEXT"><div name="-8095535" id="-8095535">Oʻzbekistonning milliy sport turlarini va xalq oʻyinlarini rivojlantirish hamda ommalashtirish uchun shart-sharoitlar yaratish;</div></div><div class="ACT_TEXT"><div name="-8095536" id="-8095536">jismoniy tarbiya va sportni rivojlantirishning uzluksizligi va uzviyligini taʼminlash;</div></div><div class="ACT_TEXT"><div name="-8095537" id="-8095537">xalqaro hamkorlikni amalga oshirish.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095538" id="-8095538"><b>5-modda. Jismoniy tarbiya va sport subyektlari</b></div></div><div class="ACT_TEXT"><div name="-8095539" id="-8095539">Jismoniy tarbiya va sport subyektlari jumlasiga quyidagilar kiradi:</div></div><div class="ACT_TEXT"><div name="-8095540" id="-8095540">Oʻzbekiston Respublikasi Sport vazirligi;</div></div><div class="ACT_TEXT"><div name="-8095541" id="-8095541">Oʻzbekiston Milliy olimpiya qoʻmitasi;</div></div><div class="ACT_TEXT"><div name="-8095542" id="-8095542">Oʻzbekiston Milliy paralimpiya qoʻmitasi;</div></div><div class="ACT_TEXT"><div name="-8095543" id="-8095543">sport federatsiyalari (uyushmalari) hamda jismoniy tarbiya va sport sohasidagi boshqa nodavlat notijorat tashkilotlari;</div></div><div class="ACT_TEXT"><div name="-8095544" id="-8095544">jismoniy tarbiya va sport tashkilotlari;</div></div><div class="ACT_TEXT"><div name="-8095545" id="-8095545">sportning texnik va amaliy turlarini rivojlantiruvchi tashkilotlar;</div></div><div class="ACT_TEXT"><div name="-8095546" id="-8095546">jismoniy tarbiya va sport sohasida faoliyatni amalga oshiruvchi taʼlim tashkilotlari;</div></div><div class="ACT_TEXT"><div name="-8095547" id="-8095547">jismoniy tarbiya va sport sohasidagi ilmiy tadqiqotlarni amalga oshiruvchi tashkilotlar;</div></div><div class="ACT_TEXT"><div name="-8095548" id="-8095548">jismoniy tarbiya va sport bilan shugʻullanuvchi jismoniy shaxslar, sportchilar, trenerlar, sport hakamlari, sport agentlari hamda jismoniy tarbiya va sport sohasidagi boshqa mutaxassislar, shuningdek jismoniy tarbiya va sport tadbirlarining ishtirokchilari hamda tomoshabinlari;</div></div><div class="ACT_TEXT"><div name="-8095549" id="-8095549">ushbu Qonunga muvofiq boshqa jismoniy va yuridik shaxslar.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8095550" id="-8095550"><b>2-bob. Jismoniy tarbiya va sport sohasini davlat tomonidan tartibga solish</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8095551" id="-8095551"><b>6-modda. Jismoniy tarbiya va sportni rivojlantirishni davlat tomonidan qoʻllab-quvvatlash</b></div></div><div class="ACT_TEXT"><div name="-8095552" id="-8095552">Jismoniy tarbiya va sportni rivojlantirishni davlat tomonidan qoʻllab-quvvatlash:</div></div><div class="ACT_TEXT"><div name="-8095553" id="-8095553">sportchilarning sport tadbirlarida, shu jumladan sport musobaqalari va oʻquv-mashgʻulot yigʻinlarida ishtirok etishini taʼminlash;</div></div><div class="ACT_TEXT"><div name="-8095554" id="-8095554">Oʻzbekiston Milliy olimpiya qoʻmitasi, Oʻzbekiston Milliy paralimpiya qoʻmitasi, sport federatsiyalari (uyushmalari) hamda jismoniy tarbiya va sport sohasidagi boshqa nodavlat notijorat tashkilotlari faoliyatiga moliyaviy jihatdan koʻmaklashish;</div></div><div class="ACT_TEXT"><div name="-8095555" id="-8095555">jismoniy tarbiya va sportni rivojlantirish, aholi oʻrtasida sogʻlom turmush tarzini shakllantirish uchun shart-sharoitlar yaratish;</div></div><div class="ACT_TEXT"><div name="-8095556" id="-8095556">jismoniy tarbiya va sport tashkilotlari tomonidan moddiy-texnika va axborot resurslaridan, shuningdek ilmiy-tadqiqotga oid va texnik ishlanmalar hamda texnologiyalardan foydalanish uchun shart-sharoitlar yaratish;</div></div><div class="ACT_TEXT"><div name="-8095557" id="-8095557">davlat mulkida boʻlgan jismoniy tarbiya-sogʻlomlashtirish va sport inshootlarini saqlash;</div></div><div class="ACT_TEXT"><div name="-8095558" id="-8095558">sport inshootlarini qurish, mavjudlarini taʼmirlash va rekonstruksiya qilish;</div></div><div class="ACT_TEXT"><div name="-8095559" id="-8095559">jismoniy tarbiya va sport tashkilotlari faoliyatini rivojlantirish uchun zarur shart-sharoitlar yaratish;</div></div><div class="ACT_TEXT"><div name="-8095560" id="-8095560">jismoniy tarbiya va sport vositalaridan aholining, shu jumladan nogironligi boʻlgan shaxslarning sogʻligʻini mustahkamlash maqsadida foydalanish uchun shart-sharoitlar yaratish;</div></div><div class="ACT_TEXT"><div name="-8095561" id="-8095561">nogironligi boʻlgan shaxslarning Paralimpiya oʻyinlarida hamda nogironligi boʻlgan shaxslar oʻrtasidagi boshqa sport tadbirlarida ishtirok etishini rivojlantirishga va taʼminlashga koʻmaklashish;</div></div><div class="ACT_TEXT"><div name="-8095562" id="-8095562">sport tadbirlarini, ommaviy sport va jismoniy tarbiya-sogʻlomlashtirish tadbirlarini tashkil etish;</div></div><div class="ACT_TEXT"><div name="-8095563" id="-8095563">jismoniy tarbiya va sport tashkilotlarining xalqaro hamkorligiga koʻmaklashish;</div></div><div class="ACT_TEXT"><div name="-8095564" id="-8095564">jismoniy tarbiya va sport sohasidagi dasturlarni, ilmiy-uslubiy tizimlarni hamda kompleks ilmiy tadqiqotlarni moliyalashtirish yoʻli bilan amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095565" id="-8095565"><b>7-modda. Oʻzbekiston Respublikasi Vazirlar Mahkamasining jismoniy tarbiya va sport sohasidagi vakolatlari</b></div></div><div class="ACT_TEXT"><div name="-8095566" id="-8095566">Oʻzbekiston Respublikasi Vazirlar Mahkamasi:</div></div><div class="ACT_TEXT"><div name="-8095567" id="-8095567">jismoniy tarbiya va sport sohasida yagona davlat siyosatining amalga oshirilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095568" id="-8095568">jismoniy tarbiya va sport sohasidagi davlat dasturlarini va maqsadli dasturlarni tasdiqlaydi hamda ularning amalga oshirilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095569" id="-8095569">sport va ommaviy jismoniy tarbiya tadbirlarining kalendar rejasini shakllantirish, shuningdek sport turlari boʻyicha Oʻzbekiston Respublikasining sport terma jamoalarini shakllantirish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095570" id="-8095570">xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasini, shuningdek sportning texnik va amaliy turlari boʻyicha sport va ommaviy jismoniy tarbiya tadbirlarining kalendar rejasini tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-8095571" id="-8095571">jismoniy tarbiya va sport sohasidagi vakolatli davlat organining, boshqa respublika ijro etuvchi hokimiyat organlarining faoliyatini muvofiqlashtiradi hamda yoʻnaltiradi;</div></div><div class="ACT_TEXT"><div name="-8095572" id="-8095572">jismoniy tarbiya va sport sohasidagi mutaxassislarni tayyorlash, qayta tayyorlash va ularning malakasini oshirish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095573" id="-8095573">jismoniy tarbiya va sport musobaqalari hamda tadbirlarini oʻtkazish qoidalarini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095574" id="-8095574">sport unvonlari, sport razryadlari va malaka toifalarini berish tartibini tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-8095575" id="-8095575">sport musobaqalarida gʻolib va sovrindor boʻlgan sportchilarni hamda ularni tayyorlagan trenerlarni va terma jamoalar aʼzolarini ragʻbatlantirish tartibini belgilaydi.</div></div><div class="ACT_TEXT"><div name="-8095576" id="-8095576">Oʻzbekiston Respublikasi Vazirlar Mahkamasi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095577" id="-8095577"><b>8-modda. Jismoniy tarbiya va sport sohasidagi vakolatli davlat organining vakolatlari</b></div></div><div class="ACT_TEXT"><div name="-8095578" id="-8095578">Oʻzbekiston Respublikasi Sport vazirligi jismoniy tarbiya va sport sohasidagi vakolatli davlat organidir (bundan buyon matnda vakolatli davlat organi deb yuritiladi).</div></div><div class="ACT_TEXT"><div name="-8095579" id="-8095579">Vakolatli davlat organi:</div></div><div class="ACT_TEXT"><div name="-8095580" id="-8095580">jismoniy tarbiya va sport sohasidagi yagona davlat siyosatini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095581" id="-8095581">jismoniy tarbiya va sport sohasidagi davlat dasturlarini hamda maqsadli dasturlarni ishlab chiqadi va amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095582" id="-8095582">jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikka rioya etilishi ustidan monitoring va nazoratni, shuningdek jismoniy tarbiya va sportning rivojlanish tahlilini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095583" id="-8095583">jismoniy tarbiya va sport sohasidagi normativ-huquqiy hujjatlar va texnik jihatdan tartibga solish sohasidagi normativ hujjatlarning ishlab chiqilishi va tasdiqlanishini oʻz vakolatlari doirasida tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095584" id="-8095584">sport taʼlim tashkilotlarini hamda boshqa jismoniy tarbiya va sport tashkilotlarini tashkil etish boʻyicha takliflar kiritadi va ularning faoliyati tashkil etilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095585" id="-8095585">sport turlari boʻyicha yagona sport tasnifini, shuningdek ushbu tasnif toʻgʻrisidagi nizomni tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-8095586" id="-8095586">sport turlarini va sport turining tarmoqlarini eʼtirof etish, ularni sport turlari reyestriga kiritish, reyestrni yuritish va undan chiqarish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095587" id="-8095587">Sport federatsiyalari (uyushmalari) reyestrini shakllantirish, yuritish, reyestrdan chiqarish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095588" id="-8095588">xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasini shakllantiradi hamda manfaatdor tashkilotlar bilan birgalikda ularning moliyalashtirilishi va oʻtkazilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095589" id="-8095589">jismoniy tarbiya-sogʻlomlashtirish yoki sport inshootlari qabul qilib olinayotganda va sport musobaqalari oʻtkazilishidan oldin ularning belgilangan standartlarga muvofiqligini tekshiradi;</div></div><div class="ACT_TEXT"><div name="-8095590" id="-8095590">Oʻzbekiston Respublikasi sport terma jamoalarining tarkiblarini tasdiqlaydi, Oʻzbekiston sport delegatsiyalarini jamlaydi, ularning tayyorgarlik koʻrishini hamda xalqaro sport musobaqalarida va ommaviy jismoniy tarbiya tadbirlarida ishtirok etishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095591" id="-8095591">Olimpiya va Paralimpiya harakatini rivojlantirish, xalqaro musobaqalarda sportchilarning ishtirokini taʼminlash boʻyicha zarur chora-tadbirlarni belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095592" id="-8095592">sport va ommaviy jismoniy tarbiya tadbirlarini tashkil etadi hamda oʻtkazadi;</div></div><div class="ACT_TEXT"><div name="-8095593" id="-8095593">jismoniy tarbiya va sport sohasidagi mutaxassislarni tayyorlash, qayta tayyorlash hamda ularning malakasini oshirishni tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095594" id="-8095594">jismoniy tarbiya-sogʻlomlashtirish va sport uchun moʻljallangan tovarlarni ishlab chiqarish jarayonining jismoniy tarbiya va sport sohasiga oid standartlarga muvofiq tashkil etilishiga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095595" id="-8095595">yangi jismoniy tarbiya-sogʻlomlashtirish va sport inshootlari barpo etilishini hamda mavjudlarining taʼmirlanishini va rekonstruksiya qilinishini tashkil etishga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095596" id="-8095596">jismoniy tarbiya va sport boʻyicha ilmiy, oʻquv va ommabop adabiyotlar, sport turlari boʻyicha dasturlar tayyorlanishi va nashr etilishini, shuningdek jismoniy tarbiya va sport sohasida multimedia va raqamli texnologiyalar mahsulotlari ishlab chiqilishini tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095597" id="-8095597">sportni ommalashtirishni va aholini sogʻlom turmush tarziga keng jalb etishni tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095598" id="-8095598">jismoniy tarbiya va sportning ommalashtirilishini respublika ijro etuvchi hokimiyat organlari, mahalliy davlat hokimiyati organlari, fuqarolarning oʻzini oʻzi boshqarish organlari, jismoniy tarbiya va sport tashkilotlari, ommaviy axborot vositalari bilan birgalikda tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095599" id="-8095599">jismoniy tarbiya va sport sohasida xalqaro hamkorlikni amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-8095600" id="-8095600">Vakolatli davlat organi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095601" id="-8095601"><b>9-modda. Oʻzbekiston Respublikasi Sogʻliqni saqlash vazirligining jismoniy tarbiya va sport sohasidagi vakolatlari</b></div></div><div class="ACT_TEXT"><div name="-8095602" id="-8095602">Oʻzbekiston Respublikasi Sogʻliqni saqlash vazirligi:</div></div><div class="ACT_TEXT"><div name="-8095603" id="-8095603">jismoniy tarbiyadan sogʻliqni mustahkamlash, kasalliklarning oldini olish va davolash vositasi sifatida foydalanadi;</div></div><div class="ACT_TEXT"><div name="-8095604" id="-8095604">mamlakatda sport tibbiyotini oʻrganish va rivojlantirish sohasida ilmiy-tadqiqot ishlarini olib boradi, dasturlarni ishlab chiqadi va amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095605" id="-8095605">aholining jismoniy jihatdan kamol topish holati tahlilini oʻtkazadi va tegishli davlat organlariga takliflar kiritadi;</div></div><div class="ACT_TEXT"><div name="-8095606" id="-8095606">jismoniy tarbiya va sport bilan shugʻullanayotgan shaxslarning tibbiy monitoringini tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095607" id="-8095607">sportchilarning sport musobaqalariga tayyorgarlik koʻrishini tibbiy jihatdan taʼminlashda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095608" id="-8095608">davlat sport taʼlim muassasalari sportchilarining belgilangan tartibda tibbiy koʻrikdan oʻtkazib borilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095610" id="-8095610">sport tibbiyoti sohasidagi xodimlarni tayyorlash, qayta tayyorlash va ularning malakasini oshirishni tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095611" id="-8095611">sportchilar va boshqa mutaxassislar sport jarohatlarini olganda ularga tibbiy yordam koʻrsatilishini tashkil etadi, shuningdek ularni jismoniy reabilitatsiya qilish boʻyicha tadbirlar oʻtkazadi;</div></div><div class="ACT_TEXT"><div name="-8095612" id="-8095612">aholining jinsi va yoshi toifasiga qarab, jismoniy mashqlar dasturini shakllantirishga doir uslubiy tavsiyalarni ishlab chiqishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095613" id="-8095613">jismoniy tarbiya va sport sohasidagi normativ-huquqiy hujjatlarni ishlab chiqish hamda amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095614" id="-8095614">sogʻlomlashtirish markazlarini, davolash-jismoniy tarbiya dispanserlarini tashkil etadi.</div></div><div class="ACT_TEXT"><div name="-8095615" id="-8095615">Oʻzbekiston Respublikasi Sogʻliqni saqlash vazirligi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095616" id="-8095616">10-modda. Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligining jismoniy tarbiya va sport sohasidagi vakolatlari</div></div><div class="ACT_TEXT"><div name="-8095617" id="-8095617">Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi:</div></div><div class="ACT_TEXT"><div name="-8095618" id="-8095618">oʻrta maxsus, professional va oliy taʼlim tashkilotlarida jismoniy tarbiya va sport bilan shugʻullanish tashkil etilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095619" id="-8095619">oʻrta maxsus, professional va oliy taʼlim tashkilotlarida oʻquv-tarbiya jarayonining sogʻlomlashtirishga yoʻnaltirilgan boʻlishini, shuningdek sogʻlom turmush tarzi normalarini joriy etish uchun shart-sharoitlar yaratilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095620" id="-8095620">oʻrta maxsus, professional va oliy taʼlim tashkilotlari talabalari oʻrtasida jismoniy tarbiya va sport tadbirlarini tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095621" id="-8095621">jismoniy tarbiya va sport boʻyicha mutaxassislarni tayyorlash, qayta tayyorlash hamda ularning malakasini oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095622" id="-8095622">jismoniy tarbiya va sport sohasidagi oʻquv-uslubiy adabiyotlarni tayyorlashda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095623" id="-8095623">oʻrta maxsus, professional va oliy taʼlim tashkilotlarida sport klublari faoliyati yoʻlga qoʻyilishini taʼminlaydi hamda ularning sport klublari oʻrtasida sport musobaqalarini tizimli ravishda oʻtkazib boradi;</div></div><div class="ACT_TEXT"><div name="-8095624" id="-8095624">Butunjahon talabalar oʻyinlarida oliy taʼlim tashkilotlari talabalarining ishtirokini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095625" id="-8095625">oʻrta maxsus, professional va oliy taʼlim tashkilotlari sport inshootlarining moddiy-texnika va resurs bazasi saqlanishi hamda rivojlantirilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095626" id="-8095626">jismoniy tarbiya va sport sohasida ilmiy va innovatsion loyihalarni amalga oshirishga investitsiya va grantlarni jalb etish, ilmiy va innovatsion faoliyatni moliyalashtirish boʻyicha chora-tadbirlarni amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095627" id="-8095627">oʻquvchilar va talabalarga sogʻlom turmush tarzini, sport bilan shugʻullanishning muhimligi, jismoniy va maʼnaviy komillikka intilish tushunchasini singdirishga, ularni salbiy taʼsirlardan himoya qilishga hamda zararli odatlardan xalos etishga doir chora-tadbirlar majmuini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095628" id="-8095628">jismoniy tarbiya va sport sohasidagi normativ-huquqiy hujjatlarni ishlab chiqish hamda amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095629" id="-8095629">oʻquvchilar va talabalarni jismoniy tarbiyalashning zamonaviy shakllari hamda usullarini, jinsi va yoshiga qarab ularga sport koʻnikmalarini singdirishning ilmiy asoslangan tizimlarini ishlab chiqishni hamda ularni joriy etishga koʻmaklashishni tashkil etadi.</div></div><div class="ACT_TEXT"><div name="-8095630" id="-8095630">Oʻzbekiston Respublikasi Oliy taʼlim, fan va innovatsiyalar vazirligi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095631" id="-8095631">11-modda. Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligining jismoniy tarbiya va sport sohasidagi vakolatlari</div></div><div class="ACT_TEXT"><div name="-8095633" id="-8095633">Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi:</div></div><div class="ACT_TEXT"><div name="-8095634" id="-8095634">maktabgacha taʼlim va umumiy oʻrta taʼlim tashkilotlarida jismoniy tarbiya va sportni rivojlantirishni hamda sport infratuzilmasini mustahkamlashni taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095635" id="-8095635">maktabgacha taʼlim va umumiy oʻrta taʼlim tashkilotlarida jismoniy tarbiya va sport bilan shugʻullanishni tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095636" id="-8095636">bolalar va oʻquvchi yoshlar oʻrtasida jismoniy tarbiya va sport tadbirlarini tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095637" id="-8095637">jismoniy tarbiya va sport sohasidagi oʻquv-uslubiy adabiyotlarni tayyorlashda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095638" id="-8095638">umumiy oʻrta taʼlim tashkilotlarida maktab sport klublari faoliyati yoʻlga qoʻyilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095639" id="-8095639">umumiy oʻrta taʼlim tashkilotlarining maktab sport klublari va oʻquvchilari oʻrtasida sport musobaqalarini tizimli ravishda oʻtkazib boradi;</div></div><div class="ACT_TEXT"><div name="-8095640" id="-8095640">jismoniy tarbiya va sport boʻyicha mutaxassislarni tayyorlash, qayta tayyorlash hamda ularning malakasini oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095641" id="-8095641">maktabgacha taʼlim va umumiy oʻrta taʼlim tashkilotlarining moddiy-texnika bazasini rivojlantirish choralarini koʻradi;</div></div><div class="ACT_TEXT"><div name="-8095642" id="-8095642">bolalarga sportga nisbatan muhabbatni singdirishga, oʻsib kelayotgan avlodda sport bilan shugʻullanish, sogʻlom turmush tarzini olib borish, jismoniy va maʼnaviy komillikka intilish muhimligi tushunchasini shakllantirishga, bolalarni salbiy taʼsirlardan himoya qilishga va zararli odatlardan xalos etishga doir chora-tadbirlar majmuini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095643" id="-8095643">jismoniy tarbiya va sport sohasidagi normativ-huquqiy hujjatlarni ishlab chiqish hamda amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095644" id="-8095644">bolalarni jismoniy tarbiyalashning zamonaviy shakllari hamda usullarini, bolalarning jinsi va yoshiga qarab ularga sport koʻnikmalarini singdirishning, sportga qobiliyatli bolalarni ixtisoslashtirilgan sport taʼlim muassasalarida oʻqitish uchun tanlab olishning ilmiy asoslangan tizimlarini ishlab chiqishni hamda ularni joriy etishga koʻmaklashishni tashkil etadi.</div></div><div class="ACT_TEXT"><div name="-8095645" id="-8095645">Oʻzbekiston Respublikasi Maktabgacha va maktab taʼlimi vazirligi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095646" id="-8095646">12-modda. Mahalliy davlat hokimiyati organlarining jismoniy tarbiya va sport sohasidagi vakolatlari</div></div><div class="ACT_TEXT"><div name="-8095647" id="-8095647">Mahalliy davlat hokimiyati vakillik organlari:</div></div><div class="ACT_TEXT"><div name="-8095648" id="-8095648">tegishli hududda jismoniy tarbiya va sport sohasini rivojlantirishga ajratiladigan mahalliy budjet mablagʻlarini koʻrib chiqadi, tasdiqlaydi, ularning ijro etilishi ustidan nazoratni amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095649" id="-8095649">tegishli hududda jismoniy tarbiya va sport sohasidagi hududiy dasturlarni tasdiqlaydi, ularning ijro etilishi ustidan nazoratni amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095650" id="-8095650">tegishli hududdagi jismoniy tarbiya va sport sohasiga masʼullarning hisobotlarini eshitadi;</div></div><div class="ACT_TEXT"><div name="-8095651" id="-8095651">jismoniy tarbiya va sport sohasidagi normativ-huquqiy hujjatlarni ishlab chiqishda hamda amalga oshirishda ishtirok etadi.</div></div><div class="ACT_TEXT"><div name="-8095652" id="-8095652">Mahalliy ijro etuvchi hokimiyat organlari:</div></div><div class="ACT_TEXT"><div name="-8095653" id="-8095653">jismoniy tarbiya va sport sohasidagi davlat dasturlarini hamda maqsadli dasturlarni ishlab chiqishda hamda amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095654" id="-8095654">jismoniy tarbiya va sport sohasidagi hududiy dasturlarni ishlab chiqadi hamda amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095655" id="-8095655">jismoniy tarbiya va sport sohasidagi normativ-huquqiy hujjatlarni ishlab chiqishda hamda amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095656" id="-8095656">hududlarda jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikning ijro etilishini tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095657" id="-8095657">jismoniy tarbiya va sport sohasidagi tadbirlarning mahalliy budjetdan moliyalashtirilishini taʼminlaydi;</div></div><div class="ACT_TEXT"><div name="-8095658" id="-8095658">jismoniy tarbiya va sport tashkilotlarini tashkil etishga koʻmaklashadi hamda ularning faoliyatini qoʻllab-quvvatlaydi;</div></div><div class="ACT_TEXT"><div name="-8095659" id="-8095659">jismoniy tarbiya va sport sohasidagi davlat-xususiy sheriklikni rivojlantirishga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095660" id="-8095660">aholini jismoniy tarbiya va sportga jalb etish ishlarini tashkil etadi;</div></div><div class="ACT_TEXT"><div name="-8095661" id="-8095661">jismoniy tarbiya va sport tadbirlarini tashkil etish hamda oʻtkazishga, jismoniy tarbiya va sport sohasidagi mutaxassislarni tayyorlash, qayta tayyorlash va ularning malakasini oshirishga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095662" id="-8095662">jismoniy tarbiya va sportni rivojlantirish uchun fuqarolarning ish joyi, yashash joyi hamda dam olish joyida shart-sharoitlar yaratadi;</div></div><div class="ACT_TEXT"><div name="-8095663" id="-8095663">jismoniy tarbiya-sogʻlomlashtirish va sport uchun moʻljallangan tovarlar ishlab chiqarilishini, sohaga oid xizmatlar rivojlantirilishini tashkil etishga koʻmaklashadi.</div></div><div class="ACT_TEXT"><div name="-8095664" id="-8095664">Mahalliy davlat hokimiyati organlari qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095665" id="-8095665">13-modda. Fuqarolarning, fuqarolar oʻzini oʻzi boshqarish organlarining, nodavlat notijorat tashkilotlarining hamda fuqarolik jamiyati boshqa institutlarining jismoniy tarbiya va sport sohasidagi tadbirlarda ishtirok etishi</div></div><div class="ACT_TEXT"><div name="-8095666" id="-8095666">Fuqarolar, fuqarolarning oʻzini oʻzi boshqarish organlari, nodavlat notijorat tashkilotlari hamda fuqarolik jamiyatining boshqa institutlari:</div></div><div class="ACT_TEXT"><div name="-8095667" id="-8095667">jismoniy tarbiya va sport sohasidagi davlat dasturlarini, hududiy dasturlarni hamda boshqa dasturlarni amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095668" id="-8095668">jismoniy tarbiya va sport sohasidagi jamoatchilik nazoratini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095669" id="-8095669">jismoniy tarbiya va sportni rivojlantirishga, aholi oʻrtasida sogʻlom turmush tarzini shakllantirishga qaratilgan tushuntirish ishlarini amalga oshirishda ishtirok etadi.</div></div><div class="ACT_TEXT"><div name="-8095670" id="-8095670">Fuqarolar, fuqarolarning oʻzini oʻzi boshqarish organlari, nodavlat notijorat tashkilotlari hamda fuqarolik jamiyatining boshqa institutlari jismoniy tarbiya va sport sohasidagi boshqa tadbirlarda ham ishtirok etishi mumkin.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8095671" id="-8095671"><b>3-bob. Jismoniy tarbiya va sport sohasidagi faoliyatni tashkil etish</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8095672" id="-8095672">14-modda. Jismoniy tarbiya va sport sohasidagi mutaxassislar</div></div><div class="ACT_TEXT"><div name="-8095673" id="-8095673">Sportchilar, trenerlar, sport hakamlari hamda Oʻzbekiston Respublikasi Kambagʻallikni qisqartirish va bandlik vazirligi tomonidan vakolatli davlat organi bilan birgalikda kasblari va lavozimlarining tasniflangan roʻyxati belgilanadigan boshqa mutaxassislar jismoniy tarbiya va sport sohasidagi mutaxassislardir.</div></div><div class="ACT_TEXT"><div name="-8095674" id="-8095674">Sportchi, trener va sport hakami kasblari va lavozimlariga doir malaka talablari vakolatli davlat organi tomonidan belgilanadi, jismoniy tarbiya va sport sohasidagi boshqa mutaxassislarning kasblari va lavozimlariga doir malaka talablari qonunchilikka muvofiq belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095675" id="-8095675">15-modda. Havaskorlik sporti va professional sport</div></div><div class="ACT_TEXT"><div name="-8095676" id="-8095676">Fuqarolar havaskorlik sporti, shuningdek professional sport bilan sportchi, trener, sport hakami sifatida shugʻullanish yoki qonunchilikda taqiqlanmagan jismoniy tarbiya va sport sohasiga oid boshqa faoliyat turlari bilan shugʻullanish huquqiga ega.</div></div><div class="ACT_TEXT"><div name="-8095677" id="-8095677">Havaskorlik sporti va professional sport sohasidagi korxonalar, muassasalar va tashkilotlarning tashkil etilishi hamda faoliyat koʻrsatishi tartibi qonunchilikda belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095678" id="-8095678">16-modda. Ommaviy sport musobaqalari</div></div><div class="ACT_TEXT"><div name="-8095679" id="-8095679">Ommaviy sport musobaqalari aholini ommaviy sportga jalb etish maqsadida “Besh tashabbus olimpiadasi”, “Besh tashabbus paralimpiadasi” va boshqa ommaviy sport tadbirlari shaklida oʻtkazib boriladi.</div></div><div class="ACT_TEXT"><div name="-8095680" id="-8095680">Ommaviy sport musobaqalari vakolatli davlat organi bilan kelishilgan holda ushbu musobaqalar tashkilotchilari tomonidan belgilanadigan tartib asosida oʻtkaziladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095681" id="-8095681">17-modda. Sport sinovlari</div></div><div class="ACT_TEXT"><div name="-8095682" id="-8095682">Sport sinovlari aholi oʻrtasida jismoniy tarbiya va sportni ommalashtirish hamda aholining jismoniy faolligini baholash maqsadida oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-8095683" id="-8095683">Sport sinovlari natijalari vakolatli davlat organining axborot tizimiga kiritib boriladi.</div></div><div class="ACT_TEXT"><div name="-8095684" id="-8095684">Sport sinovlarini oʻtkazish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095685" id="-8095685">18-modda. Oʻzbekiston olimpiya harakati. Oʻzbekiston Milliy olimpiya qoʻmitasi</div></div><div class="ACT_TEXT"><div name="-8095686" id="-8095686">Oʻzbekiston olimpiya harakati Xalqaro olimpiya harakatining tarkibiy qismi boʻlib, uning maqsadi olimpiya harakati prinsiplarini ommalashtirishdan, jismoniy tarbiya va sportni rivojlantirishga koʻmaklashishdan, sport sohasidagi xalqaro hamkorlikni mustahkamlashdan, Olimpiya oʻyinlarida hamda Xalqaro olimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etishdan iboratdir.</div></div><div class="ACT_TEXT"><div name="-8095687" id="-8095687">Oʻzbekiston olimpiya harakati oʻz faoliyatini Oʻzbekiston Respublikasining qonunchiligiga, Xalqaro olimpiya qoʻmitasining Olimpiya xartiyasiga hamda oʻz ustaviga muvofiq amalga oshiruvchi Oʻzbekiston Milliy olimpiya qoʻmitasi tomonidan boshqariladi. Davlat Oʻzbekiston Milliy olimpiya qoʻmitasiga oʻz ustavida belgilangan maqsadlarini amalga oshirishiga har tomonlama koʻmaklashgan holda, Oʻzbekiston olimpiya harakatini tan oladi va qoʻllab-quvvatlaydi.</div></div><div class="ACT_TEXT"><div name="-8095688" id="-8095688">Oʻzbekiston Milliy olimpiya qoʻmitasi:</div></div><div class="ACT_TEXT"><div name="-8095689" id="-8095689">olimpiya harakati prinsiplarini ommalashtiradi, yuksak yutuqlarga erishiladigan sportni va ommaviy sportni rivojlantirishga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095690" id="-8095690">Xalqaro olimpiya qoʻmitasining Olimpiya xartiyasiga muvofiq Olimpiya oʻyinlarida hamda Xalqaro Olimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida Oʻzbekiston Respublikasining manfaatlarini ifoda etadi;</div></div><div class="ACT_TEXT"><div name="-8095691" id="-8095691">sportchilarni Olimpiya oʻyinlarida hamda Xalqaro Olimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etishga tayyorlashning zarur darajasini taʼminlashga qaratilgan dasturlarni va chora-tadbirlarni ishlab chiqish hamda amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095692" id="-8095692">sportda dopingning oldini olishga hamda unga qarshi kurashishga, shuningdek jismoniy tarbiya va sport sohasida har qanday shakldagi kamsitishlar va zoʻravonliklarning yuzaga kelishiga yoʻl qoʻymaslikka koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095693" id="-8095693">Xalqaro olimpiya qoʻmitasining hamda Oʻzbekiston Milliy olimpiya qoʻmitasining olimpiya ramzlaridan, shioridan, bayrogʻidan, madhiyasidan, “olimpiya”, “olimpiada” degan nomlardan foydalanishga boʻlgan huquqlarini Oʻzbekiston Respublikasi hududida himoya qilish choralarini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-8095694" id="-8095694">Oʻzbekiston Milliy olimpiya qoʻmitasi oʻz vakolatlarini vakolatli davlat organi, sport federatsiyalari (uyushmalari) hamda boshqa tashkilotlar bilan hamkorlikda amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-8095695" id="-8095695">Olimpiya oʻyinlarida va Xalqaro olimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida Oʻzbekiston Respublikasi sport terma jamoalarining chiqishlari Oʻzbekiston Respublikasi Davlat bayrogʻi ostida oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-8095696" id="-8095696">Oʻzbekiston Milliy olimpiya qoʻmitasi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095697" id="-8095697">19-modda. Oʻzbekiston paralimpiya harakati. Oʻzbekiston Milliy paralimpiya qoʻmitasi</div></div><div class="ACT_TEXT"><div name="-8095698" id="-8095698">Oʻzbekiston paralimpiya harakati Xalqaro paralimpiya harakatining tarkibiy qismi boʻlib, uning maqsadi paralimpiya harakati prinsiplarini ommalashtirishdan, nogironligi boʻlgan shaxslar oʻrtasida jismoniy tarbiya va sportni rivojlantirishga koʻmaklashishdan, sport sohasidagi xalqaro hamkorlikni mustahkamlashdan, Paralimpiya oʻyinlarida hamda Xalqaro paralimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etishdan iboratdir.</div></div><div class="ACT_TEXT"><div name="-8095699" id="-8095699">Oʻzbekiston paralimpiya harakati oʻz faoliyatini Oʻzbekiston Respublikasi qonunchiligiga, Xalqaro paralimpiya qoʻmitasining Paralimpiya xartiyasiga hamda oʻz ustaviga muvofiq amalga oshiruvchi Oʻzbekiston Milliy paralimpiya qoʻmitasi tomonidan boshqariladi. Davlat Oʻzbekiston Milliy paralimpiya qoʻmitasiga oʻz ustavida belgilangan maqsadlarini amalga oshirishiga har tomonlama koʻmaklashgan holda, Oʻzbekiston paralimpiya harakatini tan oladi va qoʻllab-quvvatlaydi.</div></div><div class="ACT_TEXT"><div name="-8095700" id="-8095700">Oʻzbekiston Milliy paralimpiya qoʻmitasi:</div></div><div class="ACT_TEXT"><div name="-8095701" id="-8095701">paralimpiya harakati prinsiplarini ommalashtiradi, yuksak yutuqlarga erishiladigan sportning paralimpiya turlarini hamda nogironligi boʻlgan shaxslar oʻrtasida ommaviy sportni rivojlantirishga koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095702" id="-8095702">Xalqaro paralimpiya qoʻmitasining Paralimpiya xartiyasiga muvofiq Paralimpiya oʻyinlarida hamda Xalqaro paralimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida Oʻzbekiston Respublikasining manfaatlarini ifoda etadi;</div></div><div class="ACT_TEXT"><div name="-8095703" id="-8095703">sportchilarni Paralimpiya oʻyinlarida hamda Xalqaro paralimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etish uchun tayyorlashning zarur darajasini taʼminlashga qaratilgan chora-tadbirlarni ishlab chiqish va amalga oshirishda ishtirok etadi;</div></div><div class="ACT_TEXT"><div name="-8095704" id="-8095704">sportning paralimpiya turlari boʻyicha dopingning oldini olishga hamda unga qarshi kurashishga, shuningdek jismoniy tarbiya va sport sohasida har qanday shakldagi kamsitishlar va zoʻravonliklarning yuzaga kelishiga yoʻl qoʻymaslikka koʻmaklashadi;</div></div><div class="ACT_TEXT"><div name="-8095705" id="-8095705">Xalqaro paralimpiya qoʻmitasining hamda Oʻzbekiston Milliy paralimpiya qoʻmitasining paralimpiya ramzlaridan, shioridan, bayrogʻidan, madhiyasidan, “paralimpiya”, “paralimpiada” degan nomlardan foydalanishga boʻlgan huquqlarini Oʻzbekiston Respublikasi hududida himoya qilish choralarini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-8095706" id="-8095706">Oʻzbekiston Milliy paralimpiya qoʻmitasi oʻz vakolatlarini vakolatli davlat organi, sport federatsiyalari (uyushmalari) hamda boshqa tashkilotlar bilan hamkorlikda amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-8095707" id="-8095707">Paralimpiya oʻyinlarida va Xalqaro paralimpiya qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida Oʻzbekiston Respublikasi sport terma jamoalarining chiqishlari Oʻzbekiston Respublikasi Davlat bayrogʻi ostida oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-8095708" id="-8095708">Oʻzbekiston Milliy paralimpiya qoʻmitasi qonunchilikka muvofiq boshqa vakolatlarni ham amalga oshirishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095709" id="-8095709">20-modda. Surdlimpiya, maxsus olimpiya, koʻzi ojizlar sporti va boshqa adaptiv sport turlari</div></div><div class="ACT_TEXT"><div name="-8095710" id="-8095710">Oʻzbekiston surdlimpiya harakati Xalqaro surdlimpiya harakatining tarkibiy qismi boʻlib, uning maqsadi surdlimpiya harakati prinsiplarini ommalashtirishdan, nogironligi boʻlgan shaxslar oʻrtasida jismoniy tarbiya va sportni rivojlantirishga koʻmaklashishdan, sport sohasidagi xalqaro hamkorlikni mustahkamlashdan, Surdlimpiya oʻyinlarida hamda Xalqaro karlar sporti qoʻmitasi shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etishdan iboratdir.</div></div><div class="ACT_TEXT"><div name="-8095711" id="-8095711">Oʻzbekiston maxsus olimpiya harakati Xalqaro maxsus olimpiya harakatining tarkibiy qismi boʻlib, uning maqsadi maxsus olimpiya harakati prinsiplarini ommalashtirishdan, nogironligi boʻlgan shaxslar oʻrtasida jismoniy tarbiya va sportni rivojlantirishga koʻmaklashishdan, sport sohasida xalqaro hamkorlikni mustahkamlashdan, xalqaro maxsus olimpiya oʻyinlarida hamda tegishli xalqaro sport tashkilotlari shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etishdan iboratdir.</div></div><div class="ACT_TEXT"><div name="-8095712" id="-8095712">Oʻzbekiston koʻzi ojizlar sporti harakati Xalqaro koʻzi ojizlar sporti harakatining tarkibiy qismi boʻlib, uning maqsadi koʻzi ojizlar sporti harakati prinsiplarini ommalashtirishdan, koʻzi ojiz shaxslar oʻrtasida jismoniy tarbiya va sportni rivojlantirishga koʻmaklashishdan, sport sohasida xalqaro hamkorlikni mustahkamlashdan, xalqaro koʻzi ojizlar sporti musobaqalarida hamda tegishli xalqaro sport tashkilotlari shafeligida oʻtkaziladigan boshqa xalqaro sport tadbirlarida ishtirok etishdan iboratdir.</div></div><div class="ACT_TEXT"><div name="-8095713" id="-8095713">Surdlimpiya, maxsus olimpiya, koʻzi ojizlar sporti va boshqa adaptiv sport turlarini rivojlantirish Oʻzbekiston adaptiv sport turlari assotsiatsiyasi hamda sportning surdlimpiya, maxsus olimpiya va koʻzi ojizlar sporti turlari boʻyicha nodavlat notijorat tashkilotlari tomonidan tashkil etiladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095714" id="-8095714">21-modda. Sport federatsiyalari (uyushmalari)</div></div><div class="ACT_TEXT"><div name="-8095715" id="-8095715">Sport federatsiyasi (uyushmasi) mamlakatda muayyan sport turini (turlarini) rivojlantirish, ommalashtirish, sport tadbirlarini tashkil etish va oʻtkazish, tegishli sport turi (turlari) boʻyicha sportchilarni tayyorlash ishlarini amalga oshiradi, xalqaro miqyosdagi barcha sport musobaqalari va tadbirlarida Oʻzbekiston Respublikasi manfaatlarini ifoda etadi.</div></div><div class="ACT_TEXT"><div name="-8095716" id="-8095716">Sport federatsiyasi (uyushmasi) oʻzi rivojlantiradigan sport turi (turlari) boʻyicha Oʻzbekiston Respublikasining chempionatlari va kuboklari musobaqalari oʻtkazib borilishini tashkil etadi.</div></div><div class="ACT_TEXT"><div name="-8095717" id="-8095717">Sport federatsiyasining (uyushmasining) rasmiy nomi nodavlat notijorat tashkilotlari toʻgʻrisidagi qonunchilikda belgilangan talablarga muvofiq boʻlishi hamda unda sport federatsiyasi (uyushmasi) faoliyatining hududiy sohasi, shuningdek sport federatsiyasi (uyushmasi) qaysi sport turini (turlarini) rivojlantirish maqsadida tashkil etilgan boʻlsa, oʻsha sport turi (turlari) koʻrsatilishi lozim.</div></div><div class="ACT_TEXT"><div name="-8095718" id="-8095718">Sport federatsiyalarining (uyushmalarining) tashkil etilishi, faoliyati, qayta tashkil etilishi va tugatilishi, ushbu Qonunda nazarda tutilgan oʻziga xos xususiyatlar inobatga olingan holda, nodavlat notijorat tashkilotlari toʻgʻrisidagi qonunchilikka muvofiq amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095719" id="-8095719">22-modda. Sport federatsiyalari (uyushmalari) reyestri</div></div><div class="ACT_TEXT"><div name="-8095720" id="-8095720">Sport federatsiyalari (uyushmalari) reyestri vakolatli davlat organi tomonidan yuritiladi.</div></div><div class="ACT_TEXT"><div name="-8095721" id="-8095721">Quyidagi mezonlarga muvofiq boʻlgan nodavlat notijorat tashkilotlari belgilangan tartibda Sport federatsiyalari (uyushmalari) reyestriga kiritiladi:</div></div><div class="ACT_TEXT"><div name="-8095722" id="-8095722">ularning rivojlantiradigan sport turi (turlari) boʻyicha xalqaro sport tashkilotiga aʼzo ekanligi (bundan milliy va adaptiv sport turlari mustasno);</div></div><div class="ACT_TEXT"><div name="-8095723" id="-8095723">ular rivojlantiradigan sport turi (turlari) boʻyicha sport turi qoidalarining mavjudligi;</div></div><div class="ACT_TEXT"><div name="-8095724" id="-8095724">ularning Sport federatsiyalari (uyushmalari) reyestriga kiritilgan sport federatsiyalari (uyushmalari) nomlaridan farqlanadigan nomga ega ekanligi;</div></div><div class="ACT_TEXT"><div name="-8095725" id="-8095725">ular rivojlantiradigan sport turining (turlarining) boshqa sport turi (turlari) belgilaridan farqlanishi;</div></div><div class="ACT_TEXT"><div name="-8095726" id="-8095726">ular rivojlantiradigan sport turi (turlari) boʻyicha Sport federatsiyalari (uyushmalari) reyestriga boshqa sport federatsiyasi (uyushmasi) kiritilmaganligi.</div></div><div class="ACT_TEXT"><div name="-8095727" id="-8095727">Sport federatsiyalari (uyushmalari) reyestriga, istisno tariqasida, Oʻzbekiston Respublikasi Prezidenti va Oʻzbekiston Respublikasi Vazirlar Mahkamasining hujjatlari bilan sport turini (turlarini) yoki sportning alohida yoʻnalishlarini rivojlantirishi belgilangan sport federatsiyalari (uyushmalari) toʻgʻridan-toʻgʻri kiritiladi. Bunda sport federatsiyalarini (uyushmalarini) reyestrdan chiqarish boʻyicha qoidalar mazkur qismda koʻrsatib oʻtilgan sport federatsiyalariga (uyushmalariga) nisbatan tatbiq etilmaydi.</div></div><div class="ACT_TEXT"><div name="-8095728" id="-8095728">Sport federatsiyalari (uyushmalari) reyestrida quyidagi maʼlumotlar koʻrsatiladi:</div></div><div class="ACT_TEXT"><div name="-8095729" id="-8095729">sport federatsiyalarining (uyushmalarining) nomlari;</div></div><div class="ACT_TEXT"><div name="-8095730" id="-8095730">sport federatsiyalari (uyushmalari) tomonidan rivojlantiriladigan sport turi (turlari);</div></div><div class="ACT_TEXT"><div name="-8095731" id="-8095731">sport federatsiyalari (uyushmalari) rahbar organlarining shaxsiy tarkibi toʻgʻrisidagi maʼlumotlar;</div></div><div class="ACT_TEXT"><div name="-8095732" id="-8095732">sport federatsiyalarining (uyushmalarining) xalqaro sport tashkilotiga aʼzoligi toʻgʻrisidagi maʼlumotlar.</div></div><div class="ACT_TEXT"><div name="-8095733" id="-8095733">Sport federatsiyalari (uyushmalari) reyestrida koʻrsatilgan maʼlumotlar ochiq boʻladi va vakolatli davlat organining axborot tizimiga joylashtiriladi.</div></div><div class="ACT_TEXT"><div name="-8095734" id="-8095734">Sport federatsiyalari (uyushmalari) reyestriga vakolatli davlat organi tomonidan belgilangan tartibda boshqa maʼlumotlar ham kiritilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095735" id="-8095735">23-modda. Sport federatsiyalarining (uyushmalarining) huquq va majburiyatlari</div></div><div class="ACT_TEXT"><div name="-8095736" id="-8095736">Sport federatsiyalari (uyushmalari) quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-8095737" id="-8095737">sport turini yoki sport turining tarmogʻini Sport turlari reyestriga kiritish yuzasidan taklif kiritish;</div></div><div class="ACT_TEXT"><div name="-8095738" id="-8095738">sport turi (turlari) boʻyicha Oʻzbekiston Respublikasi sport terma jamoalarining xalqaro sport musobaqalarida ishtirok etishini tashkil etish;</div></div><div class="ACT_TEXT"><div name="-8095739" id="-8095739">sport turini (turlarini) rivojlantirish uchun qonunchilik hujjatlarida taqiqlanmagan turli manbalardan moliyaviy va boshqa turdagi yordam olish.</div></div><div class="ACT_TEXT"><div name="-8095741" id="-8095741">Sport federatsiyalari (uyushmalari) qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095742" id="-8095742">Sport federatsiyalari (uyushmalari):</div></div><div class="ACT_TEXT"><div name="-8095743" id="-8095743">sport turini (turlarini) rivojlantirishi va ommalashtirishi;</div></div><div class="ACT_TEXT"><div name="-8095744" id="-8095744">sport turi (turlari) boʻyicha sport turlari qoidalarini vakolatli davlat organiga davlat tilida taqdim etishi hamda oʻz rasmiy veb-saytida joylashtirishi;</div></div><div class="ACT_TEXT"><div name="-8095745" id="-8095745">sport turini (turlarini) rivojlantirish boʻyicha kompleks maqsadli dasturlarni ishlab chiqishi;</div></div><div class="ACT_TEXT"><div name="-8095746" id="-8095746">sportchilar, trenerlar va oʻtkazilayotgan sport musobaqalari toʻgʻrisidagi maʼlumotlarni vakolatli davlat organining axborot tizimiga kiritib borishi;</div></div><div class="ACT_TEXT"><div name="-8095747" id="-8095747">sport turini (turlarini) rivojlantirish va ommalashtirish boʻyicha amalga oshirilayotgan chora-tadbirlar toʻgʻrisidagi hisobotlarni vakolatli davlat organiga taqdim etishi;</div></div><div class="ACT_TEXT"><div name="-8095748" id="-8095748">sport turi (turlari) boʻyicha Oʻzbekiston Respublikasining sport terma jamoalarini shakllantirish, shuningdek sport va ommaviy jismoniy tarbiya tadbirlarining kalendar rejasini shakllantirish boʻyicha vakolatli davlat organiga belgilangan tartibda takliflar kiritib borishi;</div></div><div class="ACT_TEXT"><div name="-8095749" id="-8095749">sport turi (turlari) boʻyicha har qanday shakldagi kamsitishlar va zoʻravonliklarga yoʻl qoʻymasligi;</div></div><div class="ACT_TEXT"><div name="-8095750" id="-8095750">antidoping qoidalariga muvofiq dopingning oldini olishi va unga qarshi kurashish choralarini koʻrishi shart.</div></div><div class="ACT_TEXT"><div name="-8095751" id="-8095751">Sport federatsiyalarining (uyushmalarining) zimmasiga qonunchilikka muvofiq boshqa majburiyatlar ham yuklatilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095752" id="-8095752">24-modda. Jismoniy tarbiya va sport sohasidagi faoliyat. Nodavlat jismoniy tarbiya va sport tashkilotlari reyestri</div></div><div class="ACT_TEXT"><div name="-8095753" id="-8095753">Jismoniy tarbiya va sport sohasidagi faoliyat jismoniy tarbiya va sport tashkilotlari, yakka tartibdagi tadbirkorlar, oʻzini oʻzi band qilgan trenerlar hamda boshqa jismoniy va yuridik shaxslar tomonidan amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095754" id="-8095754">Jismoniy tarbiya va sport tashkilotlari xalqaro sport tashkilotlarining aʼzosi boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095755" id="-8095755">Jismoniy tarbiya va sport tashkilotlari chet davlatlarning sport tashkilotlari bilan munosabatlarda xalqaro sport tashkilotlari tomonidan tasdiqlangan qoidalarga (nizomlarga, reglamentlarga) va Oʻzbekiston Respublikasining xalqaro shartnomalariga rioya etadi.</div></div><div class="ACT_TEXT"><div name="-8095756" id="-8095756">Vakolatli davlat organi tomonidan Nodavlat jismoniy tarbiya va sport tashkilotlari reyestri yuritiladi.</div></div><div class="ACT_TEXT"><div name="-8095757" id="-8095757">Nodavlat jismoniy tarbiya va sport tashkilotlari reyestriga sport klublari, sport taʼlim tashkilotlari, jismoniy tarbiya va sport sohasida faoliyat yurituvchi boshqa yuridik shaxslar va yakka tartibdagi tadbirkorlar hamda oʻzini oʻzi band qilgan trenerlar kiritiladi.</div></div><div class="ACT_TEXT"><div name="-8095758" id="-8095758">Nodavlat jismoniy tarbiya va sport tashkilotlari reyestriga kiritilgan jismoniy va yuridik shaxslar rasmiy sport musobaqalarida oʻz nomidan ishtirok etishi, shuningdek Oʻzbekiston Respublikasining sport terma jamoalariga nomzod berishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095759" id="-8095759">Nodavlat jismoniy tarbiya va sport tashkilotlari reyestrini shakllantirish, yuritish hamda reyestrdan chiqarish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095760" id="-8095760">25-modda. Sport klubi</div></div><div class="ACT_TEXT"><div name="-8095761" id="-8095761">Sport klubi sport faoliyati bilan shugʻullanish, sport turlarini rivojlantirish va ommalashtirish, shuningdek sportchilarni musobaqalarga tayyorlash maqsadida tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-8095762" id="-8095762">Sport klubi, idoraviy mansubligi va mulkchilik shaklidan qatʼi nazar, yuridik shaxs maqomi bilan yoki yuridik shaxs maqomisiz tashkil etilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095763" id="-8095763">Yuridik shaxs maqomiga ega boʻlgan sport klubi qonunchilikka muvofiq davlat roʻyxatidan oʻtkaziladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095764" id="-8095764">26-modda. Sport ligasi</div></div><div class="ACT_TEXT"><div name="-8095765" id="-8095765">Sport ligasi sport musobaqalarini tashkil etish, oʻtkazish va boshqarish faoliyatini amalga oshirish maqsadida, idoraviy mansubligi hamda mulkchilik shaklidan qatʼi nazar, yuridik shaxs maqomi bilan yoki yuridik shaxs maqomisiz tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-8095766" id="-8095766">Yuridik shaxs maqomiga ega boʻlgan sport ligasi qonunchilikka muvofiq davlat roʻyxatidan oʻtkaziladi.</div></div><div class="ACT_TEXT"><div name="-8095767" id="-8095767">Sport ligasi sport turi (turlari) boʻyicha professional sport musobaqalarini tashkil etish hamda oʻtkazish uchun professional sport musobaqasini tashkil etish va oʻtkazish qoidalarini (nizomini, reglamentini) qonunchilikda belgilangan tartibda tasdiqlaydi.</div></div><div class="ACT_TEXT"><div name="-8095769" id="-8095769">Professional sport musobaqasini tashkil etish va oʻtkazish qoidalari (nizomi, reglamenti) ochiq maʼlumot sifatida sport ligasining Internetdagi rasmiy veb-saytiga joylashtiriladi. Bunda mazkur qoidalar (nizom, reglament) qonunchilikka muvofiq boʻlishi kerak.</div></div><div class="ACT_TEXT"><div name="-8095770" id="-8095770">Sport ligasining faoliyat yuritish tartibi, shuningdek sport ligalari tomonidan professional sport musobaqalarini tashkil etish va oʻtkazish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095771" id="-8095771">27-modda. Oʻzbekiston milliy sport turlari va xalq oʻyinlari</div></div><div class="ACT_TEXT"><div name="-8095772" id="-8095772">Oʻzbekiston milliy sport turlari va xalq oʻyinlari milliy ijtimoiy-madaniy yoʻnalishga ega boʻlgan hamda Oʻzbekiston Respublikasi hududida rivojlanayotgan sport va oʻyin turlaridir.</div></div><div class="ACT_TEXT"><div name="-8095773" id="-8095773">Oʻzbekiston milliy sport turlari va xalq oʻyinlari Oʻzbekiston Respublikasining jismoniy tarbiya va sport sohasidagi madaniy merosining ajralmas qismi, aholida vatanparvarlik va Vatanga muhabbat, xalqaro maydonda mamlakatning obroʻ-eʼtiborini yuksaltirishga intilish tuygʻularini tarbiyalash poydevoridir.</div></div><div class="ACT_TEXT"><div name="-8095774" id="-8095774">Davlat organlari, fuqarolarning oʻzini oʻzi boshqarish organlari, jismoniy tarbiya va sport tashkilotlari, shuningdek boshqa tashkilotlar:</div></div><div class="ACT_TEXT"><div name="-8095775" id="-8095775">Oʻzbekiston milliy sport turlarini va xalq oʻyinlarini rivojlantirishga har tomonlama koʻmaklashadi hamda ularni aholi oʻrtasida yoyish uchun zarur shart-sharoitlar yaratadi;</div></div><div class="ACT_TEXT"><div name="-8095776" id="-8095776">Oʻzbekiston milliy sport turlarining va xalq oʻyinlarining xalqaro maydondagi obroʻ-eʼtiborini mustahkamlashga koʻmaklashadi.</div></div><div class="ACT_TEXT"><div name="-8095777" id="-8095777">Oʻzbekiston milliy sport turlarini va xalq oʻyinlarini Sport va ommaviy jismoniy tarbiya tadbirlarining kalendar rejasiga kiritish tartibi qonunchilikda belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095778" id="-8095778">28-modda. Jismoniy tarbiya va sport tadbirlarini tashkil etish hamda oʻtkazish</div></div><div class="ACT_TEXT"><div name="-8095779" id="-8095779">Jismoniy tarbiya yoki sport tadbirlari tashkilotchilari bu tadbirlarni oʻtkazish shartlarini, shu jumladan jismoniy tarbiya va sport tadbirlarini tashkil etish hamda oʻtkazishni moliyalashtirish shartlarini belgilaydi, bunday tadbirlarni tashkil etish va oʻtkazish uchun masʼul boʻladi.</div></div><div class="ACT_TEXT"><div name="-8095780" id="-8095780">Jismoniy tarbiya va sport tadbirlari tashkilotchilari quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-8095781" id="-8095781">jismoniy tarbiya va sport tadbirining nomi va ramzlaridan foydalanish;</div></div><div class="ACT_TEXT"><div name="-8095782" id="-8095782">jismoniy tarbiya va sport tadbirlarini oʻtkazish joyida tovarlar, ishlar va xizmatlar reklamasini joylashtirish;</div></div><div class="ACT_TEXT"><div name="-8095783" id="-8095783">jismoniy tarbiya va sport tadbirlarida foydalaniladigan sport ekipirovkasi, sport uskunalari va anjomlarini ishlab chiqaruvchilarni belgilash;</div></div><div class="ACT_TEXT"><div name="-8095784" id="-8095784">jismoniy tarbiya va sport tadbirlarini yoritish;</div></div><div class="ACT_TEXT"><div name="-8095785" id="-8095785">jismoniy tarbiya va (yoki) sport tadbirini toʻxtatish va bekor qilish, ularni oʻtkazish vaqtini oʻzgartirish hamda ularning yakunlarini tasdiqlash.</div></div><div class="ACT_TEXT"><div name="-8095786" id="-8095786">Jismoniy tarbiya va sport tadbirlarining nomlaridan, ular asosida tuzilgan soʻz birikmalaridan hamda mazkur tadbirlar ramzlaridan uchinchi shaxslarning foydalanishi jismoniy tarbiya va sport tadbirlari tashkilotchilari bilan yozma shaklda tuziladigan kelishuvlar asosida amalga oshiriladi, bundan ushbu nomlardan, ular asosida tuzilgan soʻz birikmalaridan va mazkur tadbirlar ramzlaridan axborot maqsadida yoxud ommaviy axborot vositalarida jismoniy tarbiya va sport tadbirlarini yoritish huquqini olgan uchinchi shaxslar tomonidan ushbu huquqlardan foydalanish hollari mustasno.</div></div><div class="ACT_TEXT"><div name="-8095787" id="-8095787">Ommaviy axborot vositalarida jismoniy tarbiya va sport tadbirlarining jismoniy tarbiya yoki sport tadbirlari tashkilotchilari tomonidan tasdiqlangan, toʻgʻri koʻrsatilgan nomlaridan foydalanilishi kerak. Bunda mazkur nomlar reklama hisoblanmaydi.</div></div><div class="ACT_TEXT"><div name="-8095788" id="-8095788">Jismoniy tarbiya va sport tadbirlarini yoritish huquqidan uchinchi shaxslar faqat jismoniy tarbiya yoki sport tadbirlari tashkilotchilarining yozma ruxsatlari bilan yoxud uchinchi shaxslar tomonidan ushbu huquqlarning bunday tadbirlar tashkilotchilaridan sotib olinganligi toʻgʻrisidagi yozma shakldagi kelishuvlar asosida foydalanishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095789" id="-8095789">Jismoniy tarbiya va sport tadbirlari toʻgʻrisidagi qoidalarning (nizomlarning, reglamentlarning) mazmuniga nisbatan qoʻyiladigan umumiy talablar vakolatli davlat organi tomonidan belgilanadi.</div></div><div class="ACT_TEXT"><div name="-8095790" id="-8095790">Faqat rasmiy sport musobaqalari Oʻzbekiston Respublikasi chempionati yoki kubogi maqomiga hamda nomiga ega boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095791" id="-8095791">Rasmiy sport musobaqalarini oʻtkazishga faqat ushbu Qonunning <a href="https://lex.uz/docs/-8093787#-8095801">30-moddasiga</a> muvofiq tasdiqlangan sport turlari qoidalariga asosan yoʻl qoʻyiladi.</div></div><div class="ACT_TEXT"><div name="-8095792" id="-8095792">Oʻzbekiston Respublikasi hududida xalqaro sport tadbirlari tegishli sport federatsiyasi (uyushmasi) hamda vakolatli davlat organi bilan kelishilgan holda oʻtkazilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095793" id="-8095793">29-modda. Sport turlarini va sport turining tarmoqlarini eʼtirof etish. Sport turlarining reyestri</div></div><div class="ACT_TEXT"><div name="-8095794" id="-8095794">Oʻzbekiston Respublikasida belgilangan tartibda eʼtirof etilgan sport turlari va sport turining tarmoqlari Sport turlari reyestriga kiritiladi.</div></div><div class="ACT_TEXT"><div name="-8095795" id="-8095795">Sport turini yoki sport turining tarmogʻini eʼtirof etish uchun u sport turiga yoki sport turining tarmogʻiga mos belgiga, sport turi qoidalariga, mashgʻulot oʻtkazishning oʻziga xos xususiyatlari va uslubiyatiga, sport infratuzilmasiga, foydalaniladigan sport anjomlari va jihozlariga ega boʻlishi hamda sport mashgʻulotlari va sport musobaqalarini oʻtkazish talablariga javob beradigan sport infratuzilmasi mavjud boʻlishi, shuningdek sportchilarning ishtirok etishiga, odamning jismoniy va aqliy rivojlanish qobiliyatini hamda harakat faolligini takomillashtirishga, sogʻlom turmush tarzini shakllantirishga xizmat qilishi kerak.</div></div><div class="ACT_TEXT"><div name="-8095796" id="-8095796">Sport turini yoki sport turining tarmogʻini eʼtirof etish ushbu sport turi yoki sport turining tarmogʻi maʼmuriy-hududiy birliklarning (Qoraqalpogʻiston Respublikasi, viloyatlar va Toshkent shahri) kamida yettitasida rivojlangan boʻlishi kerak, bundan vakolatli davlat organi tomonidan belgilangan sport turlari yoki sport turining tarmoqlari mustasno.</div></div><div class="ACT_TEXT"><div name="-8095797" id="-8095797">Sport turlarini yoki sport turining tarmoqlarini eʼtirof etish sport federatsiyalarining (uyushmalarining), jismoniy tarbiya va sport tashkilotlarining arizasi asosida vakolatli davlat organi tomonidan amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095798" id="-8095798">Olimpiya va Paralimpiya oʻyinlari dasturiga kiritilgan sport turlarini yoki sport turining tarmoqlarini, shuningdek Oʻzbekiston Respublikasi Prezidenti va Oʻzbekiston Respublikasi Vazirlar Mahkamasining hujjatlarida nazarda tutilgan hollarda sport turlarini yoki sport turining tarmoqlarini eʼtirof etish vakolatli davlat organi tomonidan, istisno tariqasida, toʻgʻridan-toʻgʻri eʼtirof etiladi va Sport turlari reyestriga kiritiladi.</div></div><div class="ACT_TEXT"><div name="-8095799" id="-8095799">Gʻayriinsoniy va inson qadr-qimmatini kamsituvchi sport turlari yoki sport turining tarmoqlari Oʻzbekiston Respublikasida sport turlari yoki sport turining tarmoqlari sifatida eʼtirof etilishi mumkin emas.</div></div><div class="ACT_TEXT"><div name="-8095800" id="-8095800">Sport turlari reyestri vakolatli davlat organi tomonidan yuritiladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095801" id="-8095801">30-modda. Sport turlari qoidalari</div></div><div class="ACT_TEXT"><div name="-8095802" id="-8095802">Sport turlari reyestriga kiritilgan sport turlarining qoidalari xalqaro sport tashkilotlari tomonidan tasdiqlangan qoidalarga muvofiq qoʻllaniladi, bundan harbiy-amaliy, Oʻzbekiston milliy sport turlari va xalq oʻyinlari mustasno.</div></div><div class="ACT_TEXT"><div name="-8095803" id="-8095803">Harbiy-amaliy, Oʻzbekiston milliy sport turlari va xalq oʻyinlari qoidalari qonunchilikda belgilangan tartibda ishlab chiqiladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095804" id="-8095804">31-modda. Sport unvonlari, sport razryadlari, malaka toifalari. Sport turlari boʻyicha yagona sport tasnifi</div></div><div class="ACT_TEXT"><div name="-8095805" id="-8095805">Oʻzbekiston Respublikasida quyidagi sport unvonlari, sport razryadlari, malaka toifalari belgilanadi:</div></div><div class="ACT_TEXT"><div name="-8095807" id="-8095807">a) sport unvonlari:</div></div><div class="ACT_TEXT"><div name="-8095808" id="-8095808">xalqaro toifadagi Oʻzbekiston sport ustasi yoki xalqaro grossmeyster;</div></div><div class="ACT_TEXT"><div name="-8095809" id="-8095809">Oʻzbekiston sport ustasi yoki Oʻzbekiston grossmeysteri;</div></div><div class="ACT_TEXT"><div name="-8095810" id="-8095810">b) sport razryadlari:</div></div><div class="ACT_TEXT"><div name="-8095811" id="-8095811">Oʻzbekiston sport ustaligiga yoki Oʻzbekiston grossmeysterligiga nomzod;</div></div><div class="ACT_TEXT"><div name="-8095812" id="-8095812">birinchi sport razryadi;</div></div><div class="ACT_TEXT"><div name="-8095813" id="-8095813">ikkinchi sport razryadi;</div></div><div class="ACT_TEXT"><div name="-8095815" id="-8095815">uchinchi sport razryadi;</div></div><div class="ACT_TEXT"><div name="-8095816" id="-8095816">oʻsmirlar uchun birinchi sport razryadi;</div></div><div class="ACT_TEXT"><div name="-8095817" id="-8095817">oʻsmirlar uchun ikkinchi sport razryadi;</div></div><div class="ACT_TEXT"><div name="-8095818" id="-8095818">oʻsmirlar uchun uchinchi sport razryadi;</div></div><div class="ACT_TEXT"><div name="-8095819" id="-8095819">v) sport hakamlarining malaka toifalari:</div></div><div class="ACT_TEXT"><div name="-8095820" id="-8095820">xalqaro toifali sport hakami;</div></div><div class="ACT_TEXT"><div name="-8095821" id="-8095821">milliy toifali sport hakami;</div></div><div class="ACT_TEXT"><div name="-8095822" id="-8095822">birinchi toifali sport hakami;</div></div><div class="ACT_TEXT"><div name="-8095823" id="-8095823">ikkinchi toifali sport hakami;</div></div><div class="ACT_TEXT"><div name="-8095824" id="-8095824">uchinchi toifali sport hakami;</div></div><div class="ACT_TEXT"><div name="-8095825" id="-8095825">sport boʻyicha hakam;</div></div><div class="ACT_TEXT"><div name="-8095826" id="-8095826">g) trenerlarning malaka toifalari:</div></div><div class="ACT_TEXT"><div name="-8095827" id="-8095827">xalqaro toifali trener;</div></div><div class="ACT_TEXT"><div name="-8095828" id="-8095828">oliy toifali trener;</div></div><div class="ACT_TEXT"><div name="-8095829" id="-8095829">birinchi toifali trener;</div></div><div class="ACT_TEXT"><div name="-8095830" id="-8095830">ikkinchi toifali trener;</div></div><div class="ACT_TEXT"><div name="-8095831" id="-8095831">d) yoʻriqchi-uslubchilarning malaka toifalari:</div></div><div class="ACT_TEXT"><div name="-8095832" id="-8095832">oliy toifali yoʻriqchi-uslubchi;</div></div><div class="ACT_TEXT"><div name="-8095833" id="-8095833">birinchi toifali yoʻriqchi-uslubchi;</div></div><div class="ACT_TEXT"><div name="-8095834" id="-8095834">ikkinchi toifali yoʻriqchi-uslubchi.</div></div><div class="ACT_TEXT"><div name="-8095835" id="-8095835">Sport unvonlarini, sport razryadlarini va malaka toifalarini berish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-8095836" id="-8095836">Sport turlari boʻyicha yagona sport tasnifi Sport turlari reyestriga kiritilgan sport turlari boʻyicha tegishli sport unvonlari va sport razryadlarini berish uchun bajarilishi zarur boʻlgan normalar hamda talablarni, shuningdek ularni bajarish shartlarini belgilaydi.</div></div><div class="ACT_TEXT"><div name="-8095837" id="-8095837">Sport turlari boʻyicha yagona sport tasnifi toʻgʻrisidagi nizomda mazkur normalar, talablar va shartlarning mazmuni, shuningdek sport turlari boʻyicha sport unvonlari va sport razryadlarini berish tartibi belgilanadi.</div></div><div class="ACT_TEXT"><div name="-8095838" id="-8095838">Sport turlari boʻyicha yagona sport tasnifi va u toʻgʻrisidagi nizom vakolatli davlat organi tomonidan tasdiqlanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095839" id="-8095839">32-modda. Xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasi</div></div><div class="ACT_TEXT"><div name="-8095840" id="-8095840">Xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasi Oʻzbekiston Respublikasi hududida oʻtkaziladigan xalqaro va respublika miqyosidagi rasmiy sport yoki ommaviy jismoniy tarbiya tadbirlari roʻyxatini, shuningdek Oʻzbekiston Respublikasi sport terma jamoalarini xalqaro sport tadbirlariga tayyorlash hamda ularning ishtirok etishini taʼminlash boʻyicha tadbirlar roʻyxatini belgilovchi hujjatdir.</div></div><div class="ACT_TEXT"><div name="-8095841" id="-8095841">Sport va ommaviy jismoniy tarbiya tadbirlari xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasiga sport turlarining oʻziga xos xususiyatlari hisobga olingan holda kiritiladi.</div></div><div class="ACT_TEXT"><div name="-8095842" id="-8095842">Xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasi tegishli kalendar yil boshlanguniga qadar tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-8095843" id="-8095843">Xalqaro va respublika miqyosidagi sport hamda ommaviy jismoniy tarbiya tadbirlarining kalendar rejasiga kiritilgan sport va ommaviy jismoniy tarbiya tadbirlari rasmiy sport va ommaviy jismoniy tarbiya tadbirlari hisoblanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095844" id="-8095844">33-modda. Sportchining huquq va majburiyatlari</div></div><div class="ACT_TEXT"><div name="-8095845" id="-8095845">Sportchi quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-8095846" id="-8095846">sport turini yoki sport turlarini tanlash;</div></div><div class="ACT_TEXT"><div name="-8095847" id="-8095847">tanlangan sport turi yoki sport turlari boʻyicha sport musobaqalarida ushbu sport turlari qoidalari hamda sport musobaqalari toʻgʻrisidagi qoidalarda (nizomlarda, reglamentlarda) belgilangan tartibda ishtirok etish;</div></div><div class="ACT_TEXT"><div name="-8095848" id="-8095848">Sport turlari boʻyicha yagona sport tasnifi normalari va talablarini bajarganda sport unvonlari va sport razryadlarini olish;</div></div><div class="ACT_TEXT"><div name="-8095849" id="-8095849">jismoniy tarbiya va sport tashkilotlari hamda boshqa tashkilotlar bilan qonunchilikda belgilangan tartibda shartnomalar tuzish;</div></div><div class="ACT_TEXT"><div name="-8095850" id="-8095850">oʻz huquqlari, erkinliklari va qonuniy manfaatlarini ifodalash hamda himoya qilish uchun kasaba uyushmalariga va boshqa birlashmalarga birlashish;</div></div><div class="ACT_TEXT"><div name="-8095851" id="-8095851">tanlangan sport turi boʻyicha sport federatsiyalari (uyushmalari) tomonidan oʻz huquqlari va qonuniy manfaatlarining himoya qilinishini talab qilish;</div></div><div class="ACT_TEXT"><div name="-8095852" id="-8095852">jismoniy tarbiya va sport tashkilotlarining qarorlari, ular mansabdor shaxslarining harakatlari (harakatsizligi) ustidan boʻysunuv tartibida yuqori turuvchi organlarga yoki mansabdor shaxslarga yoxud sudga belgilangan tartibda shikoyat qilish.</div></div><div class="ACT_TEXT"><div name="-8095853" id="-8095853">Sportchilarning ayrim toifalari qonunchilikda belgilangan tartibda stipendiya va imtiyozli pensiya olish huquqiga ega.</div></div><div class="ACT_TEXT"><div name="-8095854" id="-8095854">Sportchi qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095856" id="-8095856">Jismoniy tarbiya va sport sohasidagi davlat tashkilotlari va sport federatsiyalari (uyushmalari) sportchilar uchun zarur shart-sharoitlar yaratilishini va ularning sogʻligʻi muhofaza qilinishini taʼminlashi shart.</div></div><div class="ACT_TEXT"><div name="-8095858" id="-8095858">Sportchi:</div></div><div class="ACT_TEXT"><div name="-8095859" id="-8095859">jismoniy tarbiya va sport tadbirlarida ishtirok etish hamda oʻquv mashgʻulotlar paytida, shuningdek sport obyektlarida boʻlganda xavfsizlik talablariga rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095860" id="-8095860">antidoping qoidalariga rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095861" id="-8095861">adolatli kurash prinsipiga rioya etishi, shuningdek raqiblari, sport hakamlariga va tomoshabinlarga hurmat bilan munosabatda boʻlishi;</div></div><div class="ACT_TEXT"><div name="-8095862" id="-8095862">oʻzi ishtirok etayotgan jismoniy tarbiya yoki sport tadbirlari toʻgʻrisidagi qoidalarga (nizomlarga, reglamentlarga) hamda jismoniy tarbiya yoki sport tadbirlari tashkilotchilarining qonuniy talablariga rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095863" id="-8095863">sanitariya qoidalariga, normalariga va gigiyena normativlariga, tibbiy talablarga rioya etishi, belgilangan tartibda va muddatlarda tibbiy tekshiruvlardan oʻtishi shart.</div></div><div class="ACT_TEXT"><div name="-8095864" id="-8095864">Sportchining zimmasiga qonunchilikka muvofiq boshqa majburiyatlar ham yuklatilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095865" id="-8095865">34-modda. Sportchi pasporti</div></div><div class="ACT_TEXT"><div name="-8095866" id="-8095866">Sportchi pasporti yagona namunadagi hujjat boʻlib, sportchining jismoniy tarbiya va sport tashkilotiga mansubligini hamda sport malakasini tasdiqlaydi.</div></div><div class="ACT_TEXT"><div name="-8095867" id="-8095867">Sportchi pasportida quyidagilar koʻrsatiladi:</div></div><div class="ACT_TEXT"><div name="-8095868" id="-8095868">sportchining familiyasi, ismi, otasining ismi;</div></div><div class="ACT_TEXT"><div name="-8095869" id="-8095869">jinsi;</div></div><div class="ACT_TEXT"><div name="-8095870" id="-8095870">tugʻilgan sanasi;</div></div><div class="ACT_TEXT"><div name="-8095871" id="-8095871">sportchi mansub boʻlgan jismoniy tarbiya va sport tashkiloti;</div></div><div class="ACT_TEXT"><div name="-8095872" id="-8095872">sportchi tomonidan tanlangan sport turi;</div></div><div class="ACT_TEXT"><div name="-8095873" id="-8095873">sport unvonlari va sport razryadlari berilganligi toʻgʻrisidagi maʼlumotlar;</div></div><div class="ACT_TEXT"><div name="-8095874" id="-8095874">sport unvonlari va sport razryadlarini berish uchun zarur normalar hamda talablar bajarilganligini tasdiqlovchi maʼlumotlar;</div></div><div class="ACT_TEXT"><div name="-8095875" id="-8095875">sportchi tibbiy tekshiruvdan oʻtganligi toʻgʻrisidagi belgi;</div></div><div class="ACT_TEXT"><div name="-8095876" id="-8095876">sport musobaqalarida erishilgan natijalar;</div></div><div class="ACT_TEXT"><div name="-8095877" id="-8095877">sportchining sport diskvalifikatsiyasi toʻgʻrisidagi maʼlumotlar;</div></div><div class="ACT_TEXT"><div name="-8095878" id="-8095878">davlat mukofotlari va boshqa shakldagi ragʻbatlantirishlar toʻgʻrisidagi maʼlumotlar;</div></div><div class="ACT_TEXT"><div name="-8095879" id="-8095879">treneri (trenerlari) toʻgʻrisidagi maʼlumotlar;</div></div><div class="ACT_TEXT"><div name="-8095880" id="-8095880">tanlangan sport turining yoki sport turlarining oʻziga xos xususiyatlari bilan bogʻliq boshqa maʼlumotlar.</div></div><div class="ACT_TEXT"><div name="-8095881" id="-8095881">Sportchining jismoniy tarbiya va sport tashkilotiga mansubligi sportchi hamda jismoniy tarbiya va sport tashkiloti oʻrtasida tuziladigan shartnoma asosida va (yoki) sportchining jismoniy tarbiya va sport tashkilotiga aʼzoligini belgilovchi boshqa hujjatlar asosida aniqlanadi.</div></div><div class="ACT_TEXT"><div name="-8095882" id="-8095882">Sportchi pasporti uning amal qilish muddati cheklanmagan holda vakolatli davlat organining axborot tizimi orqali elektron shaklda beriladi.</div></div><div class="ACT_TEXT"><div name="-8095883" id="-8095883">Sportchi pasportini berish, almashtirish (yangisini berish) va hisobga olish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095884" id="-8095884">35-modda. Trener</div></div><div class="ACT_TEXT"><div name="-8095885" id="-8095885">Trener sportchilarni tayyorlash hamda ularning musobaqalarga tayyorgarlik koʻrishini tashkil etish, ularga nazariy va amaliy bilimlarni berish, shuningdek ularni jismoniy jihatdan kamol toptirishni amalga oshiruvchi jismoniy shaxsdir.</div></div><div class="ACT_TEXT"><div name="-8095886" id="-8095886">Trenerlik faoliyati bilan tegishli sport turi boʻyicha malaka sertifikatiga ega boʻlgan shaxslar shugʻullanishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095887" id="-8095887">Trenerlik faoliyati vakolatli davlat organi tomonidan belgilangan tartibda eʼtirof etilgan sport turi boʻyicha jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikka, shuningdek xalqaro sport tashkilotlarining qoidalariga (nizomlariga, reglamentlariga) muvofiq amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095888" id="-8095888">Oʻzbekiston Respublikasi sport terma jamoalarining trenerlarini lavozimga tayinlash va lavozimidan ozod etish qonunchilikka muvofiq amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095889" id="-8095889">Trenerlik faoliyatini amalga oshirishda quyidagilarga yoʻl qoʻyilmaydi:</div></div><div class="ACT_TEXT"><div name="-8095890" id="-8095890">zoʻravonlikni, diniy ekstremizmni, davlat tuzumiga, mamlakatning tinchligi va xavfsizligiga, uning aholisiga qarshi qaratilgan boshqa harakatlarni targʻib qilishga;</div></div><div class="ACT_TEXT"><div name="-8095891" id="-8095891">jismoniy tarbiya va sport bilan shugʻullanuvchilarning shaʼni va qadr-qimmatini kamsitishga;</div></div><div class="ACT_TEXT"><div name="-8095892" id="-8095892">oʻquv mashgʻulotlari jarayonida sportga aloqasi boʻlmagan boshqa faoliyatni olib borishga;</div></div><div class="ACT_TEXT"><div name="-8095893" id="-8095893">taqiqlangan vositalarni, tamaki va alkogol mahsulotlarini isteʼmol qilishga hamda ularni isteʼmol qilishni targʻib etishga.</div></div><div class="ACT_TEXT"><div name="-8095894" id="-8095894">Trener quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-8095896" id="-8095896">trenerlik faoliyatini amalga oshirish;</div></div><div class="ACT_TEXT"><div name="-8095897" id="-8095897">qayta tayyorlash va malaka oshirish kurslarida oʻqish;</div></div><div class="ACT_TEXT"><div name="-8095898" id="-8095898">sport musobaqalarida, jismoniy tarbiya tadbirlarida ishtirok etish.</div></div><div class="ACT_TEXT"><div name="-8095899" id="-8095899">Trener qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095900" id="-8095900">Trener:</div></div><div class="ACT_TEXT"><div name="-8095901" id="-8095901">jismoniy tarbiya va sportni hamda sogʻlom turmush tarzini targʻib qilishi;</div></div><div class="ACT_TEXT"><div name="-8095902" id="-8095902">oʻquv-mashgʻulotlarida xavfsizlik, sanitariya qoidalariga, normalariga va gigiyena normativlariga rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095903" id="-8095903">trenerga nisbatan qoʻyilgan talablarga qatʼiy rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095904" id="-8095904">kasbiy malakasini uzluksiz oshirib borishi shart.</div></div><div class="ACT_TEXT"><div name="-8095905" id="-8095905">Trenerning zimmasiga qonunchilikka muvofiq boshqa majburiyatlar ham yuklatilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095906" id="-8095906">Trenerlik malaka sertifikatini berish va trenerlik faoliyatini amalga oshirish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095907" id="-8095907">36-modda. Sport hakami</div></div><div class="ACT_TEXT"><div name="-8095908" id="-8095908">Sport turi qoidalariga va sport musobaqasi toʻgʻrisidagi nizomga (reglamentga) rioya etilishini taʼminlash uchun vakolat berilgan jismoniy shaxs sport hakamidir.</div></div><div class="ACT_TEXT"><div name="-8095909" id="-8095909">Sport hakamining faoliyati jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikka, shuningdek xalqaro sport tashkilotlarining qoidalariga (nizomlariga, reglamentlariga) muvofiq amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095910" id="-8095910">Sport hakami xalqaro sport tashkilotlari tomonidan tasdiqlangan qoidalarga (nizomlarga, reglamentlarga), sport turi qoidalariga hamda sport musobaqalarining qoidalariga (nizomlariga, reglamentlariga) muvofiq sport musobaqalariga hakamlik qiladi hamda ularga rioya etilishini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-8095911" id="-8095911">Sport hakami quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-8095912" id="-8095912">sport musobaqalarida hakamlik qilish;</div></div><div class="ACT_TEXT"><div name="-8095913" id="-8095913">sport musobaqalarida hakamlik qilganlik uchun haq (daromad) olish;</div></div><div class="ACT_TEXT"><div name="-8095914" id="-8095914">jamoat birlashmalariga birlashish;</div></div><div class="ACT_TEXT"><div name="-8095915" id="-8095915">sport musobaqasida hakamlik qilishda sport musobaqasi tashkilotchisidan tegishli shart-sharoitlar yaratilishini talab qilish.</div></div><div class="ACT_TEXT"><div name="-8095916" id="-8095916">Sport hakami qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095917" id="-8095917">Sport hakami:</div></div><div class="ACT_TEXT"><div name="-8095918" id="-8095918">xalqaro sport tashkilotlari tomonidan tasdiqlangan qoidalarni (reglamentlarni, nizomlarni), sport turi qoidalarini hamda sport musobaqalari qoidalarini (nizomlarini, reglamentlarini) bilishi va ularning talablariga qatʼiy rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095919" id="-8095919">yuksak madaniyatni va hamjihatlikni namuna qilib koʻrsatishi, shuningdek qoʻpollik, tartibsizlikning, ishtirokchilar (sportchilar, trenerlar, vakillar, tomoshabinlar) tomonidan sport turlari qoidalari buzilishining oldini olish choralarini koʻrishi shart.</div></div><div class="ACT_TEXT"><div name="-8095920" id="-8095920">Sport hakamining zimmasiga qonunchilikka muvofiq boshqa majburiyatlar ham yuklatilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095921" id="-8095921">Sport hakami jismoniy tarbiya va sport toʻgʻrisidagi qonunchilik, shuningdek xalqaro sport tashkilotlari qoidalari (nizomlari, reglamentlari) boʻyicha talablarni bajarmagan hollarda, uning xatti-harakatlari tegishli sport federatsiyalari (uyushmalari) huzurida tashkil etiladigan sport hakamlari hayʼatlarida koʻrib chiqiladi.</div></div><div class="ACT_TEXT"><div name="-8095922" id="-8095922">Sport hakami malaka toifasini berish va sport hakami faoliyatini amalga oshirish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095923" id="-8095923">37-modda. Sport agenti</div></div><div class="ACT_TEXT"><div name="-8095924" id="-8095924">Sport agenti sportchi, trener yoki sport klubi nomidan shartnoma asosida faoliyat koʻrsatuvchi, shartnomalar hamda transfer kelishuvlarini tuzishda vositachilik qiluvchi va ularning shartlariga rioya etilishini kuzatib boruvchi shaxsdir.</div></div><div class="ACT_TEXT"><div name="-8095925" id="-8095925">Sport agentining faoliyati jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikka, shuningdek xalqaro sport tashkilotlarining qoidalariga (nizomlariga, reglamentlariga) muvofiq amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095926" id="-8095926">Sport agenti quyidagi huquqlarga ega:</div></div><div class="ACT_TEXT"><div name="-8095928" id="-8095928">sportchilar, trenerlar va sport klublari bilan agentlik shartnomalarini tuzish;</div></div><div class="ACT_TEXT"><div name="-8095929" id="-8095929">sportchilar, trenerlar va sport klublari nomidan hamda ularning manfaatlarini koʻzlab shartnoma asosida faoliyat koʻrsatish;</div></div><div class="ACT_TEXT"><div name="-8095930" id="-8095930">shartnomalar tuzishda sportchilarning, trenerlarning va sport klublarining manfaatlarini ifodalash;</div></div><div class="ACT_TEXT"><div name="-8095931" id="-8095931">jismoniy tarbiya va sport sohasidagi faoliyat bilan shugʻullanadigan homiylar, reklama beruvchilar bilan hamkorlik qilish;</div></div><div class="ACT_TEXT"><div name="-8095932" id="-8095932">sportchilar, trenerlar va sport klublari manfaatlarini ifoda etganlik uchun haq (daromad) olish.</div></div><div class="ACT_TEXT"><div name="-8095933" id="-8095933">Sport agenti qonunchilikka muvofiq boshqa huquqlarga ham ega boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095934" id="-8095934">Sport agenti:</div></div><div class="ACT_TEXT"><div name="-8095935" id="-8095935">xalqaro sport tashkilotlari tomonidan tasdiqlangan qoidalarni (reglamentlarni, nizomlarni), sport turi qoidalari hamda sport musobaqalarining qoidalarini (nizomlarini, reglamentlarini) bilishi va ularning talablariga qatʼiy rioya etishi;</div></div><div class="ACT_TEXT"><div name="-8095936" id="-8095936">tuzilgan shartnomalarga muvofiq sportchilarning, trenerlarning va sport klublarining huquqlari va qonuniy manfaatlariga rioya etilishini kuzatib borishi hamda himoya qilishi kerak.</div></div><div class="ACT_TEXT"><div name="-8095937" id="-8095937">Sport agentining zimmasiga qonunchilikka muvofiq boshqa majburiyatlar ham yuklatilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8095938" id="-8095938">Sport agenti faoliyatini amalga oshirish tartibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095939" id="-8095939">38-modda. Oʻzbekiston Respublikasi Milliy antidoping agentligi</div></div><div class="ACT_TEXT"><div name="-8095944" id="-8095944">Oʻzbekiston Respublikasi Milliy antidoping agentligi (bundan buyon matnda Milliy antidoping agentligi deb yuritiladi) sportda dopingning oldini olishni va unga qarshi kurashishni hamda doping nazoratini amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-8095948" id="-8095948">Milliy antidoping agentligi:</div></div><div class="ACT_TEXT"><div name="-8095955" id="-8095955">Butunjahon antidoping kodeksi asosida milliy antidoping qoidalarini tasdiqlaydi;</div></div><div class="ACT_TEXT"><div name="-8095961" id="-8095961">antidoping qoidalariga muvofiq doping nazoratini amalga oshiradi;</div></div><div class="ACT_TEXT"><div name="-8095968" id="-8095968">Butunjahon antidoping agentligi tomonidan yillik tasdiqlanadigan sportda taqiqlangan substansiyalar va (yoki) usullarning roʻyxatini Oʻzbekiston Respublikasida eʼlon qiladi;</div></div><div class="ACT_TEXT"><div name="-8095975" id="-8095975">doping nazoratini oʻtkazish tartibini belgilaydi;</div></div><div class="ACT_TEXT"><div name="-8095979" id="-8095979">doping nazoratidan oʻtkaziladigan sportchilar roʻyxatini tuzadi;</div></div><div class="ACT_TEXT"><div name="-8095980" id="-8095980">jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikka va antidoping qoidalariga muvofiq boshqa vazifalarni amalga oshiradi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8095983" id="-8095983">39-modda. Sportda dopingning oldini olish va unga qarshi kurashish</div></div><div class="ACT_TEXT"><div name="-8095987" id="-8095987">Antidoping qoidalarida nazarda tutilgan bir yoki bir nechta qoidabuzarlik, shu jumladan sportda foydalanish taqiqlangan substansiyalar va (yoki) usullar (bundan buyon matnda taqiqlangan substansiya va (yoki) taqiqlangan usul deb yuritiladi) roʻyxatiga kiritilgan substansiyadan va (yoki) usuldan foydalanish yoki foydalanishga urinish sportda doping deb eʼtirof etiladi.</div></div><div class="ACT_TEXT"><div name="-8095989" id="-8095989">Sportda dopingning oldini olish va unga qarshi kurashish antidoping qoidalariga muvofiq amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8095994" id="-8095994">Sportchilar va boshqa shaxslar tomonidan antidoping qoidalarining buzilishiga, sport musobaqasida qatnashayotgan jonivorlarga nisbatan taqiqlangan substansiya va (yoki) taqiqlangan usulning qoʻllanilishiga yoʻl qoʻyilmaydi.</div></div><div class="ACT_TEXT"><div name="-8095999" id="-8095999">Dopingga qarshi taʼminot sportda dopingning oldini olish va unga qarshi kurashishga qaratilgan tadbirlarni oʻtkazishdan iborat.</div></div><div class="ACT_TEXT"><div name="-8096003" id="-8096003">Sportda dopingning oldini olish va unga qarshi kurashish chora-tadbirlari quyidagilarni oʻz ichiga oladi:</div></div><div class="ACT_TEXT"><div name="-8096007" id="-8096007">doping nazoratini oʻtkazishni;</div></div><div class="ACT_TEXT"><div name="-8096010" id="-8096010">sportchilarning, trenerlarning, jismoniy tarbiya va sport sohasidagi boshqa mutaxassislarning antidoping qoidalarini buzganlik uchun javobgarligini belgilashni;</div></div><div class="ACT_TEXT"><div name="-8096012" id="-8096012">taqiqlangan substansiyalar va (yoki) taqiqlangan usullar qoʻllanilishining oldini olishni;</div></div><div class="ACT_TEXT"><div name="-8096016" id="-8096016">doping nazoratini oʻtkazuvchi mutaxassislarning malakasini oshirishni;</div></div><div class="ACT_TEXT"><div name="-8096017" id="-8096017">jismoniy tarbiya va sport sohasida faoliyatni amalga oshiruvchi taʼlim tashkilotlarining qoʻshimcha taʼlim dasturlariga antidoping qoidalari, sportda dopingning sportchilar sogʻligʻi uchun oqibatlari, antidoping qoidalarini buzganlik uchun javobgarlik toʻgʻrisidagi boʻlimlarni kiritishni;</div></div><div class="ACT_TEXT"><div name="-8096018" id="-8096018">ommaviy axborot vositalarida dopingga qarshi targʻibot olib borishni;</div></div><div class="ACT_TEXT"><div name="-8096019" id="-8096019">sportda dopingning oldini olishni va unga qarshi kurashishga qaratilgan ilmiy tadqiqotlar oʻtkazishni;</div></div><div class="ACT_TEXT"><div name="-8096020" id="-8096020">sportchilarning ish qobiliyatini tiklash vositalari va usullarini ishlab chiqish boʻyicha ilmiy tadqiqotlar oʻtkazishni;</div></div><div class="ACT_TEXT"><div name="-8096021" id="-8096021">doping nazoratini oʻtkazish tartibida nazarda tutilgan doping nazoratini oʻtkazish shartlarini buzganlik uchun jismoniy tarbiya va sport tashkilotlarining javobgarligini belgilashni;</div></div><div class="ACT_TEXT"><div name="-8096049" id="-8096049">sportda dopingning oldini olishni va unga qarshi kurashish sohasida xalqaro hamkorlikni amalga oshirishni;</div></div><div class="ACT_TEXT"><div name="-8096050" id="-8096050">antidoping qoidalarida belgilangan boshqa har qanday faoliyatni amalga oshirishni.</div></div><div class="ACT_TEXT"><div name="-8096051" id="-8096051">Sportda dopingning oldini olish va unga qarshi kurashish choralarini koʻrish uchun sport federatsiyalari (uyushmalari):</div></div><div class="ACT_TEXT"><div name="-8096055" id="-8096055">Butunjahon antidoping kodeksini, milliy antidoping qoidalarini hamda tegishli xalqaro sport federatsiyalari (uyushmalari) tomonidan tasdiqlangan antidoping qoidalarini oʻz rasmiy veb-saytlarida davlat tilida joylashtirishi;</div></div><div class="ACT_TEXT"><div name="-8096056" id="-8096056">sport musobaqasi davrida hamda musobaqadan tashqari davrda Milliy antidoping agentligiga doping-test oʻtkazish maqsadida sportchilar roʻyxatini shakllantirish uchun zarur boʻlgan maʼlumotlarni taqdim etishi;</div></div><div class="ACT_TEXT"><div name="-8096057" id="-8096057">ushbu Qonunga, Butunjahon antidoping kodeksiga, milliy antidoping qoidalariga hamda tegishli xalqaro sport federatsiyalari (uyushmalari) tomonidan tasdiqlangan antidoping qoidalariga muvofiq boshqa talablarni bajarishi shart.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096058" id="-8096058">40-modda. Sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olish va unga qarshi kurashish</div></div><div class="ACT_TEXT"><div name="-8096086" id="-8096086">Sportchining, trenerning, sport hakamining yoki sport musobaqalari boshqa ishtirokchilarining yoxud tashkilotchilarining sport musobaqalari natijalarini yoki uning borishini qasddan oʻzgartirish maqsadida qonunga xilof ravishda moddiy qimmatliklar olishi yoki mulkiy manfaatdor boʻlishi yoxud shu maqsadda ushbu shaxslarga moddiy qimmatliklar berish yoki ularni mulkiy manfaatdor qilish, shuningdek ularga ruhiy, psixologik, jismoniy yoki boshqacha tarzda noqonuniy taʼsir koʻrsatish sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatish hisoblanadi.</div></div><div class="ACT_TEXT"><div name="-8096088" id="-8096088">Sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olish hamda unga qarshi kurashish jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikka, shuningdek sport federatsiyalari (uyushmalari) tomonidan tasdiqlangan qoidalarga muvofiq amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8096091" id="-8096091">Sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olish va unga qarshi kurashish chora-tadbirlari quyidagilarni oʻz ichiga oladi:</div></div><div class="ACT_TEXT"><div name="-8096092" id="-8096092">sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatganlik uchun javobgarlikni belgilashni;</div></div><div class="ACT_TEXT"><div name="-8096093" id="-8096093">sport musobaqalari toʻgʻrisidagi tegishli nizomlarda sportchi, trener, sport hakami, sport sohasidagi boshqa mutaxassislarning oʻzaro manfaatlari toʻqnashuvining oldini olish va bartaraf etishga doir qoidalarni, shuningdek sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishni taqiqlash boʻyicha talablarni nazarda tutishni;</div></div><div class="ACT_TEXT"><div name="-8096094" id="-8096094">sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olish hamda unga qarshi kurashishda jismoniy tarbiya va sport subyektlarining huquqni muhofaza qiluvchi organlar bilan hamkorligini taʼminlashni;</div></div><div class="ACT_TEXT"><div name="-8096095" id="-8096095">ommaviy axborot vositalarida sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olishga va unga qarshi kurashishga qaratilgan targʻibot ishlarini olib borishni;</div></div><div class="ACT_TEXT"><div name="-8096096" id="-8096096">sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olish va unga qarshi kurashishga qaratilgan ilmiy-amaliy tadqiqotlar oʻtkazishni hamda qonunga xilof ravishda taʼsir koʻrsatilishi hollarini aniqlashga qaratilgan uslubiy qoʻllanmalar ishlab chiqishni;</div></div><div class="ACT_TEXT"><div name="-8096097" id="-8096097">sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatishning oldini olish va unga qarshi kurashish sohasidagi xalqaro hamkorlikni amalga oshirishni.</div></div><div class="ACT_TEXT"><div name="-8096098" id="-8096098">Sport musobaqalari natijalariga qonunga xilof ravishda taʼsir koʻrsatish qonunchilikka muvofiq javobgarlikka sabab boʻladi.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8096099" id="-8096099"><b>4-bob. Taʼlim tizimida, fuqarolarning ish joyida, yashash joyida hamda boshqa joylarda jismoniy tarbiya va sport</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8096100" id="-8096100">41-modda. Taʼlim tizimida jismoniy tarbiya va sportni tashkil etish</div></div><div class="ACT_TEXT"><div name="-8096101" id="-8096101">Taʼlim tizimida jismoniy tarbiya va sportni tashkil etish quyidagilarni oʻz ichiga oladi:</div></div><div class="ACT_TEXT"><div name="-8096102" id="-8096102">asosiy taʼlim dasturlari doirasida davlat taʼlim standartlari bilan belgilangan hajmlarda jismoniy tarbiya va sport boʻyicha majburiy mashgʻulotlar, shuningdek qoʻshimcha taʼlim dasturlari doirasida qoʻshimcha (fakultativ) jismoniy mashqlar va sport mashgʻulotlari oʻtkazishni;</div></div><div class="ACT_TEXT"><div name="-8096103" id="-8096103">taʼlim oluvchilarni jismoniy tarbiya va sport mashgʻulotlariga jalb etish uchun shart-sharoitlar yaratishni, shu jumladan yoshlarning jismoniy tarbiya va sport tayyorgarligi boʻyicha tadbirlar majmuini oʻtkazish uchun sport jihozlari va anjomlari bilan taʼminlashni;</div></div><div class="ACT_TEXT"><div name="-8096104" id="-8096104">taʼlim oluvchilarda ularning individual qobiliyatini hamda sogʻligʻi holatini hisobga olgan holda, jismoniy tarbiya va sport koʻnikmalarini shakllantirishni;</div></div><div class="ACT_TEXT"><div name="-8096105" id="-8096105">iqtidorli bolalar va yoshlarni aniqlashni, tanlashni va professional sportchi sifatida tayyorlashga yoʻnaltirishni;</div></div><div class="ACT_TEXT"><div name="-8096106" id="-8096106">oʻquv mashgʻulotlari paytida jismoniy tarbiya tadbirlarini amalga oshirishni;</div></div><div class="ACT_TEXT"><div name="-8096107" id="-8096107">taʼlim oluvchilarning jismoniy tarbiyasi tashkil etilishi ustidan tibbiy nazorat olib borishni;</div></div><div class="ACT_TEXT"><div name="-8096108" id="-8096108">ota-onalarda yoki ularning oʻrnini bosuvchi shaxslarda bolalarining sogʻligʻi va ularning jismoniy tarbiyasiga nisbatan masʼuliyatli munosabatni shakllantirishni;</div></div><div class="ACT_TEXT"><div name="-8096109" id="-8096109">bolalar va yoshlarning jismoniy tayyorgarligini hamda jismoniy rivojlanishini har yili monitoring qilishni;</div></div><div class="ACT_TEXT"><div name="-8096110" id="-8096110">taʼlim oluvchilar ishtirokida sport tadbirlarini, shu jumladan maktabgacha va maktab taʼlimi tizimining taʼlim muassasalari oʻquvchilari, professional taʼlim tashkilotlari oʻquvchilari hamda oliy taʼlim tashkilotlari talabalari ishtirokida sport musobaqalari oʻtkazilishini tashkil etishni.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096111" id="-8096111">42-modda. Fuqarolarning ish joyi, yashash joyi hamda dam olish joyida jismoniy tarbiya va sportni tashkil etish</div></div><div class="ACT_TEXT"><div name="-8096112" id="-8096112">Ish beruvchilar, ularning birlashmalari va xodimlar yoki ularning vakillik organlari oʻrtasidagi jamoa shartnomalari, kelishuvlari va mehnat shartnomalariga:</div></div><div class="ACT_TEXT"><div name="-8096113" id="-8096113">xodimlarga jismoniy tarbiya va sport bilan shugʻullanish hamda xodimlarning jismoniy tarbiya va sport bilan shugʻullanishiga bogʻliq boʻlgan boshqa tadbirlarni oʻtkazish uchun zarur shart-sharoitlar yaratish toʻgʻrisidagi;</div></div><div class="ACT_TEXT"><div name="-8096114" id="-8096114">xodimlarga va ularning oila aʼzolariga ushbu qismning <a href="https://lex.uz/docs/-8093787#-8096113">ikkinchi xatboshisida</a> nazarda tutilgan chora-tadbirlarni amalga oshirish uchun sport obyektlari, sport jihozlari va anjomlaridan foydalanish imkoniyatini yaratish haqidagi qoidalar kiritilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8096115" id="-8096115">Fuqarolarning oʻzini oʻzi boshqarish organlari fuqarolarning yashash joyi va dam olish joyi boʻyicha jismoniy tarbiya va sportni rivojlantirish uchun zarur shart-sharoitlar yaratadi, shu jumladan jismoniy tarbiya va sport sohasidagi mutaxassislarni jalb etish choralarini koʻradi.</div></div><div class="ACT_TEXT"><div name="-8096116" id="-8096116">Sanatoriy-kurort muassasalari, dam olish uylari va turistik bazalar rahbarlari fuqarolarning sogʻligʻini mustahkamlash, kasalliklarning oldini olish va davolash maqsadida fuqarolarning davolanishi hamda dam olishi jarayonida jismoniy tarbiya komponentlaridan foydalanish uchun shart-sharoitlar yaratadi.</div></div><div class="ACT_TEXT"><div name="-8096117" id="-8096117">Ish beruvchilar xodimlarning jismoniy tarbiya va sport bilan faol shugʻullanishi, shu jumladan ish vaqti davomida yoki ish vaqtidan keyin ixtiyoriy ravishda jismoniy tarbiya va sport bilan shugʻullanishi uchun zarur shart-sharoitlar yaratishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096118" id="-8096118">43-modda. Adaptiv jismoniy tarbiya va sport. Nogironligi boʻlgan shaxslarni jismoniy reabilitatsiya qilish</div></div><div class="ACT_TEXT"><div name="-8096119" id="-8096119">Adaptiv jismoniy tarbiya jismoniy tarbiyaning nogironligi boʻlgan shaxslarni jismoniy reabilitatsiya qilishning kompleks vositalaridan foydalanuvchi qismidir.</div></div><div class="ACT_TEXT"><div name="-8096120" id="-8096120">Adaptiv sport sportning nogironligi boʻlgan shaxslarni jismoniy reabilitatsiya qilishga hamda ijtimoiy moslashtirishga qaratilgan qismidir.</div></div><div class="ACT_TEXT"><div name="-8096121" id="-8096121">Adaptiv jismoniy tarbiya va sportni rivojlantirish sport bilan shugʻullanishning ustuvorligi, ommalashuvi hamda ochiqligi prinsiplariga asoslanadi.</div></div><div class="ACT_TEXT"><div name="-8096122" id="-8096122">Nogironligi boʻlgan shaxslarni adaptiv jismoniy tarbiya va sport usullaridan foydalangan holda jismoniy reabilitatsiya qilish hamda ijtimoiy moslashtirish jismoniy tarbiya va sport tashkilotlarida, taʼlim tashkilotlarida, shu jumladan reabilitatsiya markazlarida, nogironligi boʻlgan shaxslarning sport klublarida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8096123" id="-8096123">Taʼlim muassasalarida taʼlim olayotgan nogironligi boʻlgan shaxslar uchun mashgʻulotlar bunday taʼlim oluvchilarning shaxsiy qobiliyatlari hamda sogʻligʻining holati hisobga olingan, adaptiv jismoniy tarbiya va sport vositalaridan foydalanilgan holda tashkil etiladi.</div></div><div class="ACT_TEXT"><div name="-8096124" id="-8096124">Vakolatli davlat organi Oʻzbekiston Respublikasi Prezidenti huzuridagi Ijtimoiy himoya milliy agentligi, mahalliy davlat hokimiyati organlari, fuqarolarning oʻzini oʻzi boshqarish organlari hamda nogironligi boʻlgan shaxslarning jamoat birlashmalari bilan birgalikda nogironligi boʻlgan shaxslarning jismoniy tarbiya va sport tashkilotlari vositasida jismoniy tarbiya, jismoniy kamol toptirish va jismoniy tayyorgarlik tizimiga uygʻunlashuviga koʻmaklashadi.</div></div><div class="ACT_TEXT"><div name="-8096125" id="-8096125">Vakolatli davlat organi Oʻzbekiston Respublikasi Prezidenti huzuridagi Ijtimoiy himoya milliy agentligi, mahalliy davlat hokimiyati organlari, fuqarolarning oʻzini oʻzi boshqarish organlari, jismoniy tarbiya va sport tashkilotlari, shuningdek nogironligi boʻlgan shaxslarning jamoat birlashmalari nogironligi boʻlgan shaxslar ishtirokida jismoniy tarbiya va sport tadbirlari oʻtkazilishini tashkil etadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096126" id="-8096126">44-modda. Jazoni ijro etish muassasalarida jismoniy tarbiya va sport</div></div><div class="ACT_TEXT"><div name="-8096127" id="-8096127">Jazoni ijro etish muassasalari mahkumlarning jismoniy tarbiya va sport bilan shugʻullanishini belgilangan tartibda tashkil etadi.</div></div><div class="ACT_TEXT"><div name="-8096128" id="-8096128">Jazoni ijro etish muassasalari maʼmuriyati jismoniy tarbiya va sport bilan shugʻullanish uchun zarur shart-sharoitlar yaratadi hamda sport turlari qoidalariga muvofiq sport tadbirlarini tashkil etadi.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8096129" id="-8096129"><b>5-bob. Sport zaxirasini tayyorlash</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8096130" id="-8096130">45-modda. Yuqori malakali sportchilarni va sport zaxirasini tayyorlash</div></div><div class="ACT_TEXT"><div name="-8096132" id="-8096132">Yuqori malakali sportchilarni va sport zaxirasini tayyorlash sport taʼlim tashkilotlarida jismoniy tarbiya va sport sohasidagi mutaxassislar tomonidan amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8096133" id="-8096133">Yuqori malakali sportchilarni va sport zaxirasini tegishli sport ekipirovkasi, sport jihozi va anjomi, biologik va tibbiy-tiklovchi preparatlar bilan taʼminlash, shuningdek tibbiy xizmat (profilaktika, davolash) koʻrsatishni tashkil etish belgilangan tartibda amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8096134" id="-8096134">Yuqori malakali sportchilarni va sport zaxirasini tayyorlash sport turining oʻziga xos xususiyatlari inobatga olingan holda tegishli sport turi boʻyicha trenerlar va boshqa mutaxassislar tomonidan amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096135" id="-8096135">46-modda. Sport zaxirasini tayyorlash bosqichlari</div></div><div class="ACT_TEXT"><div name="-8096137" id="-8096137">Sport zaxirasini tayyorlashda sportchilarni tayyorlashning quyidagi bosqichlari belgilanadi:</div></div><div class="ACT_TEXT"><div name="-8096138" id="-8096138">sport-sogʻlomlashtirish (adaptiv sport turlari uchun korreksiya) bosqichi;</div></div><div class="ACT_TEXT"><div name="-8096139" id="-8096139">boshlangʻich tayyorgarlik bosqichi;</div></div><div class="ACT_TEXT"><div name="-8096140" id="-8096140">oʻquv-mashgʻulot bosqichi;</div></div><div class="ACT_TEXT"><div name="-8096142" id="-8096142">sport mahoratini takomillashtirish (sport kamolotiga erishish) bosqichi;</div></div><div class="ACT_TEXT"><div name="-8096143" id="-8096143">oliy sport mahorati bosqichi.</div></div><div class="ACT_TEXT"><div name="-8096144" id="-8096144">Ushbu moddaning <a href="https://lex.uz/docs/-8093787#-8096137">birinchi qismida</a> koʻrsatilgan bosqichlar tarkibi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096145" id="-8096145">47-modda. Sportchilar tayyorlashni amalga oshiruvchi jismoniy tarbiya va sport tashkilotlari hamda taʼlim tashkilotlari</div></div><div class="ACT_TEXT"><div name="-8096146" id="-8096146">Sportchilar tayyorlash maqsadida oʻquv-mashgʻulot jarayoni boʻyicha, shu jumladan yuqori malakali sportchilarni va sport zaxirasini tayyorlash boʻyicha faoliyatni amalga oshiruvchi jismoniy tarbiya va sport tashkilotlari hamda taʼlim tashkilotlari faoliyat koʻrsatadi. Oʻquv-mashgʻulot jarayonini tashkil etish oʻquv-mashgʻulot va boshqa sport tadbirlarini oʻtkazishni, shuningdek sport tadbirlarida sport ekipirovkasi, sport jihozi va anjomi, tibbiy xizmat, yoʻlkira, ovqatlanish masalalarini hamda qonunchilikda belgilangan boshqa tashkiliy masalalarni oʻz ichiga oladi.</div></div><div class="ACT_TEXT"><div name="-8096147" id="-8096147">Oʻquv-mashgʻulot jarayonini tashkil etish hamda yuqori malakali sportchilarni va sport zaxirasini tayyorlash sport federatsiyalari (uyushmalari), sport klublari, boshqa jismoniy tarbiya va sport tashkilotlari, yakka tartibdagi tadbirkorlar va oʻzini oʻzi band qilgan trenerlar tomonidan amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8096148" id="-8096148">Ushbu moddaning <a href="https://lex.uz/docs/-8093787#-8096146">birinchi qismida</a> koʻrsatilgan taʼlim tashkilotlari jumlasiga jismoniy tarbiya va sport sohasida faoliyatni amalga oshiruvchi taʼlim tashkilotlari kiradi.</div></div><div class="ACT_TEXT"><div name="-8096149" id="-8096149">Ushbu moddaning <a href="https://lex.uz/docs/-8093787#-8096148">uchinchi qismida</a> koʻrsatilgan taʼlim tashkilotlari jumlasiga kirmaydigan taʼlim tashkilotlarida sportchilarni tayyorlash maqsadida sport turlari boʻyicha shunday tayyorgarlikni chuqurlashtirilgan oʻquv-mashgʻulot jarayoni asosida amalga oshiradigan tarkibiy boʻlinmalar, ixtisoslashtirilgan guruhlar va sport klublari tashkil etilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096150" id="-8096150">48-modda. Sport turlari boʻyicha sportchilarni tayyorlashga doir oʻquv dasturlari</div></div><div class="ACT_TEXT"><div name="-8096151" id="-8096151">Jismoniy tarbiya va sport sohasida faoliyatni amalga oshiruvchi sport taʼlim tashkilotlarida sportchilarni tayyorlash vakolatli davlat organi tomonidan tasdiqlangan namunaviy oʻquv dasturlariga muvofiq olib boriladi.</div></div><div class="ACT_TEXT"><div name="-8096152" id="-8096152">Sportchilarni tayyorlashning namunaviy oʻquv dasturlari oʻquv-mashgʻulot jarayonini amalga oshiruvchi jismoniy tarbiya va sport tashkilotlari faoliyatini tartibga soluvchi qonunchilikka muvofiq ishlab chiqiladi hamda jismoniy tarbiya va sport sohasidagi tegishli ilmiy tadqiqotlar natijalariga hamda jismoniy tarbiya va sport tadbirlarini oʻtkazish amaliyotiga asoslanadi.</div></div><div class="ACT_TEXT"><div name="-8096153" id="-8096153">Sportchilarni tayyorlashning namunaviy oʻquv dasturlari vakolatli davlat organi tomonidan tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-8096154" id="-8096154">Jismoniy tarbiya va sport sohasida faoliyatni amalga oshiruvchi taʼlim tashkilotlarida oʻquv-mashgʻulot faoliyatini sportchilarni tayyorlashga doir oʻquv dasturlaridan foydalanmasdan tashkil etishga yoʻl qoʻyilmaydi.</div></div><div class="ACT_TEXT"><div name="-8096155" id="-8096155">Jismoniy tarbiya va sport sohasida faoliyatni amalga oshiruvchi taʼlim tashkilotlarida sportchilarni tayyorlashda raqamli texnologiyalardan foydalanilishi mumkin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096156" id="-8096156">49-modda. Jismoniy tarbiya va sport sohasidagi pedagogik faoliyat</div></div><div class="ACT_TEXT"><div name="-8096157" id="-8096157">Tegishli maʼlumotga va kasbiy tayyorgarlikka ega boʻlgan shaxslarning jismoniy tarbiya va sport sohasida, shu jumladan davolash jismoniy tarbiyasi sohasida pedagogik faoliyat bilan shugʻullanishiga qonunchilikda belgilangan tartibda yoʻl qoʻyiladi.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8096158" id="-8096158"><b>6-bob. Oʻzbekiston Respublikasining sport terma jamoalari va ularni shakllantirish</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8096159" id="-8096159">50-modda. Oʻzbekiston Respublikasining sport terma jamoalari</div></div><div class="ACT_TEXT"><div name="-8096160" id="-8096160">Oʻzbekiston Respublikasining sport terma jamoalari asosiy va zaxira tarkiblardan tashkil topadi.</div></div><div class="ACT_TEXT"><div name="-8096161" id="-8096161">Oʻzbekiston Respublikasining sport terma jamoalari tarkibiga kiruvchi jismoniy tarbiya va sport sohasidagi mutaxassislar roʻyxati tegishli sport federatsiyalari (uyushmalari) bilan kelishilgan holda vakolatli davlat organi tomonidan tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-8096162" id="-8096162">Oʻzbekiston Respublikasining sport terma jamoalarini respublika budjeti mablagʻlari hisobidan moddiy-texnikaviy taʼminlash, shu jumladan sport ekipirovkasi bilan taʼminlash, ilmiy-uslubiy, tibbiy-biologik, tibbiy jihatdan, dopingga qarshi taʼminlash vakolatli davlat organi tomonidan belgilangan tartibda Oʻzbekiston Respublikasi Sogʻliqni saqlash vazirligi bilan kelishilgan holda amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096163" id="-8096163">51-modda. Oʻzbekiston Respublikasining sport terma jamoalarini shakllantirish</div></div><div class="ACT_TEXT"><div name="-8096164" id="-8096164">Oʻzbekiston Respublikasining sport terma jamoalariga nomzodlar roʻyxatlari har yili sport federatsiyalari (uyushmalari) tomonidan shakllantiriladi va vakolatli davlat organi tomonidan tasdiqlanadi.</div></div><div class="ACT_TEXT"><div name="-8096165" id="-8096165">Oʻzbekiston Respublikasining sport terma jamoalariga nomzodlar roʻyxatlarini shakllantirishning umumiy prinsiplari va mezonlari, ushbu roʻyxatlarni tasdiqlash tartibi vakolatli davlat organi tomonidan belgilanadi.</div></div><div class="ACT_TEXT"><div name="-8096166" id="-8096166">Xalqaro sport musobaqalarida ishtirok etishga tayyorgarlik koʻrish va ishtirok etish uchun Oʻzbekiston Respublikasining sport terma jamoalari Oʻzbekiston Respublikasining sport terma jamoalariga nomzodlarning tegishli roʻyxatiga kiritilgan shaxslar orasidan sport federatsiyalari (uyushmalari) tomonidan shakllantiriladi.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8096167" id="-8096167"><b>7-bob. Jismoniy tarbiya va sportning moddiy, tibbiy, moliyaviy hamda boshqa taʼminoti</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8096168" id="-8096168">52-modda. Jismoniy tarbiya-sogʻlomlashtirish va sport inshootlari</div></div><div class="ACT_TEXT"><div name="-8096169" id="-8096169">Jismoniy tarbiya-sogʻlomlashtirish va sport inshootlari xususiy yoki ommaviy mulk boʻlishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8096170" id="-8096170">Jismoniy tarbiya-sogʻlomlashtirish va sport inshootlarini xususiylashtirish tartibi qonunchilikda belgilanadi.</div></div><div class="ACT_TEXT"><div name="-8096172" id="-8096172">Mahalliy davlat hokimiyati organlari oʻz hududida jismoniy tarbiya-sogʻlomlashtirish va sport inshootlarining rejalashtirilishi, loyihalashtirilishi, qurilishi hamda foydalanishga topshirilishi ustidan nazoratni amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-8096173" id="-8096173">Taʼlim tashkilotlarining, korxonalarning, turar joy dahalarining asosiy jismoniy tarbiya-sogʻlomlashtirish va sport inshootlari bilan eng kam taʼminlanish normativlari qonunchilikda belgilanadi.</div></div><div class="ACT_TEXT"><div name="-8096174" id="-8096174">Jismoniy tarbiya-sogʻlomlashtirish va sport inshootlarida fuqarolarning ayrim toifalariga qonunchilikda belgilangan tartibda imtiyozli asosda xizmatlar koʻrsatilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8096175" id="-8096175">Taʼlim tashkilotlarini, aholi yashash maskanlarini zarur jismoniy tarbiya-sogʻlomlashtirish va sport inshootlari majmuini barpo etmasdan qurishga va rekonstruksiya qilishga, shuningdek jismoniy tarbiya-sogʻlomlashtirish va sport inshootlarini shu hudud doirasida ularga teng inshootlarni barpo etmasdan tugatishga yoʻl qoʻyilmaydi.</div></div><div class="ACT_TEXT"><div name="-8096176" id="-8096176">Sport obyektlari boʻlmagan ayrim yer va suv hududi uchastkalarida, shuningdek havo hududi uchastkalarida ushbu uchastkalarni qonunchilikda belgilangan tartibda muayyan muddatga sport obyektlari (trassalari) sifatida rasmiylashtirgan holda jismoniy tarbiya va sport tadbirlarini oʻtkazishga qonunchilikda belgilangan tartibda yoʻl qoʻyiladi.</div></div><div class="ACT_TEXT"><div name="-8096177" id="-8096177">Vakolatli davlat organi Oʻzbekiston Respublikasi Vazirlar Mahkamasi tomonidan belgilanadigan tartibda Sport inshootlari reyestrini yuritadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096178" id="-8096178">53-modda. Jismoniy tarbiya yoki sport tadbirlarining tibbiy taʼminoti</div></div><div class="ACT_TEXT"><div name="-8096179" id="-8096179">Jismoniy tarbiya yoki sport tadbirlarining tashkilotchilari bu tadbirlar ishtirokchilarini tibbiy yordam bilan taʼminlashni amalga oshirishi shart.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096181" id="-8096181">54-modda. Jismoniy tarbiya va sportni moliyalashtirish</div></div><div class="ACT_TEXT"><div name="-8096182" id="-8096182">Jismoniy tarbiya va sportni moliyalashtirish quyidagilar hisobidan amalga oshiriladi:</div></div><div class="ACT_TEXT"><div name="-8096183" id="-8096183">Oʻzbekiston Respublikasi Davlat budjetining mablagʻlari;</div></div><div class="ACT_TEXT"><div name="-8096184" id="-8096184">tadbirkorlik faoliyati va boshqa xoʻjalik faoliyatidan olinadigan daromadlar;</div></div><div class="ACT_TEXT"><div name="-8096185" id="-8096185">jismoniy tarbiya va sport sohasida pulli xizmatlar koʻrsatishdan kelib tushadigan mablagʻlar;</div></div><div class="ACT_TEXT"><div name="-8096186" id="-8096186">yuridik va jismoniy shaxslarning homiylik va xayriya mablagʻlari;</div></div><div class="ACT_TEXT"><div name="-8096188" id="-8096188">jismoniy tarbiya va sport jamoat birlashmalari ishtirokchilarining aʼzolik badallari;</div></div><div class="ACT_TEXT"><div name="-8096189" id="-8096189">sport turlari boʻyicha maxsus jamgʻarmalarning mablagʻlari;</div></div><div class="ACT_TEXT"><div name="-8096190" id="-8096190">sport ramzlari, timsollaridan foydalanganlik uchun toʻlovlar;</div></div><div class="ACT_TEXT"><div name="-8096191" id="-8096191">chet el investitsiyalari mablagʻlari;</div></div><div class="ACT_TEXT"><div name="-8096192" id="-8096192">xalqaro va xorijiy tashkilotlarning grantlari hamda texnik koʻmak mablagʻlari;</div></div><div class="ACT_TEXT"><div name="-8096193" id="-8096193">qonunchilikda taqiqlanmagan boshqa manbalar.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096194" id="-8096194">55-modda. Sportchi va trenerlarni davlat tomonidan qoʻllab-quvvatlash</div></div><div class="ACT_TEXT"><div name="-8096195" id="-8096195">Davlat tomonidan sportchi hamda trenerlarga bir martalik va oylik toʻlov (stipendiya, nafaqa va boshqalar) shaklidagi qoʻllab-quvvatlash choralari taqdim etilishi mumkin.</div></div><div class="ACT_TEXT"><div name="-8096196" id="-8096196">Ushbu moddada koʻrsatib oʻtilgan qoʻllab-quvvatlash choralari qonunchilikda belgilangan sport musobaqalarida gʻolib va sovrindor boʻlgan sportchilar, shuningdek ularni tayyorlagan trenerlarga taqdim etiladi.</div></div><div class="ACT_TEXT"><div name="-8096197" id="-8096197">Sportchilar va trenerlarga bir martalik va oylik toʻlov (stipendiya, nafaqa va boshqalar) shaklidagi qoʻllab-quvvatlash choralarini taqdim etish tartibi hamda ularning miqdorlari qonunchilik hujjatlari bilan belgilanadi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096198" id="-8096198">56-modda. Jismoniy tarbiya va sport sohasida xavfsizlik normalari va qoidalariga rioya etilishini, fuqarolarning sogʻligʻi, shaʼni va qadr-qimmati muhofaza qilinishini taʼminlash</div></div><div class="ACT_TEXT"><div name="-8096199" id="-8096199">Jismoniy tarbiya yoki sport tadbirlarini oʻtkazadigan tashkilotlar ushbu tadbirlar oʻtkaziladigan joylarning texnika xavfsizligi qoidalariga va sanitariya qoidalariga, normalariga va gigiyena normativlariga muvofiq lozim darajada jihozlanishini taʼminlaydi.</div></div><div class="ACT_TEXT"><div name="-8096200" id="-8096200">Jismoniy tarbiya yoki sport tadbirlari ularning ishtirokchilari va tomoshabinlar sogʻligʻiga, shaʼni va qadr-qimmatiga ziyon yetkazilmaydigan tarzda oʻtkazilishi kerak.</div></div><div class="ACT_TEXT"><div name="-8096201" id="-8096201">Sportchilarning shaʼni va qadr-qimmati kamsitilishiga olib keladigan, shuningdek ularning sport jarohatlari olishiga sabab boʻladigan tayyorgarlik uslublaridan foydalanishga yoʻl qoʻyilmaydi.</div></div><div class="ACT_TEXT"><div name="-8096202" id="-8096202">Jismoniy tarbiya yoki sport tadbirlarida ishtirok etish vaqtida sogʻligʻiga ziyon yetkazilgan sportchilar, trenerlar hamda sport hakamlariga qonunchilikka muvofiq tibbiy, ijtimoiy va kasbiy reabilitatsiya taʼminlanadi.</div></div><div class="ACT_TEXT"><div name="-8096203" id="-8096203">Muassasalar va tashkilotlarning voyaga yetmagan sportchilar bilan oʻzaro munosabatlari belgilangan tartibda faqat ularning ota-onasining yoki ota-onasi oʻrnini bosuvchi shaxslarning yoxud ular tarbiyalanayotgan ixtisoslashtirilgan muassasalarning roziligi va ishtirokida amalga oshiriladi.</div></div><div class="ACT_TEXT"><div name="-8096204" id="-8096204">Sport musobaqalarida ishtirok etuvchi shaxslar qonunchilikda belgilangan tartibda sugʻurta polisiga ega boʻlishi shart.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096205" id="-8096205">57-modda. Sport jihozi, anjomi va sport kiyim-boshi</div></div><div class="ACT_TEXT"><div name="-8096207" id="-8096207">Sport jihozi, anjomi va sport kiyim-boshi tegishli standartlarga, texnik reglamentlarga, normalarga va talablarga muvofiq boʻlishi kerak.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096208" id="-8096208">58-modda. Jismoniy tarbiya va sportning ilmiy-uslubiy hamda texnik taʼminoti</div></div><div class="ACT_TEXT"><div name="-8096209" id="-8096209">Jismoniy tarbiya va sport sohasidagi ilmiy-tadqiqot ishlarini tashkil etish hamda oʻtkazishni taʼlim muassasalari va tarkibida ilmiy markazlar tashkil etiladigan boshqa tashkilotlar, ilmiy-tadqiqot institutlari, belgilangan tartibda tashkil etilgan hamda oʻz faoliyatini davlat buyurtmalari va boshqa buyurtmalar asosida olib boradigan laboratoriyalar amalga oshiradi.</div></div><div class="ACT_TEXT"><div name="-8096210" id="-8096210">Taʼlim muassasalari va boshqa tashkilotlar jismoniy tarbiya vositalari bilan aholi sogʻligʻini mustahkamlashga koʻmaklashadigan aniq dasturlarni ishlab chiqadi hamda amaliyotga joriy etadi, sport zaxiralarini va Oʻzbekiston Respublikasining sport terma jamoalarini xalqaro sport tadbirlariga tayyorlashni ilmiy jihatdan taʼminlashni takomillashtiradi.</div></div><div class="ACT_TEXT"><div name="-8096211" id="-8096211">Vakolatli davlat organi, boshqa davlat organlari va tashkilotlari taʼlim muassasalari va tashkilotlariga jismoniy tarbiya va sport sohasida ilmiy-tadqiqot ishlarini olib borishda, shuningdek dolzarb ilmiy-tadqiqot ishlariga davlat buyurtmalari hamda boshqa buyurtmalarni shakllantirishda koʻmaklashadi, ilmiy-tadqiqot ishlarining yakunlarini tahlil qiladi va ularning faoliyatiga yordam koʻrsatadi.</div></div><div class="TEXT_HEADER_DEFAULT"><div name="-8096212" id="-8096212"><b>8-bob. Yakunlovchi qoidalar</b></div></div><div class="CLAUSE_DEFAULT"><div name="-8096213" id="-8096213">59-modda. Jismoniy tarbiya va sport sohasidagi xalqaro hamkorlik</div></div><div class="ACT_TEXT"><div name="-8096214" id="-8096214">Jismoniy tarbiya va sport sohasidagi xalqaro hamkorlik xalqaro huquqning umum eʼtirof etilgan prinsiplari va normalari, shuningdek Oʻzbekiston Respublikasining xalqaro shartnomalari va qonunchiligi asosida amalga oshiriladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096215" id="-8096215">60-modda. Nizolarni hal etish</div></div><div class="ACT_TEXT"><div name="-8096216" id="-8096216">Jismoniy tarbiya va sport sohasidagi nizolar qonunchilikda belgilangan tartibda hal etiladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096217" id="-8096217">61-modda. Jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikni buzganlik uchun javobgarlik</div></div><div class="ACT_TEXT"><div name="-8096218" id="-8096218">Jismoniy tarbiya va sport toʻgʻrisidagi qonunchilikni buzganlikda aybdor shaxslar belgilangan tartibda javobgar boʻladi.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096219" id="-8096219">62-modda. Oʻzbekiston Respublikasining ayrim qonun hujjatlarini oʻz kuchini yoʻqotgan deb topish</div></div><div class="ACT_TEXT"><div name="-8096220" id="-8096220">Quyidagilar oʻz kuchini yoʻqotgan deb topilsin:</div></div><div class="ACT_TEXT"><div name="-8096221" id="-8096221">1) Oʻzbekiston Respublikasining 1992-yil 14-yanvarda qabul qilingan “Jismoniy tarbiya va sport toʻgʻrisida”gi 513-XII-sonli <a href="https://lex.uz/docs/-10860">Qonuni </a>(Oʻzbekiston Respublikasi Oliy Kengashining Axborotnomasi, 1992-yil, № 3, 160-modda);</div></div><div class="ACT_TEXT"><div name="-8096222" id="-8096222">2) Oʻzbekiston Respublikasi Oliy Kengashining 1992-yil 14-yanvarda qabul qilingan “Jismoniy tarbiya va sport toʻgʻrisida”gi Oʻzbekiston Respublikasi Qonunini amalga kiritish haqida”gi 514-XII-sonli <a href="https://lex.uz/docs/-64485">Qarori </a>(Oʻzbekiston Respublikasi Oliy Kengashining Axborotnomasi, 1992-yil, № 3, 161-modda);</div></div><div class="ACT_TEXT"><div name="-8096223" id="-8096223">3) Oʻzbekiston Respublikasining 1994-yil 6-mayda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonunlariga oʻzgartishlar va qoʻshimchalar kiritish toʻgʻrisida”gi 1086-XII-sonli <a href="https://lex.uz/docs/-116861">Qonuni </a>(Oʻzbekiston Respublikasi Oliy Kengashining Axborotnomasi, 1994-yil, № 5, 161-modda);</div></div><div class="ACT_TEXT"><div name="-8096224" id="-8096224">4) Oʻzbekiston Respublikasining 2000-yil 26-mayda qabul qilingan “Jismoniy tarbiya va sport toʻgʻrisida”gi Oʻzbekiston Respublikasi Qonuniga oʻzgartishlar va qoʻshimchalar kiritish haqida”gi 76-II-sonli <a href="https://lex.uz/docs/-63106">Qonuni </a>(Oʻzbekiston Respublikasi Oliy Majlisining Axborotnomasi, 2000-yil, № 5-6, 147-modda);</div></div><div class="ACT_TEXT"><div name="-8096225" id="-8096225">5) Oʻzbekiston Respublikasining 2005-yil 15-sentabrda qabul qilingan “Baʼzi davlat boshqaruv organlarining qayta tashkil etilganligi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartishlar kiritish toʻgʻrisida”gi OʻRQ-5-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2005-yil, № 9, 309-modda) <a href="https://lex.uz/docs/-857283?ONDATE=16.09.2005 00#-871615">1-moddasi;</a></div></div><div class="ACT_TEXT"><div name="-8096226" id="-8096226">6) Oʻzbekiston Respublikasining 2015-yil 4-sentabrda qabul qilingan “Jismoniy tarbiya va sport toʻgʻrisida”gi Oʻzbekiston Respublikasi Qonuniga oʻzgartish va qoʻshimchalar kiritish haqida”gi OʻRQ-394-sonli <a href="https://lex.uz/docs/-2742233">Qonuni </a>(Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2015-yil, № 9, 340-modda);</div></div><div class="ACT_TEXT"><div name="-8096227" id="-8096227">7) Oʻzbekiston Respublikasining 2016-yil 26-dekabrda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-416-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2016-yil, № 12, 383-modda) <a href="https://lex.uz/docs/-3084099?ONDATE=27.12.2016 00#-3084181">5-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096228" id="-8096228">8) Oʻzbekiston Respublikasining 2017-yil 13-iyunda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish, shuningdek ayrim qonun hujjatlarini oʻz kuchini yoʻqotgan deb topish toʻgʻrisida”gi OʻRQ-436-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2017-yil, № 6, 300-modda) <a href="https://lex.uz/docs/-3235501?ONDATE=14.06.2017 00#-3235529">4-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096230" id="-8096230">9) Oʻzbekiston Respublikasining 2018-yil 3-yanvarda qabul qilingan “Ayrim davlat organlari faoliyati takomillashtirilishi, shuningdek fuqarolarning huquqlari va erkinliklarini himoya qilish kafolatlarini taʼminlashga doir qoʻshimcha chora-tadbirlar qabul qilinishi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-456-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2018-yil, № 1, 1-modda) <a href="https://lex.uz/docs/-3486595?ONDATE=05.01.2018 02#-3487275">4-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096231" id="-8096231">10) Oʻzbekiston Respublikasining 2018-yil 23-iyulda qabul qilingan “Baʼzi davlat organlari va tashkilotlarining faoliyati takomillashtirilishi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-486-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2018-yil, № 7, 431-modda) <a href="https://lex.uz/docs/-3832383?ONDATE=24.07.2018 00#-3832654">2-moddasi;</a></div></div><div class="ACT_TEXT"><div name="-8096232" id="-8096232">11) Oʻzbekiston Respublikasining 2020-yil 3-dekabrda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-653-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2020-yil, № 12, 691-modda) <a href="https://lex.uz/docs/-5140909?ONDATE=04.12.2020 00#-5143243">2-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096233" id="-8096233">12) Oʻzbekiston Respublikasining 2021-yil 21-aprelda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartishlar kiritish toʻgʻrisida”gi OʻRQ-683-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2021-yil, 4-songa ilova) <a href="https://lex.uz/docs/-5388561?ONDATE=21.04.2021 00#-5389805">13-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096234" id="-8096234">13) Oʻzbekiston Respublikasining 2021-yil 12-oktabrda qabul qilingan “Litsenziyalash, ruxsat berish va xabardor qilish tartib-taomillari toʻgʻrisida”gi Oʻzbekiston Respublikasi Qonuni qabul qilinganligi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish haqida”gi OʻRQ-721-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2021-yil, № 10, 968-modda) <a href="https://lex.uz/docs/-5674701?ONDATE=12.10.2021 00#-5674713">1-moddasi;</a></div></div><div class="ACT_TEXT"><div name="-8096235" id="-8096235">14) Oʻzbekiston Respublikasining 2022-yil 17-mayda qabul qilingan “Oʻzbekiston Respublikasida tibbiy-ijtimoiy xizmatlar tizimi takomillashtirilishi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartishlar kiritish toʻgʻrisida”gi OʻRQ-770-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2022-yil, № 5, 464-modda) <a href="https://lex.uz/docs/-6020838?ONDATE=18.05.2022 00#-6023885">3-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096236" id="-8096236">15) Oʻzbekiston Respublikasining 2022-yil 3-noyabrda qabul qilingan “Standartlashtirish toʻgʻrisida”gi OʻRQ-800-sonli Qonuni (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2022-yil, № 11, 1061-modda) 28-moddasi birinchi qismining <a href="https://lex.uz/docs/-6270526?ONDATE=05.11.2023 00#-6272230">1-bandi;</a></div></div><div class="ACT_TEXT"><div name="-8096237" id="-8096237">16) Oʻzbekiston Respublikasining 2023-yil 20-yanvarda qabul qilingan “Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-815-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2023-yil, № 1, 2-modda) <a href="https://lex.uz/docs/-6364848?ONDATE=21.01.2023 00#-6365216">1-moddasi</a>;</div></div><div class="ACT_TEXT"><div name="-8096238" id="-8096238">17) Oʻzbekiston Respublikasining 2024-yil 7-sentabrda qabul qilingan “Maʼmuriy islohotlar doirasida taʼlim sohasida davlat boshqaruvi takomillashtirilishi munosabati bilan Oʻzbekiston Respublikasining ayrim qonun hujjatlariga oʻzgartirish va qoʻshimchalar kiritish toʻgʻrisida”gi OʻRQ-957-sonli Qonunining (Oʻzbekiston Respublikasi Oliy Majlisi palatalarining Axborotnomasi, 2024-yil, № 9, 958-modda) <a href="https://lex.uz/docs/-7093724?ONDATE=09.09.2024 01#-7093898">2-moddasi.</a></div></div><div class="CLAUSE_DEFAULT"><div name="-8096239" id="-8096239">63-modda. Ushbu Qonunning ijrosini, yetkazilishini, mohiyati va ahamiyati tushuntirilishini taʼminlash</div></div><div class="ACT_TEXT"><div name="-8096240" id="-8096240">Oʻzbekiston Respublikasi Sport vazirligi va boshqa manfaatdor tashkilotlar ushbu Qonunning ijrosini, ijrochilarga yetkazilishini hamda mohiyati va ahamiyati aholi oʻrtasida tushuntirilishini taʼminlasin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096241" id="-8096241">64-modda. Qonunchilikni ushbu Qonunga muvofiqlashtirish</div></div><div class="ACT_TEXT"><div name="-8096242" id="-8096242">Oʻzbekiston Respublikasi Vazirlar Mahkamasi:</div></div><div class="ACT_TEXT"><div name="-8096243" id="-8096243">hukumat qarorlarini ushbu Qonunga muvofiqlashtirsin;</div></div><div class="ACT_TEXT"><div name="-8096244" id="-8096244">ushbu Qonun 7-moddasi birinchi qismining <a href="https://lex.uz/docs/-8093787#-8095573">sakkizinchi xatboshisida</a> nazarda tutilgan jismoniy tarbiya va sport musobaqalari hamda tadbirlarini oʻtkazish qoidalarini ushbu Qonun rasmiy eʼlon qilingan kundan eʼtiboran uch oy ichida ishlab chiqsin va tasdiqlasin;</div></div><div class="ACT_TEXT"><div name="-8096245" id="-8096245">ushbu Qonun 24-moddasining <a href="https://lex.uz/docs/-8093787#-8095759">yettinchi qismida</a> nazarda tutilgan Nodavlat jismoniy tarbiya va sport tashkilotlari reyestrini shakllantirish, yuritish hamda reyestrdan chiqarish tartibini ushbu Qonun rasmiy eʼlon qilingan kundan eʼtiboran uch oy ichida ishlab chiqsin va tasdiqlasin;</div></div><div class="ACT_TEXT"><div name="-8096246" id="-8096246">ushbu Qonun 26-moddasining <a href="https://lex.uz/docs/-8093787#-8095770">beshinchi qismida</a> nazarda tutilgan sport ligasining faoliyat yuritish tartibini, shuningdek sport ligalari tomonidan professional sport musobaqalarini tashkil etish va oʻtkazish tartibini ushbu Qonun rasmiy eʼlon qilingan kundan eʼtiboran uch oy ichida ishlab chiqsin hamda tasdiqlasin;</div></div><div class="ACT_TEXT"><div name="-8096247" id="-8096247">ushbu Qonun 37-moddasining <a href="https://lex.uz/docs/-8093787#-8095938">yettinchi qismida</a> nazarda tutilgan sport agenti faoliyatini amalga oshirish tartibini ushbu Qonun rasmiy eʼlon qilingan kundan eʼtiboran uch oy ichida ishlab chiqsin va tasdiqlasin;</div></div><div class="ACT_TEXT"><div name="-8096248" id="-8096248">respublika ijro etuvchi hokimiyat organlari ushbu Qonunga zid boʻlgan oʻz normativ-huquqiy hujjatlarini qayta koʻrib chiqishlari va bekor qilishlarini taʼminlasin.</div></div><div class="CLAUSE_DEFAULT"><div name="-8096249" id="-8096249">65-modda. Ushbu Qonunning kuchga kirishi</div></div><div class="ACT_TEXT"><div name="-8096250" id="-8096250">Ushbu Qonun rasmiy eʼlon qilingan kundan eʼtiboran kuchga kiradi.</div></div><div class="ACT_TEXT"><div name="-8096251" id="-8096251">Ushbu Qonunning 24-moddasi <a href="https://lex.uz/docs/-8093787#-8095756">toʻrtinchi — yettinchi qismlari</a>, <a href="https://lex.uz/docs/-8093787#-8095764">26,</a> <a href="https://lex.uz/docs/-8093787#-8095923">37-moddalari</a> mazkur Qonun kuchga kirgan kundan eʼtiboran uch oy oʻtgach amalga kiritiladi.</div></div><div class="SIGNATURE"><div name="-8096252" id="-8096252"><b>Oʻzbekiston Respublikasining Prezidenti Sh. MIRZIYOYEV</b></div></div><div class="ACT_ESSENTIAL_ELEMENTS"><div name="-8096253" id="-8096253">Toshkent sh.,</div></div><div class="ACT_ESSENTIAL_ELEMENTS"><div name="-8096254" id="-8096254">2026-yil 24-mart,</div></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><div name="-8096255" id="-8096255">OʻRQ-<span translate="no">1123</span>-son</div></div><div class="PUBLICATION_ORIGIN"><label id="s1089"></label><div name="-8095491" id="-8095491">(Qonunchilik maʼlumotlari milliy bazasi, 25.03.2026-y., 03/26/1123/0271-son)</div></div></div>
