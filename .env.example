# .env namunasi
# Lokal uchun `.env` yarating: `cp .env.example .env`
#
# Eslatma:
# - `manage.py` default `config.settings.dev` bilan ishlaydi (SQLite).
# - Productionda `DJANGO_SETTINGS_MODULE=config.settings.prod` qo'ying.

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=your-strong-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

# CORS (ixtiyoriy)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production DB (prod.py `DATABASE_URL` bo'lsa Postgresga o'tadi)
DATABASE_URL=postgres://user:password@host:5432/dbname

# ImageKit (Production uchun majburiy)
IMAGEKIT_PUBLIC_KEY=your-public-key-here
IMAGEKIT_PRIVATE_KEY=your-private-key-here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-endpoint
